# App
APP_ENV=development
APP_URL=http://localhost:4321

# Supabase (server-side)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Supabase (client-side — prefix PUBLIC_ para Astro expor ao browser)
PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_NOME_MAGNETICO=price_xxxx
STRIPE_PRICE_NOME_BEBE=price_xxxx
STRIPE_PRICE_NOME_EMPRESA=price_xxxx

# IA — Groq (development)
GROQ_API_KEY=gsk_xxxx

# IA — Claude (production)
ANTHROPIC_API_KEY=sk-ant-xxxx

# IA — OpenAI (fallback)
OPENAI_API_KEY=sk-xxxx

# N8N Webhooks
N8N_WEBHOOK_URL=https://n8n.seudominio.com.br/webhook
N8N_WEBHOOK_SECRET=your_webhook_secret

# Rate Limiting
RATE_LIMIT_TESTE_BLOQUEIO=3
