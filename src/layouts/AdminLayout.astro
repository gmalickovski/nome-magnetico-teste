---
import BaseLayout from './BaseLayout.astro';
import { supabase } from '../backend/db/supabase';

export interface Props {
  title: string;
}

const { title } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login');
}

const { data: profile } = await supabase
  
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single();

if (profile?.role !== 'admin') {
  return Astro.redirect('/app');
}

const adminNavItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/usuarios', label: 'Usuários' },
  { href: '/admin/assinaturas', label: 'Assinaturas' },
  { href: '/admin/ia', label: 'Config. IA' },
];
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<BaseLayout title={`Admin — ${title}`} noIndex={true}>
  <div class="min-h-screen bg-[#111111] flex flex-col md:flex-row">
    
    <!-- Mobile Header -->
    <header class="border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40 md:hidden w-full">
      <div class="px-4 py-4 flex items-center justify-between relative">
        <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/app'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </button>
        <a href="/app" class="font-cinzel text-xl font-bold text-[#D4AF37] tracking-wider absolute left-1/2 -translate-x-1/2">
          NOME MAGNÉTICO
        </a>
        <button id="mobileAdminMenuBtn" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobileAdminMenu" class="fixed inset-0 bg-[#111111]/95 backdrop-blur-xl z-50 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col">
      <div class="px-4 py-4 flex items-center justify-between border-b border-[#D4AF37]/20">
        <span class="font-cinzel text-xl font-bold text-[#D4AF37] tracking-wider">ADMIN</span>
        <button id="closeAdminMenuBtn" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <nav class="flex flex-col p-6 gap-6">
        {adminNavItems.map(item => (
          <a
            href={item.href}
            class={`text-lg transition-colors ${
              Astro.url.pathname === item.href ? 'text-[#D4AF37]' : 'text-gray-300'
            }`}
          >
            {item.label}
          </a>
        ))}
        <div class="h-px bg-[#D4AF37]/20 my-2"></div>
        <a href="/app" class="text-left text-lg text-purple-400 hover:text-purple-300 transition-colors mt-2">
          Voltar ao App
        </a>
      </nav>
    </div>

    <!-- Desktop Sidebar -->
    <aside class="hidden md:flex w-64 border-r border-[#D4AF37]/20 bg-[#0a0a0a] flex-shrink-0 flex-col">
      <div class="p-6">
        <h1 class="font-cinzel text-lg font-bold text-[#D4AF37]">Nome Magnético</h1>
        <p class="text-xs text-gray-500 mt-1">Painel Administrativo</p>
      </div>
      <nav class="px-3 pb-6">
        {adminNavItems.map(item => (
          <a
            href={item.href}
            class={`flex items-center px-3 py-2 rounded-xl text-sm transition-colors mb-1 ${
              Astro.url.pathname === item.href
                ? 'bg-[#D4AF37]/10 text-[#D4AF37] border border-[#D4AF37]/20'
                : 'text-gray-400 hover:text-gray-200 hover:bg-white/5'
            }`}
          >
            {item.label}
          </a>
        ))}
        <div class="mt-6 pt-6 border-t border-white/10">
          <a href="/app" class="flex items-center px-3 py-2 rounded-xl text-sm text-gray-500 hover:text-gray-300 transition-colors">
            ← Voltar ao App
          </a>
        </div>
      </nav>
    </aside>

    <!-- Conteúdo -->
    <main class="flex-1 overflow-auto pb-24 md:pb-0">
      <div class="p-4 md:p-8 max-w-5xl mx-auto">
        <slot />
      </div>
    </main>

    <!-- Bottom Navigation (Mobile) -->
    <nav class="fixed bottom-0 left-0 right-0 bg-[#111111]/95 backdrop-blur-xl border-t border-[#D4AF37]/20 z-40 md:hidden flex items-center justify-around py-2 px-2 pb-safe">
      <a href="/app" class="flex flex-col items-center gap-1 p-2 group relative">
        <div class={`absolute -top-3 left-1/2 -translate-x-1/2 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 ${isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises') && !pathname.startsWith('/admin') ? 'bg-[#D4AF37] shadow-[0_4px_12px_rgba(212,175,55,0.4)] translate-y-0 opacity-100' : 'bg-transparent translate-y-2 opacity-0'}`}>
          <svg class="w-5 h-5 text-[#111]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L20 9V21H15V14H9V21H4V9L12 3Z"></path></svg>
        </div>
        <svg class={`w-6 h-6 transition-all duration-300 ${isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises') && !pathname.startsWith('/admin') ? 'opacity-0 scale-50' : 'text-gray-500 group-hover:text-gray-300 opacity-100 scale-100'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        <span class={`text-[10px] font-medium tracking-wide transition-colors ${isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises') && !pathname.startsWith('/admin') ? 'text-[#D4AF37]' : 'text-gray-500 group-hover:text-gray-300'}`}>Início</span>
      </a>

      <a href="/app/analises" class="flex flex-col items-center gap-1 p-2 group relative">
        <div class={`absolute -top-3 left-1/2 -translate-x-1/2 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 ${isActive('/app/analises') || isActive('/app/resultado') ? 'bg-[#D4AF37] shadow-[0_4px_12px_rgba(212,175,55,0.4)] translate-y-0 opacity-100' : 'bg-transparent translate-y-2 opacity-0'}`}>
          <svg class="w-5 h-5 text-[#111]" fill="currentColor" viewBox="0 0 24 24"><path d="M14.5 9C13.67 9 13 8.33 13 7.5C13 6.67 13.67 6 14.5 6C15.33 6 16 6.67 16 7.5C16 8.33 15.33 9 14.5 9ZM12 2L21 6V11C21 16.55 17.16 21.74 12 23C6.84 21.74 3 16.55 3 11V6L12 2ZM12 4.14L5 7.25V11C5 15.46 7.95 19.56 12 20.93C16.05 19.56 19 15.46 19 11V7.25L12 4.14Z"></path></svg>
        </div>
        <svg class={`w-6 h-6 transition-all duration-300 ${isActive('/app/analises') || isActive('/app/resultado') ? 'opacity-0 scale-50' : 'text-gray-500 group-hover:text-gray-300 opacity-100 scale-100'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        <span class={`text-[10px] font-medium tracking-wide transition-colors ${isActive('/app/analises') || isActive('/app/resultado') ? 'text-[#D4AF37]' : 'text-gray-500 group-hover:text-gray-300'}`}>Análises</span>
      </a>

      <!-- Admin Indicator when active-->
      <a href="/admin" class="flex flex-col items-center gap-1 p-2 group relative">
        <div class={`absolute -top-3 left-1/2 -translate-x-1/2 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 ${pathname.startsWith('/admin') ? 'bg-purple-500 shadow-[0_4px_12px_rgba(168,85,247,0.4)] translate-y-0 opacity-100' : 'bg-transparent translate-y-2 opacity-0'}`}>
           <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"></path></svg>
        </div>
        <svg class={`w-6 h-6 transition-all duration-300 ${pathname.startsWith('/admin') ? 'opacity-0 scale-50' : 'text-gray-500 group-hover:text-gray-300 opacity-100 scale-100'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        <span class={`text-[10px] font-medium tracking-wide transition-colors ${pathname.startsWith('/admin') ? 'text-purple-400' : 'text-gray-500 group-hover:text-gray-300'}`}>Admin</span>
      </a>

      <!-- Perfil Placeholder -->
      <a href="/app" class="flex flex-col items-center gap-1 p-2">
        <svg class="w-6 h-6 text-gray-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide text-gray-500">Perfil</span>
      </a>
    </nav>
  </div>

  <script>
    const btnOpen = document.getElementById('mobileAdminMenuBtn');
    const btnClose = document.getElementById('closeAdminMenuBtn');
    const menu = document.getElementById('mobileAdminMenu');

    if (btnOpen && btnClose && menu) {
      btnOpen.addEventListener('click', () => {
        menu.classList.remove('translate-x-full');
      });
      btnClose.addEventListener('click', () => {
        menu.classList.add('translate-x-full');
      });
    }
  </script>
</BaseLayout>
