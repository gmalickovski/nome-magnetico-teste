---
import BaseLayout from './BaseLayout.astro';
import { supabase } from '../backend/db/supabase';
import AvatarMenu from '../frontend/components/app/AvatarMenu';

export interface Props {
  title: string;
}

const { title } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login');
}

const { data: profile } = await supabase
  
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single();

if (profile?.role !== 'admin') {
  return Astro.redirect('/app');
}

const adminNavItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/usuarios', label: 'Usuários' },
  { href: '/admin/suporte', label: 'Suporte' },
  { href: '/admin/ia', label: 'Config. IA' },
];
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<BaseLayout title={`Admin — ${title}`} noIndex={true} hasBottomNav={true}>
  <div class="min-h-screen bg-[#111111] flex flex-col md:flex-row">
    
    <!-- Mobile Header -->
    <header class="border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40 md:hidden w-full">
      <div class="px-4 py-4 flex items-center justify-between relative">
        {pathname !== '/admin' && pathname !== '/admin/' ? (
          <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/admin'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          </button>
        ) : (
          <div class="w-6 h-6"></div>
        )}
        <a href="/app" class="font-cinzel text-base sm:text-lg md:text-xl font-bold text-[#D4AF37] tracking-wider whitespace-nowrap absolute left-1/2 -translate-x-1/2">
          NOME MAGNÉTICO
        </a>
        <div class="flex items-center justify-end w-8">
          <AvatarMenu client:load nome="Admin" />
        </div>
      </div>
    </header>

    <!-- Mobile Bottom Navigation -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#111111]/95 backdrop-blur-xl border-t border-[#D4AF37]/20 z-50 flex items-center justify-around pt-2" style="padding-bottom: max(0.5rem, env(safe-area-inset-bottom)); transform: translateZ(0); will-change: transform;">
      <a href="/admin" class={`flex flex-col items-center p-2 transition-colors ${isActive('/admin') && !isActive('/admin/usuarios') && !isActive('/admin/suporte') && !isActive('/admin/ia') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Dashboard</span>
      </a>
      <a href="/admin/usuarios" class={`flex flex-col items-center p-2 transition-colors ${isActive('/admin/usuarios') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Usuários</span>
      </a>
      <a href="/admin/suporte" class={`flex flex-col items-center p-2 transition-colors ${isActive('/admin/suporte') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Suporte</span>
      </a>
      <a href="/admin/ia" class={`flex flex-col items-center p-2 transition-colors ${isActive('/admin/ia') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Config. IA</span>
      </a>
      <a href="/app" class="flex flex-col items-center p-2 text-gray-500 hover:text-purple-400 transition-colors">
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Voltar App</span>
      </a>
    </nav>

    <!-- Desktop Sidebar -->
    <aside class="hidden md:flex w-64 border-r border-[#D4AF37]/20 bg-[#0a0a0a] flex-shrink-0 flex-col fixed inset-y-0 left-0 z-40">
      <div class="p-6">
        <h1 class="font-cinzel text-lg font-bold text-[#D4AF37]">Nome Magnético</h1>
        <p class="text-xs text-gray-500 mt-1">Painel Administrativo</p>
      </div>
      <nav class="px-3 pb-6">
        {adminNavItems.map(item => (
          <a
            href={item.href}
            class={`flex items-center px-3 py-2 rounded-xl text-sm transition-colors mb-1 ${
              Astro.url.pathname === item.href
                ? 'bg-[#D4AF37]/10 text-[#D4AF37] border border-[#D4AF37]/20'
                : 'text-gray-400 hover:text-gray-200 hover:bg-white/5'
            }`}
          >
            {item.label}
          </a>
        ))}
        <div class="mt-6 pt-6 border-t border-white/10">
          <a href="/app" class="flex items-center px-3 py-2 rounded-xl text-sm text-gray-500 hover:text-gray-300 transition-colors">
            &lt; Voltar ao App
          </a>
        </div>
      </nav>
    </aside>

    <!-- Conteúdo -->
    <main class="flex-1 w-full overflow-auto pb-24 md:pb-0 md:ml-64">
      <div class="p-4 md:p-8 max-w-5xl mx-auto">
        <slot />
      </div>
    </main>

  </div>

  <!-- Ocultar balão do Chatwoot nas páginas admin -->
  <script is:inline>
    function _hideChatwootAdmin() {
      if (window.$chatwoot) window.$chatwoot.toggleBubbleVisibility('hide');
    }
    if (window.$chatwoot) {
      _hideChatwootAdmin();
    } else {
      window.addEventListener('chatwoot:ready', _hideChatwootAdmin);
    }
  </script>

</BaseLayout>
