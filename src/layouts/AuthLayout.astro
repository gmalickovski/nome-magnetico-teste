---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-[#111111] relative flex flex-col overflow-hidden">

    <!-- Glow ambiente -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#D4AF37]/6 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-purple-500/4 rounded-full blur-[80px] pointer-events-none"></div>

    <!-- Top bar — fixa, com hide-on-scroll -->
    <header
      id="auth-header"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    >
      <div class="w-full max-w-md mx-auto px-5 py-3 flex items-center justify-between">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-gray-500 hover:text-[#D4AF37] text-sm transition-colors duration-200"
          aria-label="Voltar à página inicial"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Início
        </a>

        <a href="/" class="transform hover:scale-105 transition-transform duration-300">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-8 w-auto" />
        </a>

        <!-- Spacer para centralizar logo -->
        <div class="w-14"></div>
      </div>
      <!-- Separador dourado sutil (visível ao rolar) -->
      <div id="auth-header-divider" class="w-full max-w-md mx-auto px-5 opacity-0 transition-opacity duration-300">
        <div class="h-px bg-gradient-to-r from-transparent via-[#D4AF37]/20 to-transparent"></div>
      </div>
    </header>

    <!-- Conteúdo (form card) — compensar header fixo -->
    <main class="relative z-10 flex-1 flex flex-col items-center justify-start px-5 pt-[68px] pb-4 w-full max-w-md mx-auto">
      <slot />
    </main>

    <!-- Footer mínimo -->
    <footer class="relative z-10 w-full max-w-md mx-auto px-5 pb-5 pt-2 text-center">
      <p class="text-gray-600 text-xs">
        &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
      </p>
    </footer>

  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var header = document.getElementById('auth-header');
    var divider = document.getElementById('auth-header-divider');
    var lastY = 0;

    window.addEventListener('scroll', function () {
      var y = window.scrollY;
      // Background ao rolar
      if (y > 10) {
        header.style.backgroundColor = 'rgba(17,17,17,0.92)';
        header.style.backdropFilter = 'blur(12px)';
        header.style.webkitBackdropFilter = 'blur(12px)';
        divider.style.opacity = '1';
      } else {
        header.style.backgroundColor = 'transparent';
        header.style.backdropFilter = 'none';
        header.style.webkitBackdropFilter = 'none';
        divider.style.opacity = '0';
      }
      // Hide ao descer, show ao subir
      if (y > lastY && y > 60) {
        header.style.transform = 'translateY(-100%)';
      } else {
        header.style.transform = 'translateY(0)';
      }
      lastY = y;
    }, { passive: true });
  })();
</script>
