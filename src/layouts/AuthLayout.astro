---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-[#111111] relative flex flex-col items-center justify-center p-4 overflow-hidden">
    <!-- Dourado glow no fundo -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#D4AF37]/5 rounded-full blur-[120px] pointer-events-none"></div>
    
    <div class="w-full max-w-md relative z-10 flex flex-col">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block transform transition-transform hover:scale-105 duration-300">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-10 sm:h-12 w-auto mx-auto" />
        </a>
        <div class="h-px bg-gradient-to-r from-transparent via-[#D4AF37]/30 to-transparent mt-4 max-w-[80%] mx-auto"></div>
      </div>

      <!-- Voltar -->
      <div class="text-center mb-6">
        <a href="/" class="inline-flex items-center gap-2 text-gray-400 hover:text-[#D4AF37] text-sm transition-all duration-300">
          <span class="text-lg leading-none">&lt;</span> Voltar ao início
        </a>
      </div>

      <!-- Conteúdo -->
      <slot />

      <!-- Footer mínimo -->
      <p class="text-center text-gray-500 text-sm mt-8">
        &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
      </p>
    </div>
  </div>
</BaseLayout>
