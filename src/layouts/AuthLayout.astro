---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-[#111111] flex">

    <!-- ── Painel esquerdo — hero (oculto no mobile) ── -->
    <div class="hidden lg:flex lg:w-1/2 xl:w-[55%] relative flex-col items-center justify-center overflow-hidden">
      <!-- Camadas de glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1400] via-[#111111] to-[#0d0d1a]"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#D4AF37]/8 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-purple-500/6 rounded-full blur-[100px] pointer-events-none"></div>

      <!-- Conteúdo hero -->
      <div class="relative z-10 flex flex-col items-center text-center px-12 max-w-lg">
        <a href="/" class="inline-block mb-10 hover:opacity-80 transition-opacity duration-300">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-14 w-auto" />
        </a>

        <h1 class="font-cinzel text-3xl xl:text-4xl font-bold text-[#e5e2e1] leading-tight mb-4">
          Descubra o poder<br/>vibratório do seu nome
        </h1>
        <p class="text-gray-500 text-base leading-relaxed max-w-sm">
          Análise cabalística completa com 4 triângulos numerológicos, detecção de bloqueios energéticos e sugestões de nomes harmoniosos.
        </p>

        <!-- Separador dourado -->
        <div class="h-px w-24 bg-gradient-to-r from-transparent via-[#D4AF37]/50 to-transparent mt-8"></div>

        <!-- Ícones decorativos / números -->
        <div class="flex items-center gap-6 mt-8 text-[#D4AF37]/30">
          <span class="font-cinzel text-5xl font-bold select-none">11</span>
          <span class="font-cinzel text-3xl font-bold select-none">✦</span>
          <span class="font-cinzel text-5xl font-bold select-none">22</span>
        </div>
        <p class="text-gray-700 text-xs mt-3 font-light tracking-widest uppercase">Números Mestres</p>
      </div>

      <!-- Bordas decorativas -->
      <div class="absolute inset-y-0 right-0 w-px bg-gradient-to-b from-transparent via-[#D4AF37]/15 to-transparent"></div>
    </div>

    <!-- ── Painel direito — formulário ── -->
    <div class="flex-1 lg:w-1/2 xl:w-[45%] flex flex-col items-center justify-center relative overflow-hidden">
      <!-- Glow mobile (visível apenas sem o painel esquerdo) -->
      <div class="lg:hidden absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-[#D4AF37]/5 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-0 w-64 h-64 bg-purple-500/4 rounded-full blur-[80px] pointer-events-none"></div>

      <div class="relative z-10 w-full max-w-md px-6 py-10 flex flex-col">
        <!-- Logo mobile (oculta no desktop pois aparece no painel esquerdo) -->
        <div class="lg:hidden text-center mb-8">
          <a href="/" class="inline-block hover:opacity-80 transition-opacity duration-300">
            <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-10 w-auto mx-auto" />
          </a>
          <div class="h-px bg-gradient-to-r from-transparent via-[#D4AF37]/25 to-transparent mt-5 max-w-[70%] mx-auto"></div>
        </div>

        <!-- Slot do formulário -->
        <slot />

        <!-- Voltar ao início -->
        <div class="text-center mt-6">
          <a
            href="/"
            class="inline-flex items-center gap-1.5 text-gray-600 hover:text-[#D4AF37] text-sm transition-colors duration-200"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Voltar ao início
          </a>
        </div>

        <!-- Footer mínimo -->
        <p class="text-gray-700 text-xs text-center mt-8">
          &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
        </p>
      </div>
    </div>

  </div>
</BaseLayout>
