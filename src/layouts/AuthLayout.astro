---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-slate-950 flex relative justify-center">

    <!-- Background global contínuo (unificando esquerda e direita) -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(212,175,55,0.10),transparent_34%),linear-gradient(135deg,#020617_0%,#0f172a_48%,#020617_100%)]"></div>
      <div class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(rgba(229,226,225,0.16) 1px, transparent 1px), linear-gradient(90deg, rgba(229,226,225,0.16) 1px, transparent 1px); background-size: 48px 48px;"></div>
    </div>

    <!-- Container do Layout Flexível (Espaçamentos perfeitamente iguais) -->
    <div class="w-full flex justify-evenly relative z-10">

      <!-- ── Painel esquerdo — hero (oculto no mobile) ── -->
      <div class="hidden lg:flex flex-col items-start justify-center flex-none w-full max-w-lg">

        <!-- Conteúdo hero -->
        <div class="flex flex-col items-start text-left w-full">
        <a href="/" class="inline-block mb-12 hover:opacity-80 transition-opacity duration-300">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-12 w-auto" />
        </a>

        <h1 class="font-cinzel text-3xl xl:text-4xl font-bold text-[#e5e2e1] leading-tight mb-5">
          Seu nome carrega<br/>uma frequência.<br/>
          <span class="text-[#D4AF37]">Você conhece a sua?</span>
        </h1>

        <p class="text-gray-500 text-[15px] leading-relaxed max-w-sm mb-8">
          Numerologia cabalística aplicada ao seu nome de nascimento — revela bloqueios energéticos e aponta o caminho para a sua expressão máxima.
        </p>

        <!-- Separador dourado -->
        <div class="h-px w-16 bg-gradient-to-r from-[#D4AF37]/50 to-transparent mb-8"></div>

        <!-- Bullets de benefícios -->
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">4 triângulos numerológicos</span>
              <p class="text-gray-600 text-xs mt-0.5">Vida, Pessoal, Social e Destino analisados em profundidade</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">Detecção de bloqueios energéticos</span>
              <p class="text-gray-600 text-xs mt-0.5">Sequências repetidas que travam sua expressão e relacionamentos</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">Sugestões de nomes harmoniosos</span>
              <p class="text-gray-600 text-xs mt-0.5">Variações sem bloqueios, compatíveis com sua Expressão e Destino</p>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- ── Painel direito — formulário ── -->
    <div class="w-full lg:w-[420px] flex flex-col relative z-10">

      <!-- Spacer superior para manter o centro perfeito -->
      <div class="flex-1 flex flex-col justify-start">
        <!-- Logo mobile (oculta no desktop) -->
        <div class="lg:hidden flex flex-col items-center text-center pt-8 px-6">
          <a href="/" class="inline-block hover:opacity-80 transition-opacity duration-300">
            <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-10 w-auto mx-auto" />
          </a>
        </div>
      </div>

      <!-- Área central: formulário (centralizado de forma independente) -->
      <div class="flex-none flex items-center justify-center px-6 lg:px-0 w-full py-2">
        <div class="relative w-full max-w-sm lg:max-w-full">
          <!-- Sombra mais suave e realista atrás do card -->
          <div class="absolute inset-0 bg-black/40 rounded-2xl blur-[25px] pointer-events-none translate-y-6"></div>
          
          <!-- Card do formulário -->
          <div class="relative z-10">
            <slot />
          </div>
        </div>
      </div>

      <!-- Spacer inferior (Rodapé) -->
      <div class="flex-1 flex flex-col justify-end">
        <div class="px-6 pb-6 text-center space-y-3">
          <a
            href="/"
            class="inline-flex items-center gap-1.5 text-gray-600 hover:text-[#D4AF37] text-sm transition-colors duration-200"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Voltar ao início
          </a>
          <p class="text-gray-700 text-xs">
            &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
          </p>
        </div>
      </div>

    </div>

    </div> <!-- Fecha Container do Layout Flexível -->

  </div>
</BaseLayout>
