---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-[#111111] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block">
          <h1 class="font-cinzel text-3xl font-bold text-[#D4AF37] tracking-wider">
            Nome Magnético
          </h1>
        </a>
        <div class="h-px bg-gradient-to-r from-transparent via-[#D4AF37]/50 to-transparent mt-3"></div>
      </div>

      <!-- Voltar -->
      <div class="text-center mb-6">
        <a href="/" class="inline-flex items-center gap-1 text-gray-500 hover:text-[#D4AF37] text-sm transition-colors">
          ← Voltar ao início
        </a>
      </div>

      <!-- Conteúdo -->
      <slot />

      <!-- Footer mínimo -->
      <p class="text-center text-gray-500 text-sm mt-8">
        &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
      </p>
    </div>
  </div>
</BaseLayout>
