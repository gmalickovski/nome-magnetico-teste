---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-[#111111] flex">

    <!-- ── Painel esquerdo — hero (oculto no mobile) ── -->
    <div class="hidden lg:flex lg:w-1/2 xl:w-[55%] relative flex-col items-center justify-center overflow-hidden">
      <!-- Camadas de glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1400] via-[#111111] to-[#0d0d1a]"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#D4AF37]/8 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-purple-500/6 rounded-full blur-[100px] pointer-events-none"></div>

      <!-- Conteúdo hero -->
      <div class="relative z-10 flex flex-col items-start text-left px-14 max-w-lg">
        <a href="/" class="inline-block mb-12 hover:opacity-80 transition-opacity duration-300">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-12 w-auto" />
        </a>

        <h1 class="font-cinzel text-3xl xl:text-4xl font-bold text-[#e5e2e1] leading-tight mb-5">
          Seu nome carrega<br/>uma frequência.<br/>
          <span class="text-[#D4AF37]">Você conhece a sua?</span>
        </h1>

        <p class="text-gray-500 text-[15px] leading-relaxed max-w-sm mb-8">
          Numerologia cabalística aplicada ao seu nome de nascimento — revela bloqueios energéticos e aponta o caminho para a sua expressão máxima.
        </p>

        <!-- Separador dourado -->
        <div class="h-px w-16 bg-gradient-to-r from-[#D4AF37]/50 to-transparent mb-8"></div>

        <!-- Bullets de benefícios -->
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">4 triângulos numerológicos</span>
              <p class="text-gray-600 text-xs mt-0.5">Vida, Pessoal, Social e Destino analisados em profundidade</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">Detecção de bloqueios energéticos</span>
              <p class="text-gray-600 text-xs mt-0.5">Sequências repetidas que travam sua expressão e relacionamentos</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">Sugestões de nomes harmoniosos</span>
              <p class="text-gray-600 text-xs mt-0.5">Variações sem bloqueios, compatíveis com sua Expressão e Destino</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Borda divisória -->
      <div class="absolute inset-y-0 right-0 w-px bg-gradient-to-b from-transparent via-[#D4AF37]/15 to-transparent"></div>
    </div>

    <!-- ── Painel direito — formulário ── -->
    <div class="flex-1 lg:w-1/2 xl:w-[45%] flex flex-col relative overflow-hidden bg-[#111111]">
      <!-- Glow ambiente -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[450px] bg-[#D4AF37]/4 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-0 w-64 h-64 bg-purple-500/4 rounded-full blur-[80px] pointer-events-none"></div>

      <!-- Logo mobile (oculta no desktop) -->
      <div class="lg:hidden flex-shrink-0 text-center pt-10 px-6">
        <a href="/" class="inline-block hover:opacity-80 transition-opacity duration-300">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-10 w-auto mx-auto" />
        </a>
        <div class="h-px bg-gradient-to-r from-transparent via-[#D4AF37]/25 to-transparent mt-5 max-w-[70%] mx-auto"></div>
      </div>

      <!-- Área central: formulário com glow dourado -->
      <div class="flex-1 flex items-center justify-center px-6 py-8">
        <div class="relative w-full max-w-sm">
          <!-- Glow dourado atrás do card -->
          <div class="absolute -inset-3 bg-[#D4AF37]/8 rounded-3xl blur-[28px] pointer-events-none"></div>
          <div class="absolute -inset-1 bg-[#D4AF37]/5 rounded-2xl blur-[10px] pointer-events-none"></div>
          <!-- Card do formulário -->
          <div class="relative z-10">
            <slot />
          </div>
        </div>
      </div>

      <!-- Rodapé fixo ao fundo -->
      <div class="flex-shrink-0 px-6 pb-8 text-center space-y-3">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-gray-600 hover:text-[#D4AF37] text-sm transition-colors duration-200"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Voltar ao início
        </a>
        <p class="text-gray-700 text-xs">
          &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
        </p>
      </div>
    </div>

  </div>
</BaseLayout>
