---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title = 'Descubra Seu Nome Magnético',
  description = 'Descubra se seu nome tem bloqueios energéticos que sabotam carreira e relacionamentos. Numerologia cabalística com mapa completo dos 4 triângulos, 5 números e sugestões de nome harmonizado.',
  keywords = 'numerologia cabalística, numerologia do nome, mapa numerológico, bloqueios energéticos nome, análise vibracional nome, nome magnético, significado do nome numerologia, nome para bebê numerologia, nome empresarial numerologia, cabala numerologia, como meu nome afeta minha vida, nome sem bloqueios, mudar nome numerologia, numerologia nome social, análise vibracional gratuita nome, mapa numerológico completo, arquétipo junguiano nome',
  ogImage = '/og-image.jpg',
} = Astro.props;

// Schema.org — WebSite principal
const schemaWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Nome Magnético',
  url: 'https://nomemagnetico.com.br',
  description,
  inLanguage: 'pt-BR',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://nomemagnetico.com.br/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

// Schema.org — SoftwareApplication / Service (com AggregateRating para estrelas no Google)
const schemaService = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Nome Magnético',
  url: 'https://nomemagnetico.com.br',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web',
  description: 'Análise de numerologia cabalística do nome de nascimento. Detecta bloqueios energéticos e sugere variações do nome compatíveis com os números de Expressão e Destino.',
  inLanguage: 'pt-BR',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    ratingCount: '87',
    bestRating: '5',
    worstRating: '1',
  },
  offers: [
    {
      '@type': 'Offer',
      name: 'Nome Social',
      description: 'Análise cabalística do nome social com mapa numerológico completo, 4 triângulos e variações de nome harmonizado.',
      price: '97.00',
      priceCurrency: 'BRL',
      availability: 'https://schema.org/InStock',
      url: 'https://nomemagnetico.com.br/comprar?produto=nome_social',
    },
    {
      '@type': 'Offer',
      name: 'Nome de Bebê',
      description: 'Análise e ranking de nomes candidatos para bebê com compatibilidade com o Destino da criança.',
      price: '147.00',
      priceCurrency: 'BRL',
      availability: 'https://schema.org/InStock',
      url: 'https://nomemagnetico.com.br/comprar?produto=nome_bebe',
    },
    {
      '@type': 'Offer',
      name: 'Nome Empresarial',
      description: 'Análise de nomes empresariais com compatibilidade com o Destino do fundador e posicionamento de marca.',
      price: '197.00',
      priceCurrency: 'BRL',
      availability: 'https://schema.org/InStock',
      url: 'https://nomemagnetico.com.br/comprar?produto=nome_empresa',
    },
  ],
  provider: {
    '@type': 'Organization',
    name: 'Studio MLK',
    url: 'https://nomemagnetico.com.br',
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'contato@nomemagnetico.com.br',
      contactType: 'customer service',
      availableLanguage: 'Portuguese',
    },
  },
};

// Schema.org — Organization (com knowsAbout para entity-linking 2026 — citação em AI Overviews)
const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Nome Magnético',
  alternateName: 'Nome Magnetico',
  url: 'https://nomemagnetico.com.br',
  logo: {
    '@type': 'ImageObject',
    url: 'https://nomemagnetico.com.br/logo-nome-magnetico.png',
    width: 200,
    height: 60,
  },
  description: 'Numerologia cabalística com análise de bloqueios energéticos no nome, mapa numerológico completo dos 4 triângulos e sugestões de nomes harmonizados com Expressão e Destino.',
  email: 'contato@nomemagnetico.com.br',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Viamão',
    addressRegion: 'RS',
    addressCountry: 'BR',
  },
  knowsAbout: [
    'Numerologia Cabalística',
    'Cabala',
    'Bloqueios Energéticos',
    'Mapa Numerológico',
    'Arquétipos Junguianos',
    'Branding Pessoal',
    'Desenvolvimento Pessoal',
    'Análise Vibracional',
  ],
  sameAs: [
    'https://www.instagram.com/nomemagnetico',
  ],
};

// Schema.org — HowTo (para "Como Funciona" — alta visibilidade em AI Overviews 2026)
const schemaHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Como funciona a análise de numerologia cabalística do Nome Magnético',
  description: 'O Método Nome Magnético analisa o nome de nascimento em 4 etapas usando numerologia cabalística para detectar bloqueios energéticos e encontrar o nome harmonizado ideal.',
  totalTime: 'PT5M',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'BRL',
    value: '97',
  },
  step: [
    {
      '@type': 'HowToStep',
      name: 'Mapeamento da Frequência Vibracional',
      text: 'Os 5 Números Fundamentais (Expressão, Destino, Motivação, Missão e Personalidade) são calculados a partir das letras do nome de nascimento, revelando a assinatura matemática única do nome.',
      position: 1,
    },
    {
      '@type': 'HowToStep',
      name: 'Detecção dos Bloqueios Invisíveis',
      text: 'Os 4 Triângulos Cabalísticos (Vida, Pessoal, Social e Destino) são analisados para identificar sequências repetitivas que criam bloqueios energéticos em carreira, relacionamentos e prosperidade.',
      position: 2,
    },
    {
      '@type': 'HowToStep',
      name: 'Revelação do Arquétipo Junguiano',
      text: 'Com base nos números calculados, o perfil magnético da pessoa é revelado — o Arquétipo Junguiano que define como o mundo percebe você e como você pode se posicionar com autenticidade.',
      position: 3,
    },
    {
      '@type': 'HowToStep',
      name: 'Geração do Nome Harmonizado',
      text: 'Variações do nome são geradas eliminando os bloqueios detectados e preservando a identidade, com harmonia perfeita entre Expressão e Destino. Um guia prático de 30 dias de implementação é entregue em PDF.',
      position: 4,
    },
  ],
};

// Schema.org — FAQPage (gera rich snippets no Google)
const schemaFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'O que é a numerologia cabalística?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'É a ciência exata de conversão de letras em números e cálculo de frequências. Baseada na tradição mística hebraica, oferece um mapa matemático profundo do seu nome de nascimento, unindo cabala, cálculos precisos e arquétipos junguianos.',
      },
    },
    {
      '@type': 'Question',
      name: 'Como os bloqueios energéticos no nome afetam minha vida?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cada letra do seu nome emite uma frequência matemática. Quando essas frequências se repetem em sequência (como 444, 555 ou 888) nos triângulos cabalísticos, criam padrões de atrito energético — os chamados bloqueios — que podem sabotar carreira, relacionamentos e prosperidade sem que você perceba a causa.',
      },
    },
    {
      '@type': 'Question',
      name: 'Como a mudança da assinatura remove bloqueios?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Mudando letras na assinatura, a equação do seu Triângulo da Vida muda, desmanchando sequências repetitivas que causam bloqueios visíveis em diversas áreas da vida. A análise encontra variações do seu nome que eliminam os bloqueios e preservam sua identidade.',
      },
    },
    {
      '@type': 'Question',
      name: 'O que o relatório completo entrega?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Uma interpretação profunda dos 5 números fundamentais, análise dos 4 triângulos cabalísticos, lições kármicas, tendências ocultas, top 3 Nomes Magnéticos personalizados com scoring numérico e Guia de Implementação de 30 dias em PDF.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quanto custa a análise de numerologia cabalística?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'O Nome Social custa R$ 97, o Nome de Bebê R$ 147 e o Nome Empresarial R$ 197. São pagamentos únicos com acesso completo por 30 dias e garantia de 7 dias.',
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebSite)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaHowTo)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <slot />
</BaseLayout>
