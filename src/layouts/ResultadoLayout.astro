---
import BaseLayout from './BaseLayout.astro';
import { supabase } from '../backend/db/supabase';
import AvatarMenu from '../frontend/components/app/AvatarMenu';

export interface Props {
  title: string;
  analysisId: string;
  showActions?: boolean;
}

const { title, analysisId, showActions = true } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}


const pdfHref = '/api/generate-pdf?id=' + analysisId;

let userNome = user.email?.split('@')[0] ?? '';
try {
  const { data: profile } = await supabase.from('profiles').select('nome').eq('id', user.id).single();
  if (profile?.nome) userNome = profile.nome;
} catch { /* silencioso */ }
---

<BaseLayout title={title} noIndex={true} hasBottomNav={true}>
  <div class="min-h-screen bg-[#1a1a1a]">
    <!-- Header do resultado — sem menu, apenas botões contextuais -->
    <header class="border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between relative">
        <!-- Back Button (Mobile) -->
        <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/app/analises'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors md:hidden">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </button>

        <!-- Title -->
        <a href="/app" class="hover:opacity-80 transition-opacity absolute left-1/2 -translate-x-1/2 md:static md:transform-none">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-8 sm:h-9 md:h-10 w-auto" />
        </a>

        <!-- Spacer for mobile flex balance / AvatarMenu -->
        <div class="md:hidden flex items-center justify-end w-8">
          <AvatarMenu client:load nome={userNome} />
        </div>

        <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-3">
            <a
              href="/app/analises"
              class="relative inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-[#D4AF37] transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 after:w-0 hover:after:w-full"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
              Minhas Análises
            </a>
            {showActions && (
              <a
                href={pdfHref}
                class="inline-flex items-center gap-2 bg-[#D4AF37] text-[#131313] text-xs font-bold uppercase tracking-wider px-4 py-2 rounded-full shadow-[0_2px_16px_rgba(212,175,55,0.35)] hover:bg-[#f2ca50] hover:shadow-[0_4px_24px_rgba(212,175,55,0.5)] active:scale-95 transition-all duration-300"
              >
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                Baixar Análise
              </a>
            )}
            <AvatarMenu client:load nome={userNome} />
          </div>

      </div>
    </header>

    <!-- Floating PDF Button — mobile only, centered above bottom nav -->
    {showActions && (
      <a
        id="pdf-download-btn"
        href={pdfHref}
        class="md:hidden fixed bottom-[88px] left-1/2 -translate-x-1/2 z-50 inline-flex items-center gap-2 bg-[#D4AF37] text-[#131313] text-xs font-bold uppercase tracking-wider px-5 py-3 rounded-full shadow-[0_4px_24px_rgba(212,175,55,0.4)] hover:bg-[#f2ca50] hover:shadow-[0_4px_32px_rgba(212,175,55,0.55)] active:scale-95 transition-all duration-300"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        Baixar Análise
      </a>
    )}

    <!-- Mobile Bottom Navigation -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#111111]/95 backdrop-blur-xl border-t border-[#D4AF37]/20 z-50 flex items-center justify-around pt-2" style="padding-bottom: max(0.5rem, env(safe-area-inset-bottom)); transform: translateZ(0); will-change: transform;">
      <a href="/app" class="flex flex-col items-center p-2 text-gray-500 hover:text-[#D4AF37] transition-colors">
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Início</span>
      </a>
      <a href="/app/analises" class="flex flex-col items-center p-2 text-[#D4AF37] transition-colors">
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Análises</span>
      </a>
      <a href="/app/suporte" class="flex flex-col items-center p-2 text-gray-500 hover:text-[#D4AF37] transition-colors">
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Suporte</span>
      </a>
    </nav>

    <!-- Conteúdo principal -->
    <main class="max-w-4xl mx-auto px-4 py-8 pb-32 md:pb-24">
      <slot />
    </main>
  </div>

  <!-- Ocultar balão do Chatwoot nas páginas de resultado -->
  <script is:inline>
    function _hideChatwootResultado() {
      if (window.$chatwoot) window.$chatwoot.toggleBubbleVisibility('hide');
    }
    if (window.$chatwoot) {
      _hideChatwootResultado();
    } else {
      window.addEventListener('chatwoot:ready', _hideChatwootResultado);
    }
  </script>

  <!-- Mobile FAB opacity: opaque at rest, semi-transparent while scrolling/interacting -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('pdf-download-btn');
      if (!btn) return;

      var FADE_DELAY  = 150;    // ms after interaction stops before going opaque again
      var FADE_OPACITY = '0.3'; // opacity while user is actively scrolling/interacting
      var FULL_OPACITY = '1';   // opacity when idle (resting)
      var restoreTimer = null;
      var isHovered = false;

      btn.style.transition = 'opacity 0.4s ease, background-color 0.3s, box-shadow 0.3s, transform 0.1s';
      // Start fully visible
      btn.style.opacity = FULL_OPACITY;

      function onInteractionStart() {
        if (isHovered) return;
        clearTimeout(restoreTimer);
        btn.style.opacity = FADE_OPACITY;
        // After brief pause in interaction, restore
        restoreTimer = setTimeout(function () {
          if (!isHovered) btn.style.opacity = FULL_OPACITY;
        }, FADE_DELAY);
      }

      // Fade while actively interacting (scroll / touch)
      ['scroll', 'touchstart', 'touchmove'].forEach(function (ev) {
        window.addEventListener(ev, onInteractionStart, { passive: true });
      });

      // Hover always shows full opacity (desktop safety, irrelevant on mobile)
      btn.addEventListener('mouseenter', function () {
        isHovered = true;
        clearTimeout(restoreTimer);
        btn.style.opacity = FULL_OPACITY;
      });
      btn.addEventListener('mouseleave', function () {
        isHovered = false;
      });
    })();
  </script>
</BaseLayout>
