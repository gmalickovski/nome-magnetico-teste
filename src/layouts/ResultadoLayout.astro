---
import AppLayout from './AppLayout.astro';
import { PDFFeedbackButton } from '../frontend/components/app/PDFFeedbackButton';

export interface Props {
  title: string;
  analysisId: string;
  productType?: string;
  isFree?: boolean;
  showActions?: boolean;
}

const { title, analysisId, productType = 'nome_social', isFree = false, showActions = true } = Astro.props;
---

<AppLayout title={title}>
  <div class="md:-mx-10 md:-mt-10 lg:-mx-14">
    <div class="sticky top-0 z-40 hidden border-b border-[#D4AF37]/15 bg-[#111111]/92 backdrop-blur-md md:block">
      <div class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 px-4 py-3 md:px-6">
        <a href="/app/analises" class="inline-flex items-center gap-2 text-sm font-semibold text-gray-400 transition-colors hover:text-[#D4AF37]">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          <span class="hidden sm:inline">Voltar para minhas análises</span>
          <span class="sm:hidden">Voltar</span>
        </a>

        {showActions && (
          <PDFFeedbackButton client:load analysisId={analysisId} productType={productType} isFree={isFree} />
        )}
      </div>
    </div>

    <main class="mx-auto max-w-4xl pb-32 md:px-6 md:py-12 md:pb-24">
      <slot />
    </main>
  </div>

  {showActions && (
    <PDFFeedbackButton client:load analysisId={analysisId} productType={productType} isFree={isFree} fabOnly />
  )}

  <script is:inline>
    function _hideChatwootResultado() {
      if (window.$chatwoot) window.$chatwoot.toggleBubbleVisibility('hide');
    }
    if (window.$chatwoot) {
      _hideChatwootResultado();
    } else {
      window.addEventListener('chatwoot:ready', _hideChatwootResultado);
    }
  </script>
</AppLayout>
