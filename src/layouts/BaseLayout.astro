---
import { CookieBanner } from '../frontend/components/ui/CookieBanner';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
  hasBottomNav?: boolean;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  showChatwoot?: boolean;
}

const {
  title,
  description = 'Análise de numerologia cabalística: detecte os bloqueios energéticos no seu nome e descubra a variação que alinha Expressão ao Destino. Relatório completo com 4 triângulos cabalísticos.',
  keywords = 'numerologia cabalística, numerologia do nome, mapa numerológico, bloqueios energéticos nome, análise vibracional nome, nome magnético, significado do nome numerologia, nome sem bloqueios energéticos, como meu nome afeta minha vida, mudar nome numerologia',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  noIndex = false,
  hasBottomNav = false,
  articlePublishedTime,
  articleModifiedTime,
  showChatwoot = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://nomemagnetico.com.br${ogImage}`;
// process.env lê em runtime da VPS — import.meta.env seria substituído em build-time pelo CI
const chatwootBaseUrl = process.env.CHATWOOT_BASE_URL ?? '';
const chatwootToken = process.env.CHATWOOT_WEBSITE_TOKEN ?? '';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Primário -->
    <title>{title} | Nome Magnético</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    <!-- Geo (Brasil) -->
    <meta name="geo.region" content="BR" />
    <meta name="geo.placename" content="Brasil" />
    <meta name="language" content="Portuguese" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Nome Magnético`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} - Nome Magnético`} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Nome Magnético" />
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@nomemagnetico" />
    <meta name="twitter:creator" content="@nomemagnetico" />
    <meta name="twitter:title" content={`${title} | Nome Magnético`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={`${title} - Nome Magnético`} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <meta name="theme-color" content="#D4AF37" />
    <meta name="msapplication-TileColor" content="#1A1A1A" />

    <!-- Autor, Propriedade e E-E-A-T (Experience, Expertise, Authoritativeness, Trustworthiness) -->
    <meta name="author" content="Nome Magnético - Studio MLK" />
    <meta name="copyright" content="Nome Magnético" />
    <meta name="publisher" content="Studio MLK" />
    <!-- Sinais de conteúdo especializado para AI Overviews (Google SGE 2026) -->
    <meta name="subject" content="Numerologia Cabalística, Desenvolvimento Pessoal, Branding Pessoal" />
    <meta name="category" content="Ferramentas de Autoconhecimento" />
    <meta name="coverage" content="Brasil" />
    <meta name="rating" content="general" />

    <!-- Performance: Preconnect + DNS prefetch (Core Web Vitals 2026) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://analytics.studiomlk.com.br" />
    <!-- DNS prefetch para serviços externos — reduz latência de lookup -->
    <link rel="dns-prefetch" href="https://js.stripe.com" />
    <link rel="dns-prefetch" href="https://bhxneaeuhybtucmbmpvg.supabase.co" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <!-- Fontes com font-display=swap para não bloquear renderização -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;500&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <!-- Analytics (Umami) — defer para não bloquear INP -->
    <script defer src="https://analytics.studiomlk.com.br/script.js" data-website-id="15b0df31-1cc8-4464-a3f7-89fd82c25bcf"></script>
    <slot name="head" />
  </head>
  <body class:list={['bg-[#1a1a1a] text-gray-200 min-h-screen font-inter antialiased', { 'has-bottom-nav': hasBottomNav }]}>
    <slot />
    <CookieBanner client:only="react" />
    {chatwootBaseUrl && chatwootToken && (
      <script is:inline define:vars={{ chatwootBaseUrl, chatwootToken, showChatwoot }}>
        (function(d,t) {
          // Configurar antes de carregar o SDK para ocultar o balão por padrão
          window.chatwootSettings = {
            hideMessageBubble: !showChatwoot,
            position: 'right',
            locale: 'pt_BR',
          };
          var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
          g.src=chatwootBaseUrl+"/packs/js/sdk.js";
          g.async=true;
          s.parentNode.insertBefore(g,s);
          g.onload=function(){
            window.chatwootSDK.run({
              websiteToken: chatwootToken,
              baseUrl: chatwootBaseUrl
            });
          }
        })(document,"script");
      </script>
    )}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Chatwoot: reposicionar balão acima da bottom nav no mobile (apenas páginas com nav). */
  @media (max-width: 768px) {
    body.has-bottom-nav .woot-widget-bubble,
    body.has-bottom-nav .woot--bubble-holder,
    body.has-bottom-nav .woot-widget-wrap {
      bottom: 80px !important;
    }
  }

  /* Transparência ao rolar — balão Chatwoot */
  body.is-scrolling .woot-widget-bubble,
  body.is-scrolling .woot--bubble-holder {
    opacity: 0.25 !important;
    transition: opacity 0.3s ease !important;
  }

  /* Transparência ao rolar — botão PDF mobile */
  body.is-scrolling #mobile-pdf-btn {
    opacity: 0.25;
    transition: opacity 0.3s ease;
  }

  .woot-widget-bubble,
  .woot--bubble-holder,
  #mobile-pdf-btn {
    transition: opacity 0.3s ease;
  }
</style>

<script is:inline>
  (function () {
    var scrollTimer;
    window.addEventListener('scroll', function () {
      document.body.classList.add('is-scrolling');
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () {
        document.body.classList.remove('is-scrolling');
      }, 1000);
    }, { passive: true });
  })();
</script>
