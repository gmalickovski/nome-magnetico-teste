---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  hasBottomNav?: boolean;
}

const {
  title,
  description = 'Descubra os segredos do seu nome com numerologia cabalística. Detecte bloqueios energéticos e encontre seu Nome Magnético.',
  ogImage = '/og-image.jpg',
  noIndex = false,
  hasBottomNav = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
// process.env lê em runtime da VPS — import.meta.env seria substituído em build-time pelo CI
const chatwootBaseUrl = process.env.CHATWOOT_BASE_URL ?? '';
const chatwootToken = process.env.CHATWOOT_WEBSITE_TOKEN ?? '';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Nome Magnético</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Nome Magnético`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Nome Magnético`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <meta name="theme-color" content="#D4AF37" />

    <!-- SEO extra -->
    <meta property="og:site_name" content="Nome Magnético" />
    <meta name="author" content="Nome Magnético" />

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={['bg-[#1a1a1a] text-gray-200 min-h-screen font-inter antialiased', { 'has-bottom-nav': hasBottomNav }]}>
    <slot />
    {chatwootBaseUrl && chatwootToken && (
      <script is:inline define:vars={{ chatwootBaseUrl, chatwootToken }}>
        (function(d,t) {
          // Configurar antes de carregar o SDK para ocultar o balão por padrão
          window.chatwootSettings = {
            hideMessageBubble: false,
            position: 'right',
            locale: 'pt_BR',
          };
          var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
          g.src=chatwootBaseUrl+"/packs/js/sdk.js";
          g.async=true;
          s.parentNode.insertBefore(g,s);
          g.onload=function(){
            window.chatwootSDK.run({
              websiteToken: chatwootToken,
              baseUrl: chatwootBaseUrl
            });
          }
        })(document,"script");
      </script>
    )}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Chatwoot: reposicionar balão acima da bottom nav no mobile (apenas páginas com nav). */
  @media (max-width: 768px) {
    body.has-bottom-nav .woot-widget-bubble,
    body.has-bottom-nav .woot--bubble-holder,
    body.has-bottom-nav .woot-widget-wrap {
      bottom: 80px !important;
    }
  }

  /* Transparência ao rolar — balão Chatwoot */
  body.is-scrolling .woot-widget-bubble,
  body.is-scrolling .woot--bubble-holder {
    opacity: 0.25 !important;
    transition: opacity 0.3s ease !important;
  }

  /* Transparência ao rolar — botão PDF mobile */
  body.is-scrolling #mobile-pdf-btn {
    opacity: 0.25;
    transition: opacity 0.3s ease;
  }

  .woot-widget-bubble,
  .woot--bubble-holder,
  #mobile-pdf-btn {
    transition: opacity 0.3s ease;
  }
</style>

<script is:inline>
  (function () {
    var scrollTimer;
    window.addEventListener('scroll', function () {
      document.body.classList.add('is-scrolling');
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () {
        document.body.classList.remove('is-scrolling');
      }, 1000);
    }, { passive: true });
  })();
</script>
