---
import BaseLayout from './BaseLayout.astro';
import { createUserClient } from '../backend/db/supabase';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

// Verificar perfil e subscriptions ativas
let isAdmin = false;
let hasAnyActive = false;
try {
  const client = createUserClient(Astro.locals.accessToken ?? '');
  const [profileRes, subsRes] = await Promise.all([
    client
      
      .from('profiles')
      .select('role')
      .eq('id', user.id)
      .single(),
    client
      
      .from('subscriptions')
      .select('product_type')
      .eq('user_id', user.id)
      .gt('ends_at', new Date().toISOString()),
  ]);
  isAdmin = profileRes.data?.role === 'admin';
  hasAnyActive = (subsRes.data?.length ?? 0) > 0;
} catch { /* silencioso */ }

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  pathname === path || pathname.startsWith(path + '/');
---

<BaseLayout title={title} description={description} noIndex={true}>
  <div class="min-h-screen bg-[#1a1a1a]">
    <!-- Header do app -->
    <header class="border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between relative">
        <!-- Back Button (Mobile) -->
        <!-- Oculto no desktop, visível no mobile, e oculto na raiz /app -->
        {pathname !== '/app' && pathname !== '/app/' ? (
          <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/app'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors md:hidden">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          </button>
        ) : (
          <div class="w-6 h-6 md:hidden"></div>
        )}

        <!-- Title -->
        <a href="/app" class="font-cinzel text-base sm:text-lg md:text-xl font-bold text-[#D4AF37] tracking-wider hover:opacity-80 transition-opacity whitespace-nowrap absolute left-1/2 -translate-x-1/2 md:static md:transform-none">
          NOME MAGNÉTICO
        </a>

        <!-- Hamburger Icon (Mobile) -->
        <button id="mobileMenuBtn" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors md:hidden">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-6">
          <a
            href="/app"
            class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
              isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises')
                ? 'text-[#D4AF37] after:w-full'
                : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
            }`}
          >
            Meus Produtos
          </a>
          {(isAdmin || hasAnyActive) && (
            <a
              href="/app/analises"
              class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
                isActive('/app/analises') || isActive('/app/resultado')
                  ? 'text-[#D4AF37] after:w-full'
                  : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
              }`}
            >
              Análises
            </a>
          )}
          <a
            href="/app/suporte"
            class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
              isActive('/suporte')
                ? 'text-[#D4AF37] after:w-full'
                : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
            }`}
          >
            Suporte
          </a>
          {isAdmin && (
            <a
              href="/admin"
              class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-purple-400 after:transition-all after:duration-300 ${
                isActive('/admin')
                  ? 'text-purple-400 after:w-full'
                  : 'text-purple-500 hover:text-purple-400 after:w-0 hover:after:w-full'
              }`}
            >
              Admin
            </a>
          )}
          <button
            id="logoutBtnDesktop"
            class="relative text-gray-500 hover:text-red-400 transition-colors text-sm pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-red-400 after:transition-all after:duration-300 after:w-0 hover:after:w-full"
          >
            Sair
          </button>
        </nav>
      </div>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobileMenu" class="fixed inset-0 bg-[#111111]/95 backdrop-blur-xl z-50 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col">
      <div class="px-4 py-4 flex items-center justify-between border-b border-[#D4AF37]/20">
        <span class="font-cinzel text-xl font-bold text-[#D4AF37] tracking-wider">MENU</span>
        <button id="closeMenuBtn" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <nav class="flex flex-col p-6 gap-6">
        <a href="/app" class={'text-lg transition-colors ' + (isActive('/app') && !isActive('/app/analises') ? 'text-[#D4AF37]' : 'text-gray-300')}>
          Meus Produtos
        </a>
        {(isAdmin || hasAnyActive) && (
          <a href="/app/analises" class={'text-lg transition-colors ' + (isActive('/app/analises') || isActive('/app/resultado') ? 'text-[#D4AF37]' : 'text-gray-300')}>
            Minhas Análises
          </a>
        )}
        <a href="/app/suporte" class={'text-lg transition-colors ' + (isActive('/app/suporte') ? 'text-[#D4AF37]' : 'text-gray-300')}>
          Suporte
        </a>
        {isAdmin && (
          <a href="/admin" class={'text-lg transition-colors ' + (isActive('/admin') ? 'text-purple-400' : 'text-purple-500')}>
            Painel Admin
          </a>
        )}
        <div class="h-px bg-[#D4AF37]/20 my-2"></div>
        <button id="logoutBtnMobile" class="text-left text-lg text-gray-500 hover:text-red-400 transition-colors mt-2">
          Sair da Conta
        </button>
      </nav>
    </div>

    <!-- Conteúdo principal -->
    <main class="max-w-6xl mx-auto px-4 py-8 pb-24 md:pb-8">
      <slot />
    </main>

  </div>

  <script>
    const setupLogout = (id) => {
      document.getElementById(id)?.addEventListener('click', async () => {
        const { supabaseBrowser } = await import('../frontend/lib/supabase-browser');
        await supabaseBrowser.auth.signOut();
        // Limpar cookies de auth
        document.cookie = 'nome-magnetico-auth-access-token=; path=/; max-age=0';
        document.cookie = 'nome-magnetico-auth-refresh-token=; path=/; max-age=0';
        window.location.href = '/auth/login';
      });
    };

    setupLogout('logoutBtnDesktop');
    setupLogout('logoutBtnMobile');

    // Menu Mobile
    const btnOpen = document.getElementById('mobileMenuBtn');
    const btnClose = document.getElementById('closeMenuBtn');
    const menu = document.getElementById('mobileMenu');

    if (btnOpen && btnClose && menu) {
      btnOpen.addEventListener('click', () => {
        menu.classList.remove('translate-x-full');
      });
      btnClose.addEventListener('click', () => {
        menu.classList.add('translate-x-full');
      });
    }
  </script>
</BaseLayout>
