---
import BaseLayout from './BaseLayout.astro';
import { createUserClient } from '../backend/db/supabase';
import AvatarMenu from '../frontend/components/app/AvatarMenu';
import MobileNavBar from '../frontend/components/app/MobileNavBar.astro';
import ClientMessagePopup from '../frontend/components/app/ClientMessagePopup';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

let isAdmin = false;
let hasAnyActive = false;
let userNome = user.email?.split('@')[0] ?? '';
let isTest = false;
let testEndsAt: Date | null = null;
let hasPaidAnalysisHistory = false;

try {
  const client = createUserClient(Astro.locals.accessToken ?? '');
  const [profileRes, subsRes, paidAnalysesRes] = await Promise.all([
    client
      .from('profiles')
      .select('role, nome, is_test, test_ends_at')
      .eq('id', user.id)
      .single(),
    client
      .from('subscriptions')
      .select('product_type')
      .eq('user_id', user.id)
      .gt('ends_at', new Date().toISOString()),
    client
      .from('analyses')
      .select('id')
      .eq('user_id', user.id)
      .neq('product_type', 'analise_gratuita')
      .limit(1),
  ]);

  isAdmin = profileRes.data?.role === 'admin';
  if (profileRes.data?.nome) userNome = profileRes.data.nome;
  if (profileRes.data?.is_test) {
    const exp = profileRes.data.test_ends_at;
    isTest = exp === null || new Date(exp) > new Date();
    if (exp) testEndsAt = new Date(exp);
  }
  hasAnyActive = isAdmin || isTest || (subsRes.data?.length ?? 0) > 0;
  hasPaidAnalysisHistory = (paidAnalysesRes.data?.length ?? 0) > 0;
} catch { /* silencioso */ }

const showAnalisesNav = isAdmin || hasAnyActive || hasPaidAnalysisHistory;
const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  pathname === path || pathname.startsWith(path + '/');
const navAppActive = isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises') && !isActive('/app/suporte');
const navAnalisesActive = isActive('/app/analises') || isActive('/app/resultado');
const navSuporteActive = isActive('/app/suporte');

const showChatwoot = pathname.startsWith('/app/suporte');
---

<BaseLayout title={title} description={description} noIndex={true} hasBottomNav={true} showChatwoot={showChatwoot}>
  <div class="min-h-screen bg-[#1a1a1a]">
    {isTest && (
      <div class="bg-[#D4AF37]/10 border-b border-[#D4AF37]/20 px-4 py-2 text-center text-sm text-[#D4AF37]">
        Você está usando um acesso de teste.
        {testEndsAt
          ? ` Válido até ${testEndsAt.toLocaleDateString('pt-BR')}.`
          : ' Sem data de expiração.'}
        <a href="/comprar" class="underline font-medium ml-1 hover:text-[#f2ca50] transition-colors">
          Assinar agora
        </a>
      </div>
    )}

    <aside class="group hidden md:flex fixed inset-y-0 left-0 z-40 w-20 flex-col overflow-hidden border-r border-[#D4AF37]/15 bg-[#111111]/95 px-4 py-7 transition-[width] duration-300 ease-out hover:w-72">
      <a href="/app" class="mb-9 flex h-11 items-center gap-3 hover:opacity-85 transition-opacity">
        <span class="relative flex h-11 w-11 flex-shrink-0 items-center justify-center">
          <img src="/favicon.png" alt="Nome Magnético" class="absolute h-9 w-9 object-contain opacity-100 transition-opacity duration-200 group-hover:opacity-0" />
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="absolute left-0 h-10 w-auto max-w-none opacity-0 transition-opacity duration-200 group-hover:opacity-100" />
        </span>
      </a>

      <div class="mb-8 flex h-[68px] items-center gap-3 overflow-hidden rounded-2xl bg-transparent px-0 py-0 transition-all duration-300 group-hover:bg-white/[0.03] group-hover:px-3 group-hover:py-3">
        <AvatarMenu client:load nome={userNome} />
        <div class="min-w-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
          <p class="text-[10px] uppercase tracking-[0.16em] text-gray-600">Conta</p>
          <p class="truncate font-cinzel text-sm font-bold text-[#e5e2e1]">{userNome}</p>
        </div>
      </div>

      <nav class="flex flex-col gap-2">
        <a href="/app" class={`flex h-12 items-center gap-3 rounded-2xl px-3 text-sm font-semibold transition-all ${navAppActive ? 'bg-[#D4AF37]/12 text-[#D4AF37]' : 'text-gray-500 hover:bg-white/[0.03] hover:text-[#D4AF37]'}`}>
          <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
          <span class="whitespace-nowrap opacity-0 transition-opacity duration-200 group-hover:opacity-100">Meus Produtos</span>
        </a>

        {showAnalisesNav ? (
          <a href="/app/analises" class={`flex h-12 items-center gap-3 rounded-2xl px-3 text-sm font-semibold transition-all ${navAnalisesActive ? 'bg-[#D4AF37]/12 text-[#D4AF37]' : 'text-gray-500 hover:bg-white/[0.03] hover:text-[#D4AF37]'}`}>
            <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            <span class="whitespace-nowrap opacity-0 transition-opacity duration-200 group-hover:opacity-100">Minhas Análises</span>
          </a>
        ) : (
          <div title="Disponível após adquirir um produto" class="flex h-12 cursor-not-allowed items-center gap-3 rounded-2xl px-3 text-sm font-semibold text-gray-700 opacity-60">
            <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            <span class="whitespace-nowrap opacity-0 transition-opacity duration-200 group-hover:opacity-100">Minhas Análises</span>
            <svg class="ml-auto h-4 w-4 flex-shrink-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          </div>
        )}

        <a href="/app/suporte" class={`flex h-12 items-center gap-3 rounded-2xl px-3 text-sm font-semibold transition-all ${navSuporteActive ? 'bg-[#D4AF37]/12 text-[#D4AF37]' : 'text-gray-500 hover:bg-white/[0.03] hover:text-[#D4AF37]'}`}>
          <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
          <span class="whitespace-nowrap opacity-0 transition-opacity duration-200 group-hover:opacity-100">Suporte</span>
        </a>

        <a href="/blog" target="_blank" rel="noopener noreferrer" class="flex h-12 items-center gap-3 rounded-2xl px-3 text-sm font-semibold text-gray-500 hover:bg-white/[0.03] hover:text-[#D4AF37] transition-all">
          <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0015.5 3H15m3 12h-3m3-4h-3m3-4h-3" /></svg>
          <span class="whitespace-nowrap opacity-0 transition-opacity duration-200 group-hover:opacity-100">Blog</span>
        </a>

        {isAdmin && (
          <a href="https://hq.studiomlk.com.br" target="_blank" rel="noopener noreferrer" class="flex h-12 items-center gap-3 rounded-2xl px-3 text-sm font-semibold text-purple-400 transition-all hover:bg-purple-500/10">
            <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="whitespace-nowrap opacity-0 transition-opacity duration-200 group-hover:opacity-100">Admin HQ</span>
          </a>
        )}
      </nav>
    </aside>

    <header class="md:hidden border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40 h-[73px]">
      <div class="max-w-6xl mx-auto px-4 py-4 h-full flex items-center relative">
        {pathname !== '/app' && pathname !== '/app/' && (
          <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/app'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors md:hidden absolute left-4 z-10 p-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          </button>
        )}

        <a 
          href="/app" 
          class="hover:opacity-80 transition-all duration-500 absolute"
          style={pathname !== '/app' && pathname !== '/app/' ? "left: 50%; transform: translateX(-50%);" : "left: 1rem; transform: translateX(0);"}
        >
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-9 sm:h-10 w-auto" />
        </a>

        <div class="md:hidden flex items-center justify-end w-8 absolute right-4">
          <AvatarMenu client:load nome={userNome} />
        </div>
      </div>
    </header>

    <MobileNavBar isAdmin={isAdmin} showAnalisesNav={showAnalisesNav} />

    <main class="max-w-6xl mx-auto px-4 py-8 pb-24 md:ml-20 md:max-w-none md:px-10 lg:px-14 md:py-10 md:pb-10">
      <slot />
    </main>

    <ClientMessagePopup client:load />
  </div>

  <script define:vars={{ _uid: user.id, _email: user.email ?? '', _name: userNome }}>
    function _syncChatwoot() {
      window.$chatwoot.setUser(_uid, { email: _email, name: _name });
    }
    if (window.$chatwoot) {
      _syncChatwoot();
    } else {
      window.addEventListener('chatwoot:ready', _syncChatwoot);
    }
  </script>
</BaseLayout>
