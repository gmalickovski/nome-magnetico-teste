---
import BaseLayout from './BaseLayout.astro';
import { createUserClient } from '../backend/db/supabase';
import AvatarMenu from '../frontend/components/app/AvatarMenu';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

// Verificar perfil e subscriptions ativas
let isAdmin = false;
let hasAnyActive = false;
let userNome = user.email?.split('@')[0] ?? '';
try {
  const client = createUserClient(Astro.locals.accessToken ?? '');
  const [profileRes, subsRes] = await Promise.all([
    client

      .from('profiles')
      .select('role, nome')
      .eq('id', user.id)
      .single(),
    client

      .from('subscriptions')
      .select('product_type')
      .eq('user_id', user.id)
      .gt('ends_at', new Date().toISOString()),
  ]);
  isAdmin = profileRes.data?.role === 'admin';
  hasAnyActive = (subsRes.data?.length ?? 0) > 0;
  if (profileRes.data?.nome) userNome = profileRes.data.nome;
} catch { /* silencioso */ }

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  pathname === path || pathname.startsWith(path + '/');
---

<BaseLayout title={title} description={description} noIndex={true}>
  <div class="min-h-screen bg-[#1a1a1a]">
    <!-- Header do app -->
    <header class="border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between relative">
        <!-- Back Button (Mobile) -->
        <!-- Oculto no desktop, visível no mobile, e oculto na raiz /app -->
        {pathname !== '/app' && pathname !== '/app/' ? (
          <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/app'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors md:hidden">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          </button>
        ) : (
          <div class="w-6 h-6 md:hidden"></div>
        )}

        <!-- Title -->
        <a href="/app" class="font-cinzel text-base sm:text-lg md:text-xl font-bold text-[#D4AF37] tracking-wider hover:opacity-80 transition-opacity whitespace-nowrap absolute left-1/2 -translate-x-1/2 md:static md:transform-none">
          NOME MAGNÉTICO
        </a>

        <!-- Mobile Avatar (Right side) -->
        <div class="md:hidden flex items-center justify-end w-8">
          <AvatarMenu client:load nome={userNome} />
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-6">
          <a
            href="/app"
            class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
              isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises')
                ? 'text-[#D4AF37] after:w-full'
                : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
            }`}
          >
            Meus Produtos
          </a>
          {(isAdmin || hasAnyActive) && (
            <a
              href="/app/analises"
              class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
                isActive('/app/analises') || isActive('/app/resultado')
                  ? 'text-[#D4AF37] after:w-full'
                  : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
              }`}
            >
              Análises
            </a>
          )}
          <a
            href="/app/suporte"
            class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
              isActive('/app/suporte')
                ? 'text-[#D4AF37] after:w-full'
                : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
            }`}
          >
            Suporte
          </a>
          {isAdmin && (
            <a
              href="/admin"
              class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-purple-400 after:transition-all after:duration-300 ${
                isActive('/admin')
                  ? 'text-purple-400 after:w-full'
                  : 'text-purple-500 hover:text-purple-400 after:w-0 hover:after:w-full'
              }`}
            >
              Admin
            </a>
          )}
          <AvatarMenu client:load nome={userNome} />
        </nav>
      </div>
    </header>

    <!-- Mobile Bottom Navigation -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#111111]/95 backdrop-blur-xl border-t border-[#D4AF37]/20 z-50 flex items-center justify-around pb-2 pt-2">
      <a href="/app" class={`flex flex-col items-center p-2 transition-colors ${isActive('/app') && !isActive('/app/analises') && !isActive('/app/resultado') && !isActive('/app/suporte') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Início</span>
      </a>
      {(isAdmin || hasAnyActive) && (
        <a href="/app/analises" class={`flex flex-col items-center p-2 transition-colors ${isActive('/app/analises') || isActive('/app/resultado') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
          <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          <span class="text-[10px] font-medium tracking-wide">Análises</span>
        </a>
      )}
      <a href="/app/suporte" class={`flex flex-col items-center p-2 transition-colors ${isActive('/app/suporte') ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        <span class="text-[10px] font-medium tracking-wide">Suporte</span>
      </a>
      {isAdmin && (
        <a href="/admin" class={`flex flex-col items-center p-2 transition-colors ${isActive('/admin') ? 'text-purple-400' : 'text-gray-500 hover:text-purple-400'}`}>
          <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          <span class="text-[10px] font-medium tracking-wide">Admin</span>
        </a>
      )}
    </nav>

    <!-- Conteúdo principal -->
    <main class="max-w-6xl mx-auto px-4 py-8 pb-24 md:pb-8">
      <slot />
    </main>

  </div>

  <!-- Layout Scripts Removered: Logout forms are handled by React (AvatarMenu) -->
  <script define:vars={{ _uid: user.id, _email: user.email ?? '', _name: userNome, _showBubble: pathname.startsWith('/app/suporte') }}>
    function _syncChatwoot() {
      window.$chatwoot.setUser(_uid, { email: _email, name: _name });
      // Balão visível apenas na página de suporte — nas demais o usuário abre via botão
      if (!_showBubble) {
        window.$chatwoot.toggleBubbleVisibility('hide');
      }
    }
    if (window.$chatwoot) {
      _syncChatwoot();
    } else {
      window.addEventListener('chatwoot:ready', _syncChatwoot);
    }
  </script>
</BaseLayout>
