---
import BaseLayout from './BaseLayout.astro';
import { createUserClient } from '../backend/db/supabase';
import { hasUsedFreeAnalysis } from '../backend/db/analyses';
import AvatarMenu from '../frontend/components/app/AvatarMenu';
import MobileNavBar from '../frontend/components/app/MobileNavBar.astro';
import ClientMessagePopup from '../frontend/components/app/ClientMessagePopup';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login?redirect=' + encodeURIComponent(Astro.url.pathname));
}

// Verificar perfil e subscriptions ativas
let isAdmin = false;
let hasAnyActive = false;
let userNome = user.email?.split('@')[0] ?? '';
let isTest = false;
let testEndsAt: Date | null = null;
let hasFreeAnalysis = false;
try {
  const client = createUserClient(Astro.locals.accessToken ?? '');
  const [profileRes, subsRes] = await Promise.all([
    client
      .from('profiles')
      .select('role, nome, is_test, test_ends_at')
      .eq('id', user.id)
      .single(),
    client
      .from('subscriptions')
      .select('product_type')
      .eq('user_id', user.id)
      .gt('ends_at', new Date().toISOString()),
  ]);
  isAdmin = profileRes.data?.role === 'admin';
  if (profileRes.data?.nome) userNome = profileRes.data.nome;
  if (profileRes.data?.is_test) {
    const exp = profileRes.data.test_ends_at;
    isTest = exp === null || new Date(exp) > new Date();
    if (exp) testEndsAt = new Date(exp);
  }
  hasAnyActive = isAdmin || isTest || (subsRes.data?.length ?? 0) > 0;
  if (!hasAnyActive && !isAdmin) {
    hasFreeAnalysis = await hasUsedFreeAnalysis(user.id);
  }
} catch { /* silencioso */ }

const showAnalisesNav = isAdmin || hasAnyActive || hasFreeAnalysis;
const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  pathname === path || pathname.startsWith(path + '/');

const showChatwoot = pathname.startsWith('/app/suporte');
---

<BaseLayout title={title} description={description} noIndex={true} hasBottomNav={true} showChatwoot={showChatwoot}>
  <div class="min-h-screen bg-[#1a1a1a]">
    <!-- Banner usuário teste -->
    {isTest && (
      <div class="bg-[#D4AF37]/10 border-b border-[#D4AF37]/20 px-4 py-2 text-center text-sm text-[#D4AF37]">
        Você está usando um acesso de teste.
        {testEndsAt
          ? ` Válido até ${testEndsAt.toLocaleDateString('pt-BR')}.`
          : ' Sem data de expiração.'}
        <a href="/comprar" class="underline font-medium ml-1 hover:text-[#f2ca50] transition-colors">
          Assinar agora
        </a>
      </div>
    )}

    <!-- Header do app -->
    <header class="border-b border-[#D4AF37]/20 bg-[#111111]/80 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between relative">
        <!-- Back Button (Mobile) -->
        <!-- Oculto no desktop, visível no mobile, e oculto na raiz /app -->
        {pathname !== '/app' && pathname !== '/app/' ? (
          <button onclick="window.history.length > 1 ? window.history.back() : window.location.href='/app'" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors md:hidden">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          </button>
        ) : (
          <a
            href="/"
            class="md:hidden flex items-center justify-center w-10 h-10 rounded-full bg-[#111111] border border-[#D4AF37]/50 text-[#D4AF37] hover:shadow-[0_0_15px_rgba(212,175,55,0.2)] hover:scale-105 transition-all duration-300"
            aria-label="Ir para a página inicial"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          </a>
        )}

        <!-- Title -->
        <a href="/app" class="hover:opacity-80 transition-opacity absolute left-1/2 -translate-x-1/2 md:static md:transform-none">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-9 sm:h-10 md:h-11 w-auto" />
        </a>

        <!-- Mobile Avatar (Right side) -->
        <div class="md:hidden flex items-center justify-end w-8">
          <AvatarMenu client:load nome={userNome} />
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-6">
          <a
            href="/app"
            class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
              isActive('/app') && !isActive('/app/analise') && !isActive('/app/resultado') && !isActive('/app/analises')
                ? 'text-[#D4AF37] after:w-full'
                : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
            }`}
          >
            Meus Produtos
          </a>
          {showAnalisesNav && (
            <a
              href="/app/analises"
              class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
                isActive('/app/analises') || isActive('/app/resultado')
                  ? 'text-[#D4AF37] after:w-full'
                  : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
              }`}
            >
              Minhas Análises
            </a>
          )}
          <a
            href="/app/suporte"
            class={`relative text-sm transition-colors pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-[#D4AF37] after:transition-all after:duration-300 ${
              isActive('/app/suporte')
                ? 'text-[#D4AF37] after:w-full'
                : 'text-gray-400 hover:text-[#D4AF37] after:w-0 hover:after:w-full'
            }`}
          >
            Suporte
          </a>
          {isAdmin && (
            <a
              href="https://hq.studiomlk.com.br"
              target="_blank"
              rel="noopener noreferrer"
              class="relative text-sm transition-colors pb-0.5 text-purple-500 hover:text-purple-400 after:absolute after:bottom-0 after:left-0 after:h-px after:bg-purple-400 after:transition-all after:duration-300 after:w-0 hover:after:w-full"
            >
              HQ Admin
            </a>
          )}
          <AvatarMenu client:load nome={userNome} />
        </nav>
      </div>
    </header>

    <!-- Mobile Bottom Navigation -->
    <MobileNavBar isAdmin={isAdmin} showAnalisesNav={showAnalisesNav} />

    <!-- Conteúdo principal -->
    <main class="max-w-6xl mx-auto px-4 py-8 pb-24 md:pb-8">
      <slot />
    </main>

    <ClientMessagePopup client:load />

  </div>

  <!-- Layout Scripts Removered: Logout forms are handled by React (AvatarMenu) -->
  <script define:vars={{ _uid: user.id, _email: user.email ?? '', _name: userNome }}>
    function _syncChatwoot() {
      window.$chatwoot.setUser(_uid, { email: _email, name: _name });
    }
    if (window.$chatwoot) {
      _syncChatwoot();
    } else {
      window.addEventListener('chatwoot:ready', _syncChatwoot);
    }
  </script>
</BaseLayout>
