---
import { createUserClient } from '../../../backend/db/supabase';
import { hasUsedFreeAnalysis } from '../../../backend/db/analyses';

export interface Props {
  isAdmin?: boolean;
  showAnalisesNav?: boolean;
}

const user = Astro.locals.user;
let { isAdmin, showAnalisesNav } = Astro.props;

if (user && (isAdmin === undefined || showAnalisesNav === undefined)) {
  try {
    const client = createUserClient(Astro.locals.accessToken ?? '');
    const [profileRes, subsRes] = await Promise.all([
      client.from('profiles').select('role, is_test, test_ends_at').eq('id', user.id).single(),
      client.from('subscriptions').select('product_type').eq('user_id', user.id).gt('ends_at', new Date().toISOString()),
    ]);
    
    if (isAdmin === undefined) {
      isAdmin = profileRes.data?.role === 'admin';
    }
    
    if (showAnalisesNav === undefined) {
      let isTest = false;
      if (profileRes.data?.is_test) {
        const exp = profileRes.data.test_ends_at;
        isTest = exp === null || new Date(exp) > new Date();
      }
      let hasAnyActive = isAdmin || isTest || (subsRes.data?.length ?? 0) > 0;
      if (!hasAnyActive && !isAdmin) {
        const hasFreeAnalysis = await hasUsedFreeAnalysis(user.id);
        showAnalisesNav = isAdmin || hasAnyActive || hasFreeAnalysis;
      } else {
        showAnalisesNav = true;
      }
    }
  } catch {
    // fallback
    if (isAdmin === undefined) isAdmin = false;
    if (showAnalisesNav === undefined) showAnalisesNav = false;
  }
}

const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');

const navAppActive = isActive('/app') && !isActive('/app/analises') && !isActive('/app/resultado') && !isActive('/app/suporte') && !isActive('/app/analise');
const navAnalisesActive = isActive('/app/analises') || isActive('/app/resultado');
const navSuporteActive = isActive('/app/suporte');
---

<nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#111111]/95 backdrop-blur-xl border-t border-[#D4AF37]/20 z-50 flex items-center justify-around pt-2" style="padding-bottom: max(0.5rem, env(safe-area-inset-bottom))">
  <a href="/app" class={`flex flex-col items-center p-2 transition-colors ${navAppActive ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
    <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
    <span class="text-[10px] font-medium tracking-wide">Produtos</span>
  </a>
  
  {showAnalisesNav && (
    <a href="/app/analises" class={`flex flex-col items-center p-2 transition-colors ${navAnalisesActive ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
      <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
      <span class="text-[10px] font-medium tracking-wide">Análises</span>
    </a>
  )}
  
  <a href="/app/suporte" class={`flex flex-col items-center p-2 transition-colors ${navSuporteActive ? 'text-[#D4AF37]' : 'text-gray-500 hover:text-[#D4AF37]'}`}>
    <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
    <span class="text-[10px] font-medium tracking-wide">Suporte</span>
  </a>
  
  <a href="/blog" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center p-2 transition-colors text-gray-500 hover:text-[#D4AF37]">
    <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0015.5 3H15m3 12h-3m3-4h-3m3-4h-3" /></svg>
    <span class="text-[10px] font-medium tracking-wide">Blog</span>
  </a>
</nav>
