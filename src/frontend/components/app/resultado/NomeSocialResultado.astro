---
/**
 * NomeSocialResultado — resumo interativo do relatório PDF de Nome Social.
 * Importado e renderizado por src/pages/app/resultado/[id].astro.
 *
 * Ordem das seções:
 *   1. A Harmonização (estrela dupla + comparativos completos)
 *   2. Nome de Ouro
 *   3. Nossas Sugestões / Suas Sugestões
 *   4. Os 5 Números do Nome Harmonizado (estilo NomeAtual exato)
 *   5. Os 4 Triângulos (estilo NomeAtual + arcano de trânsito)
 *   6. Débitos Kármicos
 *   7. Lições Kármicas
 *   8. Tendências Ocultas
 *   9. Script + Legado
 */
import TriangleVisualization from '../TriangleVisualization';
import KarmicLessons from '../KarmicLessons';
import KarmicDebts from '../KarmicDebts';
import HiddenTendencies from '../HiddenTendencies';
import ScoreDisplay from '../ScoreDisplay';
import CompatibilityBadge from '../CompatibilityBadge';
import { ARCANOS } from '../../../../backend/numerology/arcanos';
import { detectarLicoesCarmicas, detectarTendenciasOcultas, calcularDebitosCarmicos } from '../../../../backend/numerology/karmic';
import { calcularCincoNumeros } from '../../../../backend/numerology/numbers';
import { calcularTodosTriangulos, detectarBloqueios } from '../../../../backend/numerology/triangle';

interface Props {
  analysis: any;
  nomeExibido: string;
  cincoNumeros: Array<{ label: string; sublabel: string; value: number | null; icon: string }>;
  expressao: number | null;
  arquetipoData: any;
  tVida: any;
  tPessoal: any;
  tSocial: any;
  tDestino: any;
  hasTriangulos: boolean;
  bloqueios: any[];
  arcanoData: any;
  licoesRaw: any[] | null;
  debitosRaw: any[] | null;
  tendenciasRaw: any[] | null;
  frequenciasRaw: Record<number, number> | null;
  analiseHtml: string | null;
  topNames: any[];
  rankingSocial?: any;
  canGenerateCandidateReports?: boolean;
}

const {
  analysis,
  nomeExibido,
  tVida, tPessoal, tSocial, tDestino,
  hasTriangulos,
  bloqueios,
  licoesRaw,
  debitosRaw,
  tendenciasRaw,
  frequenciasRaw,
  topNames,
  rankingSocial,
  canGenerateCandidateReports = false,
} = Astro.props;

const nomeOuroNormalizado = (rankingSocial?.melhorNome?.nomeCompleto ?? '').trim().toLowerCase();
const candidatosSemNomeOuro = ((rankingSocial?.nomesCandidatos ?? []) as any[]).filter((c: any) => (
  c.nomeCompleto?.trim().toLowerCase() !== nomeOuroNormalizado
));
const nossasSugestoes = candidatosSemNomeOuro.filter((c: any) => c.origemSugerida === 'ia');
const suasSugestoes   = candidatosSemNomeOuro.filter((c: any) => c.origemSugerida === 'usuario');

function formatDateForAnalyze(value?: string | null): string {
  if (!value) return '';
  if (/^\d{2}\/\d{2}\/\d{4}$/.test(value)) return value;
  if (/^\d{4}-\d{2}-\d{2}/.test(value)) {
    const [y, m, d] = value.slice(0, 10).split('-');
    return `${d}/${m}/${y}`;
  }
  return value;
}

const candidateBaseName = (rankingSocial?.nomeNascimento as string | undefined) ?? analysis.nome_completo ?? '';
const candidateBaseDate = formatDateForAnalyze(
  (rankingSocial?.dataNascimento as string | undefined) ?? analysis.data_nascimento ?? ''
);

// Arcanos lookup para os triângulos
const arcanoIds = [tVida?.arcanoRegente, tPessoal?.arcanoRegente, tSocial?.arcanoRegente, tDestino?.arcanoRegente]
  .filter((n): n is number => n != null);
const arcanosMap = Object.fromEntries(arcanoIds.map(id => [id, ARCANOS[id]])) as Record<number, typeof ARCANOS[number]>;

// Descrições detalhadas dos triângulos (exato do NomeAtualResultado)
const primeiroNomeTri = nomeExibido.split(' ')[0] ?? nomeExibido;
const TRIANGULO_DESC: Record<string, string> = {
  vida: `Calculado a partir do valor puro de cada letra do nome, sem modificadores externos. Revela os padrões fundamentais de existência — os temas que se repetem nas diferentes fases da vida, independentemente das circunstâncias. É a vibração base que permeia toda a trajetória de ${primeiroNomeTri}, moldando a relação com o corpo, a vitalidade, o dinheiro e a resiliência diante dos desafios. Os bloqueios neste triângulo afetam a saúde geral e os ciclos de prosperidade.`,
  pessoal: `Calculado adicionando ao valor de cada letra o número do dia de nascimento. Mapeia a dimensão íntima e emocional — as reações internas, os mecanismos de defesa e os padrões afetivos que raramente são visíveis para o mundo externo. Revela como ${primeiroNomeTri} processa as experiências por dentro, o que realmente move suas escolhas e os ciclos emocionais que se repetem nos relacionamentos mais próximos.`,
  social: `Calculado adicionando ao valor de cada letra o número do mês de nascimento. Revela como o mundo externo percebe e responde a ${primeiroNomeTri} — a impressão que o nome irradia nas interações sociais, profissionais e públicas. Governa o magnetismo pessoal, as oportunidades de networking e a reputação. É aqui que se concentram os bloqueios que sabotam visibilidade, vendas e conexões estratégicas.`,
  destino: `Calculado adicionando ao valor de cada letra a soma já reduzida do dia e mês de nascimento. É o triângulo mais revelador: mapeia os resultados que tendem a se materializar ao longo da vida, a missão maior e os frutos que a frequência vibratória do nome produz. Quando há bloqueios aqui, eles se manifestam como ciclos de esforço que raramente chegam à colheita — o trabalho não se converte em resultado.`,
};

// Débitos: fixos vs variáveis
const debitosFixos    = (debitosRaw  ?? []).filter((d: any) => d.fixo === true);
const debitosVariaveis = (debitosRaw ?? []).filter((d: any) => !d.fixo);

// Bloqueios comparativos
const harmBloqueios = (rankingSocial?.melhorNome?.bloqueios ?? []) as any[];
const harmBloqueiosCodigos = new Set(harmBloqueios.map((b: any) => b.codigo));

// Lições e Tendências do nome harmonizado (computadas server-side)
const nomeHarmCompleto = rankingSocial?.melhorNome?.nomeCompleto as string | undefined;
const harmLicoes    = nomeHarmCompleto ? detectarLicoesCarmicas(nomeHarmCompleto)    : null;
const harmTendencias = nomeHarmCompleto ? detectarTendenciasOcultas(nomeHarmCompleto) : null;

// Calcula os 5 números do NOME DE NASCIMENTO diretamente.
// analysis.numero_expressao etc. guardam os números do nome HARMONIZADO (conforme analyze.ts:237).
const nomeNascStr = (rankingSocial?.nomeNascimento as string | undefined) ?? '';
const dataNascStr = (analysis.data_nascimento as string | undefined) ?? '';
const nascCalc = nomeNascStr && dataNascStr
  ? calcularCincoNumeros(nomeNascStr, dataNascStr)
  : null;

// Kármicos do NOME DE NASCIMENTO — computados server-side para o comparativo "antes × depois".
// O banco salva os dados do nome HARMONIZADO (melhor candidato), por isso recalculamos o nascimento aqui.
const nascLicoes     = nomeNascStr ? detectarLicoesCarmicas(nomeNascStr)    : null;
const nascTendencias = nomeNascStr ? detectarTendenciasOcultas(nomeNascStr) : null;
const nascDebitos    = (nascCalc && dataNascStr)
  ? calcularDebitosCarmicos(dataNascStr, nascCalc.destino, nascCalc.motivacao, nascCalc.expressao)
  : null;
const nascTriangulos = (nomeNascStr && dataNascStr) ? calcularTodosTriangulos(nomeNascStr, dataNascStr) : null;
const nascBloqueios  = nascTriangulos ? detectarBloqueios(nascTriangulos) : [];
const eliminatedBloqueios = nascBloqueios.filter((b: any) => !harmBloqueiosCodigos.has(b.codigo));

// ── Estrela SVG dupla — pré-cálculo ──────────────────────────────────────────
function starPts(cx: number, cy: number, R: number, r: number): string {
  const pts: string[] = [];
  for (let i = 0; i < 5; i++) {
    const a1 = ((-90 + i * 72) * Math.PI) / 180;
    pts.push(`${(cx + R * Math.cos(a1)).toFixed(1)},${(cy + R * Math.sin(a1)).toFixed(1)}`);
    const a2 = ((-90 + 36 + i * 72) * Math.PI) / 180;
    pts.push(`${(cx + r * Math.cos(a2)).toFixed(1)},${(cy + r * Math.sin(a2)).toFixed(1)}`);
  }
  return pts.join(' ');
}
function tipXY(cx: number, cy: number, r: number, i: number) {
  const a = ((-90 + i * 72) * Math.PI) / 180;
  return { x: +(cx + r * Math.cos(a)).toFixed(1), y: +(cy + r * Math.sin(a)).toFixed(1) };
}

const SVG_CX = 330, SVG_CY = 260;
const SVG_oR = 160, SVG_oInner = 62;
const SVG_iR = 88,  SVG_iInner = 34;
const svgOuterPts = starPts(SVG_CX, SVG_CY, SVG_oR, SVG_oInner);
const svgInnerPts = starPts(SVG_CX, SVG_CY, SVG_iR, SVG_iInner);

const SVG_TIP_KEYS   = ['destino', 'expressao', 'motivacao', 'missao', 'impressao'] as const;
const SVG_TIP_LABELS = ['Destino', 'Expressão', 'Motivação', 'Missão', 'Impressão'];
type TipKey = typeof SVG_TIP_KEYS[number];

const nascNums: Record<TipKey, number | null> = {
  destino:   nascCalc?.destino   ?? analysis.numero_destino ?? null,
  expressao: nascCalc?.expressao ?? null,
  motivacao: nascCalc?.motivacao ?? null,
  missao:    nascCalc?.missao    ?? null,
  impressao: nascCalc?.impressao ?? null,
};
const harmNums: Record<TipKey, number | null> = {
  destino:   rankingSocial?.destino               ?? analysis.numero_destino   ?? null,
  expressao: rankingSocial?.melhorNome?.expressao ?? null,
  motivacao: rankingSocial?.melhorNome?.motivacao ?? null,
  missao:    rankingSocial?.melhorNome?.missao    ?? null,
  impressao: rankingSocial?.melhorNome?.impressao ?? null,
};

const svgTips = SVG_TIP_KEYS.map((key, i) => {
  const anchors = ['middle', 'start', 'start', 'end', 'end'] as const;
  const dxArr   = [0, 5, 5, -5, -5];
  const dyArr   = [-5, 0, 8, 8, 0];
  return {
    key,
    label:     SVG_TIP_LABELS[i],
    nNasc:     nascNums[key],
    nHarm:     harmNums[key],
    same:      nascNums[key] === harmNums[key],
    isDestino: key === 'destino',
    outerTip:  tipXY(SVG_CX, SVG_CY, SVG_oR + 20, i),
    innerTip:  tipXY(SVG_CX, SVG_CY, SVG_iR + 18, i),
    labelPos:  tipXY(SVG_CX, SVG_CY, SVG_oR + 50, i),
    anchor:    anchors[i],
    dx:        dxArr[i],
    dy:        dyArr[i],
  };
});

const dimSublabels: Record<TipKey, string> = {
  destino:   'Data de Nascimento',
  expressao: 'Letras do Nome',
  motivacao: 'Vogais do Nome',
  missao:    'Consoantes do Nome',
  impressao: 'Primeiro Nome',
};
---

{/* ── SEÇÃO 1: A HARMONIZAÇÃO ─────────────────────────────────────────────── */}
{rankingSocial?.melhorNome && (
  <section class="pt-6 mb-12">
    <div class="mb-6 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">A Transformação</p>
      <h2 class="font-cinzel text-2xl font-bold text-white">A Harmonização</h2>
    </div>

    {/* Estrela SVG dupla — viewBox ampliado para não cortar labels */}
    <div class="flex justify-center mb-5">
      <svg viewBox="0 0 660 520" width="100%" style="max-width:660px;" xmlns="http://www.w3.org/2000/svg">
        <polygon
          points={svgOuterPts}
          fill="#D4AF37"
          fill-opacity="0.10"
          stroke="#D4AF37"
          stroke-width="2"
        />
        <polygon
          points={svgInnerPts}
          fill="#DC2626"
          fill-opacity="0.12"
          stroke="#DC2626"
          stroke-width="1.5"
        />
        {svgTips.map(t => (
          <g>
            <text
              x={t.labelPos.x + t.dx}
              y={t.labelPos.y + t.dy}
              fill="#9CA3AF"
              font-size="12"
              font-family="sans-serif"
              text-anchor={t.anchor}
            >{t.label}</text>
            {t.nHarm != null && (
              <text
                x={t.outerTip.x}
                y={t.outerTip.y + 6}
                fill="#D4AF37"
                font-size="18"
                font-family="sans-serif"
                font-weight="bold"
                text-anchor="middle"
              >{t.nHarm}</text>
            )}
            {t.nNasc != null && (
              <text
                x={t.innerTip.x}
                y={t.innerTip.y + 5}
                fill="#DC2626"
                font-size="15"
                font-family="sans-serif"
                font-weight="bold"
                text-anchor="middle"
              >{t.nNasc}</text>
            )}
          </g>
        ))}
      </svg>
    </div>

    {/* Legenda */}
    <div class="flex justify-center gap-8 mb-6 text-xs text-gray-400">
      <span class="flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-full border border-red-500" style="background:rgba(220,38,38,0.25);"></span>
        {rankingSocial.nomeNascimento}
      </span>
      <span class="flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-full border border-[#D4AF37]" style="background:rgba(212,175,55,0.2);"></span>
        {rankingSocial.melhorNome.nomeCompleto}
      </span>
    </div>

    {/* Texto introdutório */}
    <div class="rounded-2xl bg-white/[0.03] p-6 mb-8">
      <h3 class="font-cinzel text-base font-bold text-[#D4AF37] mb-3">O Escudo Magnético</h3>
      <p class="text-gray-300 text-sm leading-relaxed mb-4">
        O nome de nascimento é o campo vibracional que você recebeu ao chegar nesta encarnação — sua semente de origem.
        Ele carrega padrões genuínos de força, mas também pode conter sequências de energia que criam resistência e ciclos
        difíceis de romper. Não é um defeito: é simplesmente o ponto de partida ainda sem o refinamento que apenas a intenção
        consciente pode trazer.
      </p>
      <p class="text-gray-300 text-sm leading-relaxed">
        A Harmonização cria uma segunda camada — um escudo vibracional que se sobrepõe ao campo original sem apagá-lo. A
        estrela interna vermelha representa o campo de nascimento. A estrela dourada externa é o Nome Social Harmonizado que
        envolve e protege esse campo, neutralizando bloqueios e amplificando as qualidades positivas.
      </p>
    </div>

    {/* ── Comparativo das 5 Dimensões ── */}
    <div class="mb-3 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-1">Comparativo</p>
      <h3 class="font-cinzel text-lg font-bold text-white mb-4">Antes × Depois por Dimensão</h3>
    </div>

    <div class="space-y-3 mb-10">
      {SVG_TIP_KEYS.map((key, i) => {
        const nN = nascNums[key];
        const nH = harmNums[key];
        const isImutavel = key === 'destino';
        const changed = !isImutavel && nN !== nH;
        const label = SVG_TIP_LABELS[i];
        const sublabel = dimSublabels[key];
        const badgeText = isImutavel ? 'IMUTÁVEL' : changed ? 'VIBRAÇÃO ALTERADA' : 'MANTIDA';
        const badgeCls = isImutavel
          ? 'text-[#bea5ff] bg-[#bea5ff]/10'
          : changed
          ? 'text-[#D4AF37] bg-[#D4AF37]/10'
          : 'text-gray-400 bg-white/5';
        const nascArcano = nN != null ? (ARCANOS[nN] as any) : null;
        const harmArcano = nH != null ? (ARCANOS[nH] as any) : null;
        return (
          <div class="rounded-2xl bg-white/[0.03] p-4">
            <div class="flex items-center justify-between mb-3">
              <div>
                <h4 class="font-cinzel text-sm font-bold text-white">{label}</h4>
                <p class="text-xs text-gray-500">{sublabel}</p>
              </div>
              <span class={`text-[9px] font-bold uppercase tracking-wider px-2 py-1 rounded-full ${badgeCls}`}>{badgeText}</span>
            </div>
            {isImutavel ? (
              <div class="rounded-xl bg-gray-600/10 border border-gray-600/20 p-5 text-center">
                <span class="text-[9px] text-gray-500 font-bold uppercase tracking-wider block mb-3">Imutável — calculado pela data de nascimento</span>
                <div class="font-cinzel text-4xl font-bold text-gray-300">{nH ?? '?'}</div>
                {harmArcano?.nome && <p class="text-[10px] text-gray-400/80 mt-2">{harmArcano.nome}</p>}
                {harmArcano?.palavraChave && <p class="text-[9px] text-gray-500 mt-1">{harmArcano.palavraChave}</p>}
              </div>
            ) : (
              <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
                <div class="rounded-xl bg-red-500/10 border border-red-500/20 p-3 text-center">
                  <p class="text-[9px] text-red-400 font-bold uppercase mb-1">Nascimento</p>
                  <div class="font-cinzel text-3xl font-bold text-red-400">{nN ?? '?'}</div>
                  {nascArcano?.nome    && <p class="text-[10px] text-red-300/80 mt-1">{nascArcano.nome}</p>}
                  {nascArcano?.palavraChave && <p class="text-[9px] text-gray-500">{nascArcano.palavraChave}</p>}
                </div>
                <span class="text-gray-600 text-xl font-bold">»</span>
                <div class="rounded-xl bg-emerald-500/10 border border-emerald-500/20 p-3 text-center">
                  <p class="text-[9px] text-emerald-400 font-bold uppercase mb-1">Harmonizado</p>
                  <div class="font-cinzel text-3xl font-bold text-emerald-400">{nH ?? '?'}</div>
                  {harmArcano?.nome    && <p class="text-[10px] text-emerald-300/80 mt-1">{harmArcano.nome}</p>}
                  {harmArcano?.palavraChave && <p class="text-[9px] text-gray-500">{harmArcano.palavraChave}</p>}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    {/* ── Comparativo das Interferências Kármicas ── */}
    <div class="mb-3 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-1">Resultado</p>
      <h3 class="font-cinzel text-lg font-bold text-white mb-4">Interferências Kármicas Antes × Depois</h3>
    </div>

    <div class="space-y-4">

      {/* Bloqueios */}
      {bloqueios.length > 0 && (
        <div class="rounded-2xl bg-white/[0.03] p-4">
          <h4 class="font-cinzel text-sm font-bold text-white mb-3">Bloqueios Energéticos</h4>
          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 mb-4">
            <div class="rounded-xl bg-red-500/10 border border-red-500/20 p-4 text-center">
              <p class="text-[9px] text-red-400 font-bold uppercase mb-2">Nascimento</p>
              <div class="font-cinzel text-4xl font-bold text-red-400">{nascBloqueios.length}</div>
              <p class="text-xs text-red-400/60 mt-1">bloqueio{nascBloqueios.length !== 1 ? 's' : ''}</p>
            </div>
            <span class="text-gray-600 text-xl font-bold">»</span>
            <div class="rounded-xl bg-emerald-500/10 border border-emerald-500/20 p-4 text-center">
              <p class="text-[9px] text-emerald-400 font-bold uppercase mb-2">Harmonizado</p>
              <div class="font-cinzel text-4xl font-bold text-emerald-400">{harmBloqueios.length}</div>
              <p class="text-xs text-emerald-400/60 mt-1">bloqueio{harmBloqueios.length !== 1 ? 's' : ''}</p>
            </div>
          </div>
          {eliminatedBloqueios.length > 0 && (
            <div class="space-y-2">
              {eliminatedBloqueios.map((b: any) => (
                <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-emerald-500/5 border border-emerald-500/20">
                  <span class="text-emerald-400 shrink-0">✓</span>
                  <p class="text-sm text-gray-300">
                    <span class="text-emerald-400 font-semibold">Eliminado:</span> {b.titulo ?? b.codigo}
                  </p>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* Débitos Kármicos */}
      {nascDebitos !== null && (
        <div class="rounded-2xl bg-white/[0.03] p-4">
          <h4 class="font-cinzel text-sm font-bold text-white mb-3">Débitos Kármicos</h4>
          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 mb-3">
            <div class="rounded-xl bg-red-500/10 border border-red-500/20 p-4 text-center">
              <p class="text-[9px] text-red-400 font-bold uppercase mb-2">Nascimento</p>
              <div class="font-cinzel text-4xl font-bold text-red-400">{nascDebitos.length}</div>
              <p class="text-xs text-red-400/60 mt-1">débito{nascDebitos.length !== 1 ? 's' : ''}</p>
            </div>
            <span class="text-gray-600 text-xl font-bold">»</span>
            <div class="rounded-xl bg-amber-500/10 border border-amber-500/20 p-4 text-center">
              <p class="text-[9px] text-amber-400 font-bold uppercase mb-2">Após Harmonização</p>
              <div class="font-cinzel text-4xl font-bold text-amber-400">{debitosFixos.length}</div>
              <p class="text-xs text-amber-400/60 mt-1">fixo{debitosFixos.length !== 1 ? 's' : ''} restante{debitosFixos.length !== 1 ? 's' : ''}</p>
            </div>
          </div>
          {debitosVariaveis.length > 0 && (
            <div class="flex items-start gap-3 px-3 py-2 rounded-lg bg-white/[0.03]">
              <span class="text-[#D4AF37] shrink-0 text-sm">✦</span>
              <p class="text-xs text-gray-400">
                <span class="text-[#D4AF37] font-semibold">{debitosVariaveis.length} débito{debitosVariaveis.length !== 1 ? 's' : ''} variável{debitosVariaveis.length !== 1 ? 'is' : ''}</span> — originado{debitosVariaveis.length !== 1 ? 's' : ''} nos números de Motivação ou Expressão.
                Pode{debitosVariaveis.length !== 1 ? 'm' : ''} ser reduzido{debitosVariaveis.length !== 1 ? 's' : ''} pelo nome harmonizado.
                Os {debitosFixos.length} fixo{debitosFixos.length !== 1 ? 's' : ''} são imutáveis — gravados na data de nascimento.
              </p>
            </div>
          )}
          {debitosFixos.length > 0 && (
            <div class="space-y-2 mt-3">
              {debitosFixos.map((d: any) => (
                <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#D4AF37]/5 border border-[#D4AF37]/20">
                  <span class="text-[#D4AF37] shrink-0">⚠</span>
                  <div class="flex-1">
                    <span class="text-[9px] text-[#D4AF37] font-bold uppercase tracking-wider block mb-0.5">Permanente</span>
                    <p class="text-sm text-gray-300 font-medium">{d.titulo ?? `Débito Kármico ${d.numero}`}</p>
                  </div>
