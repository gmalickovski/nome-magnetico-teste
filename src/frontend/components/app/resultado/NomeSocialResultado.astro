{/* ── SCRIPT: handler dos cards clicáveis de nome social ──────────────────── */}
{rankingSocial && (
  <script>
    document.querySelectorAll('.analisar-nome-card').forEach(function(card) {
      card.addEventListener('click', async function() {
        const nome = card.getAttribute('data-nome');
        const nomeNasc = card.getAttribute('data-nome-nasc');
        const dataNasc = card.getAttribute('data-data-nasc');
        const canGenerate = card.getAttribute('data-can-generate') === 'true';
        if (!nome || !nomeNasc || !dataNasc) return;
        if (!canGenerate) {
          window.location.href = '/app?produto=nome_social';
          return;
        }

        const loadingEl = card.querySelector('.card-loading');
        if (loadingEl) loadingEl.classList.remove('hidden');
        (card as HTMLElement).style.pointerEvents = 'none';

        try {
          let authHeader = {};
          try {
            const storedSession = window.localStorage.getItem('nome-magnetico-auth');
            const session = storedSession ? JSON.parse(storedSession) : null;
            const token = session?.access_token ?? session?.currentSession?.access_token ?? null;
            if (token) {
              authHeader = { Authorization: 'Bearer ' + token };
            }
          } catch {}

          const res = await fetch('/api/analyze', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json', ...authHeader },
            body: JSON.stringify({
              product_type: 'nome_social',
              nome_completo: nomeNasc,
              data_nascimento: dataNasc,
              nomes_candidatos: [nome],
              nome_social_principal: nome,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error ?? 'Erro ao iniciar análise');
          window.location.href = '/app/resultado/' + data.analysisId;
        } catch (err) {
          if (loadingEl) loadingEl.classList.add('hidden');
          (card as HTMLElement).style.pointerEvents = '';
          alert('Erro ao gerar análise: ' + (err instanceof Error ? err.message : String(err)));
        }
      });
    });
  </script>
)}

