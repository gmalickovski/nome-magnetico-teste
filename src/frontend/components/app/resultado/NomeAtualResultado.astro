---
/**
 * NomeAtualResultado — seções do relatório HTML da Análise Gratuita (Nome Atual).
 * Focado na análise do nome de nascimento. SEM sugestões de nomes.
 *
 * Ordem das seções:
 *   1. A Estrela de 5 Pontas (Expressão em destaque)
 *   2. Arquétipo
 *   3. Os 4 Triângulos
 *   4. Arcano Regente
 *   5. O Raio-X dos Bloqueios + CTA se houver bloqueios
 *   6. Karma, Lições e Tendências
 *   7. Análise Completa da IA
 *   8. CTA Final — convite para o Nome Social
 */
import TriangleVisualization from '../TriangleVisualization';
import KarmicLessons from '../KarmicLessons';
import KarmicDebts from '../KarmicDebts';
import HiddenTendencies from '../HiddenTendencies';
import BlockAnalysisCard from '../BlockAnalysisCard';
import ArcanoCard from '../ArcanoCard';

interface Props {
  analysis: any;
  nomeExibido: string;
  cincoNumeros: Array<{ label: string; sublabel: string; value: number | null; icon: string }>;
  expressao: number | null;
  arquetipoData: any;
  tVida: any;
  tPessoal: any;
  tSocial: any;
  tDestino: any;
  hasTriangulos: boolean;
  bloqueios: any[];
  arcanoData: any;
  licoesRaw: any[] | null;
  debitosRaw: any[] | null;
  tendenciasRaw: any[] | null;
  frequenciasRaw: Record<number, number> | null;
  analiseHtml: string | null;
}

const {
  analysis,
  nomeExibido,
  cincoNumeros,
  expressao,
  arquetipoData,
  tVida, tPessoal, tSocial, tDestino,
  hasTriangulos,
  bloqueios,
  arcanoData,
  licoesRaw,
  debitosRaw,
  tendenciasRaw,
  frequenciasRaw,
  analiseHtml,
} = Astro.props;

const destinoNum = cincoNumeros.find(n => n.label === 'Destino');

// ── Score-based CTA logic ──────────────────────────────────────────────────
const score = (analysis as any).score as number | null;
const primeiroNome = nomeExibido.split(' ')[0] ?? nomeExibido;

const debitosFixos    = (debitosRaw  ?? []).filter((d: any) => d.fixo === true);
const debitosVariaveis = (debitosRaw ?? []).filter((d: any) => !d.fixo);
const licoes           = licoesRaw    ?? [];
const tendencias       = tendenciasRaw ?? [];

// Things harmonization can actually improve
const temBloqueios        = bloqueios.length > 0;
const temDebitosVariaveis = debitosVariaveis.length > 0;
const temLicoes           = licoes.length > 0;
const temTendencias       = tendencias.length > 0;
const temMelhorias        = temBloqueios || temDebitosVariaveis || temLicoes || temTendencias;
const temPermanentes      = debitosFixos.length > 0;

type ScoreNivel = 'excelente' | 'aceitavel' | 'baixo' | 'sem-score';
const scoreNivel: ScoreNivel =
  score === null || score === undefined ? 'sem-score'
  : score >= 80  ? 'excelente'
  : score >= 50  ? 'aceitavel'
  : 'baixo';

const temProblemas = bloqueios.length > 0 || (debitosRaw && debitosRaw.length > 0) || (licoesRaw && licoesRaw.length > 0);
---

{/* ── SEÇÃO 1: O NÚMERO DE DESTINO ─────────────────────────────────────── */}
<section class="pt-6 mb-12">
  <div class="mb-5 px-1">
    <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#bea5ff]/70 mb-2">O Projeto de Fábrica</p>
    <h2 class="font-cinzel text-2xl font-bold text-white">O Seu Número de Destino</h2>
    <p class="text-sm text-gray-400 mt-1">Calculado a partir da sua data de nascimento — o único número verdadeiramente imutável.</p>
  </div>

  {/* Card do Destino — destaque central */}
  <div class="flex justify-center mb-8">
    <div class="rounded-2xl bg-[#bea5ff]/8 border border-[#bea5ff]/30 p-8 text-center flex flex-col items-center gap-2 w-64 transition-all duration-700 hover:shadow-lg hover:shadow-purple-500/10">
      <span class="text-[#bea5ff]/40 text-2xl leading-none">◈</span>
      <div class="font-cinzel text-7xl font-bold text-[#bea5ff] leading-none">{destinoNum?.value ?? '?'}</div>
      <div class="text-white text-sm font-semibold mt-2">Número de Destino</div>
      <div class="text-[#bea5ff]/60 text-xs">A Estrada da Sua Alma</div>
    </div>
  </div>

  {/* Parágrafo 1 — sobre a imutabilidade do Destino */}
  <div class="rounded-2xl bg-white/[0.03] p-6 md:p-8">
    <h3 class="font-cinzel text-base font-bold text-[#bea5ff] mb-3">O Que Não Pode Ser Mudado — e o Que Pode</h3>
    <p class="text-gray-300 text-sm leading-relaxed">
      O seu Número de Destino é o seu projeto original — calculado a partir da data em que você nasceu, ele
      representa a trilha que a sua alma escolheu antes mesmo de você receber um nome. Ele não pode ser
      alterado por nenhuma prática, ritual ou mudança de nome, pois está gravado no tecido do tempo desde
      o seu primeiro respiro. É a sua Estrada: não te define, mas te ilumina. Não importa o caminho que você
      escolha — o Destino será sempre o horizonte para o qual a sua bússola interior aponta.
    </p>
  </div>

  {/* 4 numbers do nome — cards menores lado a lado */}
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5">
    {(() => {
      const nums4 = cincoNumeros.filter(n => n.label !== 'Destino');
      const palettes = [
        { color: '#9A6B00', border: 'rgba(154,107,0,0.55)',   bg: 'rgba(154,107,0,0.05)'   },
        { color: '#6d28d9', border: 'rgba(109,40,217,0.55)',  bg: 'rgba(109,40,217,0.05)'  },
        { color: '#0369a1', border: 'rgba(3,105,161,0.55)',   bg: 'rgba(3,105,161,0.05)'   },
        { color: '#15803d', border: 'rgba(21,128,61,0.55)',   bg: 'rgba(21,128,61,0.05)'   },
      ];
      return nums4.map((num, i) => {
        const p = palettes[i % palettes.length];
        return (
          <div
            style={`border-radius:16px; border:1.5px solid ${p.border}; background:${p.bg}; padding:16px; text-align:center; display:flex; flex-direction:column; align-items:center; gap:6px;`}
          >
            <span style={`font-size:10px; font-weight:700; color:${p.color}; text-transform:uppercase; letter-spacing:0.08em;`}>{num.label}</span>
            <div style={`font-family:'Cinzel',serif; font-size:2.5rem; font-weight:700; color:${p.color}; line-height:1;`}>{num.value ?? '?'}</div>
            <div style={`font-size:11px; color:${p.color}; opacity:0.8;`}>{num.sublabel}</div>
          </div>
        );
      });
    })()}
  </div>

  {/* Parágrafo 2 — sobre os 4 números mutáveis */}
  <div class="rounded-2xl bg-white/[0.03] p-6 md:p-8 mt-5">
    <h3 class="font-cinzel text-sm font-bold text-white/80 mb-3">Os Números do Nome — O Veículo</h3>
    <p class="text-gray-300 text-sm leading-relaxed">
      Os outros quatro números — Expressão, Motivação, Impressão e Missão — emergem das letras do seu
      nome de batismo. Diferente do Destino, esses números respondem à vibração das letras que você usa.
      Quando o arranjo do nome muda, esses campos se reorganizam — podendo criar ou desfazer bloqueios,
      abrir ou fechar caminhos. Você não precisa mudar quem você é. Apenas o veículo através do qual a sua
      essência se expressa no mundo.
    </p>
  </div>
</section>

{/* ── SEÇÃO 3: OS 4 TRIÂNGULOS ────────────────────────────────────────── */}
{hasTriangulos && (
  <section class="mt-16 mb-12">
    <div class="mb-3 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">Mapa de Triângulos</p>
      <h2 class="font-cinzel text-2xl font-bold text-white">Os 4 Triângulos Numerológicos</h2>
    </div>
    <TriangleVisualization
      client:load
      nome={nomeExibido}
      vida={tVida!}
      pessoal={tPessoal!}
      social={tSocial!}
      destino={tDestino!}
      bloqueios={bloqueios as any}
    />

    {/* Texto explicativo após os triângulos */}
    <div class="mt-8 space-y-6">
      <div class="rounded-2xl bg-white/[0.03] p-6 md:p-8">
        <h3 class="font-cinzel text-lg font-bold text-[#D4AF37] mb-4">O Que São os 4 Triângulos Numerológicos</h3>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          Na Numerologia Cabalística, o nome não é apenas um conjunto de letras — ele funciona como um campo de força
          contínuo que emite uma frequência específica a cada vez que é pronunciado, escrito ou assinado. Para compreender
          a real profundidade e as nuances dessa frequência, o estudo do nome é dividido em quatro estruturas geométricas
          chamadas Pirâmides de Fluxo, cada uma revelando uma camada distinta da sua jornada. Juntas, elas formam a
          anatomia vibratória completa do seu nome de batismo.
        </p>
        <p class="text-gray-300 text-sm leading-relaxed">
          A leitura dessas pirâmides funciona de forma orgânica e progressiva. Cada triângulo mapeia um aspecto específico
          da sua vida — desde a vitalidade e os padrões gerais de existência, passando pelo universo íntimo e emocional,
          pela forma como o mundo externo lhe percebe e responde, até culminar no propósito maior que o seu Destino
          inevitavelmente atrairá. Quando uma sequência de números se repete três ou mais vezes em qualquer triângulo,
          ela forma um Bloqueio Energético — uma frequência de travamento que age silenciosamente sobre aquela dimensão
          da sua vida, 24 horas por dia.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-2xl bg-[#D4AF37]/5 p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">🔺</span>
            <h4 class="font-cinzel text-sm font-bold text-[#D4AF37]">Triângulo da Vida</h4>
          </div>
          <p class="text-gray-400 text-xs leading-relaxed">
            Calculado a partir do valor puro de cada letra do nome, sem modificadores externos. Revela os padrões
            fundamentais de existência — os temas que se repetem nas diferentes fases da vida, independentemente das
            circunstâncias. É a vibração base que permeia toda a trajetória de {primeiroNome}, moldando a relação com
            o corpo, a vitalidade, o dinheiro e a resiliência diante dos desafios. Os bloqueios neste triângulo afetam
            a saúde geral e os ciclos de prosperidade.
          </p>
        </div>
        <div class="rounded-2xl bg-[#bea5ff]/5 p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">💛</span>
            <h4 class="font-cinzel text-sm font-bold text-[#bea5ff]">Triângulo Pessoal</h4>
          </div>
          <p class="text-gray-400 text-xs leading-relaxed">
            Calculado adicionando ao valor de cada letra o número do dia de nascimento. Mapeia a dimensão íntima e
            emocional — as reações internas, os mecanismos de defesa e os padrões afetivos que raramente são visíveis
            para o mundo externo. Revela como {primeiroNome} processa as experiências por dentro, o que realmente move
            suas escolhas e os ciclos emocionais que se repetem nos relacionamentos mais próximos.
          </p>
        </div>
        <div class="rounded-2xl bg-emerald-500/5 p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">🌐</span>
            <h4 class="font-cinzel text-sm font-bold text-emerald-400">Triângulo Social</h4>
          </div>
          <p class="text-gray-400 text-xs leading-relaxed">
            Calculado adicionando ao valor de cada letra o número do mês de nascimento. Revela como o mundo externo
            percebe e responde a {primeiroNome} — a impressão que o nome irradia nas interações sociais, profissionais
            e públicas. Governa o magnetismo pessoal, as oportunidades de networking e a reputação. É aqui que se
            concentram os bloqueios que sabotam visibilidade, vendas e conexões estratégicas.
          </p>
        </div>
        <div class="rounded-2xl bg-amber-500/5 p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">⭐</span>
            <h4 class="font-cinzel text-sm font-bold text-amber-400">Triângulo do Destino</h4>
          </div>
          <p class="text-gray-400 text-xs leading-relaxed">
            Calculado adicionando ao valor de cada letra a soma já reduzida do dia e mês de nascimento. É o triângulo
            mais revelador: mapeia os resultados que tendem a se materializar ao longo da vida, a missão maior e os
            frutos que a frequência vibratória do nome produz. Quando há bloqueios aqui, eles se manifestam como ciclos
            de esforço que raramente chegam à colheita — o trabalho não se converte em resultado.
          </p>
        </div>
      </div>
    </div>
  </section>
)}

{/* ── SEÇÃO 4: ARCANO REGENTE ─────────────────────────────────────────── */}
{arcanoData && (
  <section class="mt-16 mb-12">
    <div class="mb-3 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">Ciclo Atual</p>
      <h2 class="font-cinzel text-2xl font-bold text-white">Arcano Regente</h2>
    </div>
    <ArcanoCard
      client:load
      arcano={{
        numero: arcanoData.numero,
        nome: arcanoData.nome,
        palavraChave: arcanoData.palavraChave,
        descricao: arcanoData.descricao,
      }}
      label="Arcano que governa seu ciclo de vida"
    />
  </section>
)}

{/* ── SEÇÃO 5: O RAIO-X DOS BLOQUEIOS ─────────────────────────────────── */}
<section class="mt-16 mb-10">
  <div class="mb-3 px-1">
    <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">O Raio-X dos Bloqueios</p>
    <h2 class={`font-cinzel text-2xl font-bold ${bloqueios.length > 0 ? 'text-red-400' : 'text-emerald-400'}`}>
      {bloqueios.length > 0
        ? `${bloqueios.length} Bloqueio${bloqueios.length > 1 ? 's' : ''} Energético${bloqueios.length > 1 ? 's' : ''} Detectado${bloqueios.length > 1 ? 's' : ''}`
        : 'Energia Limpa — Sem Bloqueios'}
    </h2>
    {bloqueios.length > 0 && hasTriangulos && (
      <div class="mt-3 rounded-xl bg-[#bea5ff]/5 border border-[#bea5ff]/20 px-4 py-3">
        <p class="text-xs text-[#c084fc] leading-relaxed">
          Os números em vermelho na pirâmide do Triângulo da Vida acima indicam exatamente onde essa energia está vazando.
        </p>
      </div>
    )}
  </div>
  {bloqueios.length > 0 ? (
    <div class="flex flex-col gap-4">
      {bloqueios.map((b, i) => (
        <BlockAnalysisCard client:load bloqueio={b as any} defaultOpen={i === 0} />
      ))}
    </div>
  ) : (
    <div class="rounded-2xl bg-emerald-500/5 p-6 text-center">
      <div class="text-4xl mb-3">✦</div>
      <p class="text-emerald-400 font-medium mb-1">Todos os 4 triângulos estão limpos</p>
      <p class="text-gray-400 text-sm">Nenhuma sequência energética negativa foi detectada no seu nome. Isso indica um fluxo energético natural e desobstruído.</p>
    </div>
  )}
</section>

{/* ── CTA PÓS-BLOQUEIOS (só exibe se tiver bloqueios) ───────────────────── */}
{bloqueios.length > 0 && (
  <section class="mt-8 mb-12">
    <div class="rounded-2xl border border-[#D4AF37]/30 bg-gradient-to-br from-[#D4AF37]/5 to-[#7C3AED]/5 p-6 md:p-8 text-center">
      <div class="text-3xl mb-3">⚡</div>
      <h3 class="font-cinzel text-xl font-bold text-white mb-2">
        Esses bloqueios podem ser eliminados
      </h3>
      <p class="text-gray-300 text-sm leading-relaxed mb-2 max-w-xl mx-auto">
        A numerologia cabalística possui uma solução precisa: o <strong class="text-[#D4AF37]">Nome Social Harmonizado</strong>.
        Um nome calculado para que nenhuma sequência dos seus triângulos forme esses padrões de trava — alinhando
        sua Expressão com seu Destino e injetando as vibrações exatas que você deseja atrair.
      </p>
      <p class="text-gray-400 text-xs mb-5 max-w-lg mx-auto">
        Com o Nome Social, nossa IA analisa variações do seu nome, elimina os bloqueios e gera um guia completo de como
        usar o novo nome para reprogramar seu campo magnético.
      </p>
      <a
        href="/nome-social"
        data-umami-event="cta_resultado_gratis_upsell"
        class="inline-flex items-center gap-2 bg-[#D4AF37] text-black font-bold px-8 py-3 rounded-full hover:bg-[#f2ca50] transition-all duration-300 hover:scale-105"
      >
        ✦ Quero eliminar meus bloqueios — Ver Nome Social
      </a>
    </div>
  </section>
)}

{/* ── SEÇÃO 6: DÉBITOS KÁRMICOS ───────────────────────────────────────── */}
{debitosRaw !== null && (
  <section class="mt-16 mb-12">
    <div class="mb-4 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">O Peso do Passado</p>
      <h2 class="font-cinzel text-2xl font-bold text-white">Débitos Kármicos</h2>
    </div>
    <KarmicDebts client:load debitos={debitosRaw as any} nomeCompleto={nomeExibido} />
    <div class="mt-4 rounded-xl border border-[#bea5ff]/25 bg-[#bea5ff]/5 p-4">
      <p class="text-xs text-[#c084fc] uppercase tracking-wider font-semibold mb-2">Como a Harmonização Atua nos Débitos Kármicos</p>
      <p class="text-gray-300 text-sm leading-relaxed">
        Débitos variáveis — originados nos números de Motivação ou Expressão — podem ser reduzidos ou eliminados por uma variação do nome que reajuste essas frequências.
        O processo de harmonização calcula combinações que minimizam esses padrões no campo vibracional.
      </p>
    </div>
  </section>
)}

{/* ── SEÇÃO 6B: LIÇÕES KÁRMICAS ────────────────────────────────────────── */}
{licoesRaw !== null && (
  <section class="mt-16 mb-12">
    <div class="mb-4 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">Lacunas Energéticas</p>
      <h2 class="font-cinzel text-2xl font-bold text-white">Lições Kármicas</h2>
    </div>
    <KarmicLessons client:load licoes={licoesRaw as any} nomeCompleto={nomeExibido} showSolution={false} />
  </section>
)}

{/* ── SEÇÃO 7: TENDÊNCIAS OCULTAS ─────────────────────────────────────── */}
{(tendenciasRaw !== null || (frequenciasRaw && Object.keys(frequenciasRaw).length > 0)) && (
  <section class="mt-16 mb-12">
    <div class="mb-4 px-1">
      <p class="font-cinzel text-xs uppercase tracking-[0.15em] text-[#D4AF37]/70 mb-2">Frequências Numéricas</p>
      <h2 class="font-cinzel text-2xl font-bold text-white">Tendências Ocultas</h2>
    </div>
    <HiddenTendencies
      client:load
      tendencias={tendenciasRaw as any}
      frequencias={frequenciasRaw ?? {}}
      nomeCompleto={nomeExibido}
      showSolution={false}
    />
  </section>
)}

{/* ── DIAGNÓSTICO CONSOLIDADO ─────────────────────────────────────────── */}
{(bloqueios.length > 0 || (debitosRaw && debitosRaw.length > 0) || (licoesRaw && licoesRaw.length > 0) || (tendenciasRaw && tendenciasRaw.length > 0)) && (
  <section class="mt-16 mb-12">
    {scoreNivel === 'excelente' ? (
      <div class="rounded-2xl border border-[#D4AF37]/30 bg-[#D4AF37]/5 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">✦</span>
          <h3 class="font-cinzel text-lg font-bold text-[#D4AF37]">Pontos de Otimização Identificados</h3>
          {score !== null && <span class="ml-auto text-xs font-bold px-3 py-1 rounded-full bg-emerald-500/15 text-emerald-400">Saúde Vibracional: {score}%</span>}
        </div>
        <p class="text-gray-300 text-sm leading-relaxed mb-5">
          Mesmo com uma vibração acima da média, sua análise identificou elementos que ainda podem ser refinados —
          padrões sutis que, sem harmonização, continuam influenciando seu campo energético silenciosamente:
        </p>
        <div class="space-y-2 mb-5">
          {bloqueios.length > 0 && (
            <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-red-500/10 border border-red-500/20">
              <span class="text-red-400 text-sm shrink-0">🔴</span>
              <p class="text-red-300 text-sm"><strong>{bloqueios.length} bloqueio{bloqueios.length > 1 ? 's' : ''} energético{bloqueios.length > 1 ? 's' : ''}</strong> — ainda ativo{bloqueios.length > 1 ? 's' : ''} nos triângulos do nome</p>
            </div>
          )}
          {debitosVariaveis.length > 0 && (
            <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-amber-500/10 border border-amber-500/20">
              <span class="text-amber-400 text-sm shrink-0">🟡</span>
              <p class="text-amber-300 text-sm"><strong>{debitosVariaveis.length} débito{debitosVariaveis.length > 1 ? 's' : ''} kármico{debitosVariaveis.length > 1 ? 's' : ''} variável{debitosVariaveis.length > 1 ? 'is' : ''}</strong> — pode{debitosVariaveis.length > 1 ? 'm' : ''} ser reduzido{debitosVariaveis.length > 1 ? 's' : ''} pela harmonização</p>
            </div>
          )}
          {licoes.length > 0 && (
            <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <span class="text-blue-400 text-sm shrink-0">🔵</span>
              <p class="text-blue-300 text-sm"><strong>{licoes.length} lição{licoes.length > 1 ? 'ões' : ''} kármica{licoes.length > 1 ? 's' : ''}</strong> — vibração{licoes.length > 1 ? 'ões' : ''} ausente{licoes.length > 1 ? 's' : ''} que o Nome Social pode introduzir</p>
            </div>
          )}
          {tendencias.length > 0 && (
            <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-purple-500/10 border border-purple-500/20">
              <span class="text-purple-400 text-sm shrink-0">🟣</span>
              <p class="text-purple-300 text-sm"><strong>{tendencias.length} tendência{tendencias.length > 1 ? 's' : ''} oculta{tendencias.length > 1 ? 's' : ''}</strong> — excessos que a redistribuição vibracional pode reequilibrar</p>
            </div>
          )}
          {temPermanentes && (
            <div class="flex items-start gap-3 px-3 py-2 rounded-lg bg-gray-500/10 border border-gray-500/20">
