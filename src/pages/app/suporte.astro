---
import AppLayout from '../../layouts/AppLayout.astro';
import { FAQSection } from '../../frontend/components/landing/FAQSection';
import type { FaqItemProps } from '../../frontend/components/landing/FAQSection';
import { SupportForm } from '../../frontend/components/support/SupportForm';
import { getFaqs } from '../../backend/notion/faqs';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login');
}

let faqItems: FaqItemProps[] = [];
try {
  faqItems = await getFaqs();
} catch (err) {
  console.warn('[suporte] Falha ao carregar FAQs do Notion — usando fallback:', err);
}
---

<AppLayout title="Central de Suporte">
  <div class="max-w-3xl mx-auto space-y-8 mt-4 md:mt-8 pb-16">
    <div>
      <h1 class="font-cinzel text-3xl font-bold text-white mb-2">Central de Suporte</h1>
      <p class="text-gray-400">Encontre respostas ou entre em contato com nossa equipe.</p>
    </div>

    <div class="flex flex-col gap-6">
      {/* Container Principal do Formulário */}
      <SupportForm client:visible />

      {/* Box de Email Fora do Container */}
      <a
        href="mailto:suporte@nomemagnetico.com.br"
        class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 hover:border-[#D4AF37]/40 transition-all duration-300 flex items-center gap-4"
      >
        <div class="text-3xl">✉️</div>
        <div>
          <h3 class="font-cinzel text-lg font-bold text-white mb-1">Email para contato direto</h3>
          <p class="text-gray-400 text-sm">suporte@nomemagnetico.com.br</p>
          <p class="text-gray-600 text-xs mt-1">Resposta em até 24h</p>
        </div>
      </a>
    </div>

    <FAQSection items={faqItems} client:visible />
  </div>
</AppLayout>
