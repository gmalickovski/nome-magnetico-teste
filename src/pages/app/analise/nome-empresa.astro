---
import AppLayout from '../../../layouts/AppLayout.astro';
import { hasActiveSubscription } from '../../../backend/db/subscriptions';
import { createUserClient } from '../../../backend/db/supabase';
import CompanyNameForm from '../../../frontend/components/app/CompanyNameForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const client = createUserClient(Astro.locals.accessToken ?? '');
const { data: profile } = await client.from('profiles').select('role').eq('id', user.id).single();
const isAdmin = profile?.role === 'admin';

const hasAccess = isAdmin || await hasActiveSubscription(user.id, 'nome_empresa');
if (!hasAccess) return Astro.redirect('/comprar?produto=nome_empresa');
---

<AppLayout title="Análise — Nome Empresarial">
  <div class="max-w-2xl mx-auto">
    <a
      href="/app"
      class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-gray-400 transition-colors hover:text-[#D4AF37]"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Voltar para meus produtos
    </a>

    <div class="mb-8">
      <p class="mb-3 font-inter text-xs font-bold uppercase tracking-[0.28em] text-[#D4AF37]">Nome Empresarial</p>
      <h1 class="font-cinzel text-3xl font-bold text-[#e5e2e1] mb-3">Análise de Nome Empresarial</h1>
      <p class="text-gray-400 leading-relaxed">
        Avalie nomes de empresa pela compatibilidade com o destino do fundador, presença de bloqueios,
        força de posicionamento e score final para escolher com mais segurança.
      </p>
    </div>

    <CompanyNameForm client:load />
  </div>
</AppLayout>
