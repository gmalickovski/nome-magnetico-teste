---
import AppLayout from '../../../layouts/AppLayout.astro';
import { hasActiveSubscription } from '../../../backend/db/subscriptions';
import { createUserClient } from '../../../backend/db/supabase';
import CompanyNameForm from '../../../frontend/components/app/CompanyNameForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const client = createUserClient(Astro.locals.accessToken ?? '');
const { data: profile } = await client.from('profiles').select('role').eq('id', user.id).single();
const isAdmin = profile?.role === 'admin';

const hasAccess = isAdmin || await hasActiveSubscription(user.id, 'nome_empresa');
if (!hasAccess) return Astro.redirect('/comprar?produto=nome_empresa');
---

<AppLayout title="Análise — Nome Empresarial">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="font-cinzel text-3xl font-bold text-white mb-2">Análise de Nome Empresarial</h1>
      <p class="text-gray-400">Avalie nomes de empresa pela compatibilidade com o destino do fundador e da empresa.</p>
    </div>

    <CompanyNameForm client:load />
  </div>
</AppLayout>
