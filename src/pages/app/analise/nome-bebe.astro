---
import AppLayout from '../../../layouts/AppLayout.astro';
import { hasActiveSubscription } from '../../../backend/db/subscriptions';
import BabyNameForm from '../../../frontend/components/app/BabyNameForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const hasAccess = await hasActiveSubscription(user.id, 'nome_bebe');
if (!hasAccess) return Astro.redirect('/comprar?produto=nome_bebe');
---

<AppLayout title="Análise — Nome de Bebê">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="font-cinzel text-3xl font-bold text-white mb-2">Análise de Nome de Bebê</h1>
      <p class="text-gray-400">Encontre o nome ideal para seu filho — sem bloqueios e alinhado ao destino da família.</p>
    </div>

    <BabyNameForm client:load />
  </div>
</AppLayout>
