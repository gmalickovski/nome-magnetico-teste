---
import AppLayout from '../../../layouts/AppLayout.astro';
import { hasActiveSubscription } from '../../../backend/db/subscriptions';
import { createUserClient } from '../../../backend/db/supabase';
import SocialNameForm from '../../../frontend/components/app/SocialNameForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const client = createUserClient(Astro.locals.accessToken ?? '');
const { data: profile } = await client
  .from('profiles')
  .select('birth_name, birth_date, role')
  .eq('id', user.id)
  .single();

const isAdmin = profile?.role === 'admin';
const hasAccess = isAdmin || await hasActiveSubscription(user.id, 'nome_social');
if (!hasAccess) return Astro.redirect('/comprar?produto=nome_social');

function dbDateToInput(dbDate: string | null): string {
  if (!dbDate) return '';
  const parts = dbDate.split('-');
  if (parts.length !== 3) return '';
  return `${parts[2]}/${parts[1]}/${parts[0]}`;
}

const nomeInicial = profile?.birth_name ?? '';
const dataInicial = dbDateToInput(profile?.birth_date ?? '');
---

<AppLayout title="Análise — Nome Social">
  <div class="mx-auto max-w-5xl space-y-10 pb-16">
    <a
      href="/app"
      class="inline-flex items-center gap-2 text-sm font-semibold text-gray-400 transition-colors hover:text-[#D4AF37]"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Voltar para meus produtos
    </a>

    <header class="space-y-5">
      <p class="font-inter text-xs font-bold uppercase tracking-[0.28em] text-[#D4AF37]">
        Harmonização de assinatura
      </p>
      <div class="max-w-4xl">
        <h1 class="font-cinzel text-3xl font-bold leading-tight text-[#e5e2e1] md:text-5xl">
          Análise de Nome Social
        </h1>
        <p class="mt-5 text-base leading-relaxed text-gray-400 md:text-lg">
          Informe seu nome civil completo, data de nascimento e o contexto em que deseja se apresentar.
          O sistema compara nomes candidatos, calcula os 4 triângulos cabalísticos, identifica bloqueios,
          avalia a compatibilidade com seu Destino e ordena as opções por score.
        </p>
      </div>
      <div class="grid gap-4 text-sm text-gray-400 sm:grid-cols-3">
        <div class="rounded-2xl bg-white/[0.04] px-4 py-3 ring-1 ring-white/10">
          <span class="block font-bold text-[#D4AF37]">1. Base fixa</span>
          Nome de nascimento e data definem o mapa original.
        </div>
        <div class="rounded-2xl bg-white/[0.04] px-4 py-3 ring-1 ring-white/10">
          <span class="block font-bold text-[#D4AF37]">2. Candidatos</span>
          Você informa opções ou deixa o sistema sugerir variações.
        </div>
        <div class="rounded-2xl bg-white/[0.04] px-4 py-3 ring-1 ring-white/10">
          <span class="block font-bold text-[#D4AF37]">3. Ranking</span>
          O melhor nome prioriza score alto e baixa descaracterização.
        </div>
      </div>
    </header>

    <div class="pt-4 md:pt-6">
      <SocialNameForm
        client:load
        nomeInicial={nomeInicial}
        dataInicial={dataInicial}
      />
    </div>
  </div>
</AppLayout>
