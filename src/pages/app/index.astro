---
import AppLayout from '../../layouts/AppLayout.astro';
import { hasActiveSubscription, hasAnySubscription } from '../../backend/db/subscriptions';
import { hasUsedFreeAnalysis } from '../../backend/db/analyses';
import { createUserClient } from '../../backend/db/supabase';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

// Desabilitar cache para o botão voltar do navegador não repuxar dados velhos
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');

import FreeUsedModal from '../../frontend/components/app/FreeUsedModal';
import { getHqPricesAndPromo } from '../../backend/payments/prices';
import type { PriceInfo, ActivePromotion } from '../../backend/payments/prices';

// Verifica se tem modal
const showFreeUsedModal = Astro.url.searchParams.get('free_used') === 'true';

// Verificar admin e dados
let isAdmin = false;
let profileData: any = null;
try {
  const client = createUserClient(Astro.locals.accessToken ?? '');
  const { data: profile } = await client
    .from('profiles').select('nome, role, birth_name, birth_date').eq('id', user.id).single();
  isAdmin = profile?.role === 'admin';
  profileData = profile;
} catch {}

// Admin: acesso total sem verificar subscriptions
const [hasNomeSocial, hasNomeBebe, hasNomeEmpresa] = isAdmin
  ? [true, true, true]
  : await Promise.all([
      hasActiveSubscription(user.id, 'nome_social'),
      hasActiveSubscription(user.id, 'nome_bebe'),
      hasActiveSubscription(user.id, 'nome_empresa'),
    ]);

const hasAnyAccess = hasNomeSocial || hasNomeBebe || hasNomeEmpresa;

// Detectar estado expirado (já comprou antes, mas nenhuma ativa)
const isExpired = !isAdmin && !hasAnyAccess && await hasAnySubscription(user.id);

// Card Análise Gratuita:
// - Admins: sempre visível (para testes, sem restrição)
// - Usuários comuns: apenas se não tiver acesso ativo E ainda não usou
const mostrarCardGratuito = isAdmin || (!hasAnyAccess && !(await hasUsedFreeAnalysis(user.id)));

const products = [
  {
    id: 'nome_social',
    icon: '✨',
    name: 'Nome Social',
    description: 'Análise pessoal com 4 triângulos, lições kármics e sugestões de nome.',
    href: '/app/analise/nome-social',
    hasAccess: hasNomeSocial,
  },
  {
    id: 'nome_bebe',
    icon: '👶',
    name: 'Nome de Bebê',
    description: 'Encontre o nome ideal para seu filho com compatibilidade familiar.',
    href: '/app/analise/nome-bebe',
    hasAccess: hasNomeBebe,
  },
  {
    id: 'nome_empresa',
    icon: '🏢',
    name: 'Nome Empresarial',
    description: 'Avalie nomes de empresa alinhados ao destino do fundador.',
    href: '/app/analise/nome-empresa',
    hasAccess: hasNomeEmpresa,
  },
];
---

<AppLayout title="Meu Painel">
  <div class="space-y-8">
    <!-- Boas-vindas -->
    <div>
      <h1 class="font-cinzel text-3xl font-bold text-white mb-1">
        Bem-vindo, {profileData?.nome ? profileData.nome.split(' ')[0] : 'Iniciante'}!
      </h1>
      <p class="text-gray-400">{isAdmin ? 'Acesso Administrativo Habilitado' : 'Acesse seus produtos e siga a sua jornada.'}</p>
    </div>

    <!-- Banner: Expirado -->
    {isExpired && (
      <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="font-cinzel text-lg font-bold text-red-400 mb-1">
            Seu acesso expirou
          </h3>
          <p class="text-gray-400 text-sm">Renove para continuar realizando análises numerológicas completas.</p>
        </div>
        <a
          href="/comprar"
          class="flex-shrink-0 bg-[#D4AF37] text-[#1A1A1A] font-medium px-6 py-2.5 rounded-lg hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        >
          Renovar Acesso
        </a>
      </div>
    )}

    <!-- Banner: Novo usuário (nunca comprou) -->
    {!isAdmin && !hasAnyAccess && !isExpired && (
      <div class="bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="font-cinzel text-lg font-bold text-[#D4AF37] mb-1">
            Comece sua jornada numerológica
          </h3>
          <p class="text-gray-400 text-sm">Adquira um dos produtos para realizar sua análise cabalística completa.</p>
        </div>
        <a
          href="/comprar"
          class="flex-shrink-0 bg-[#D4AF37] text-[#1A1A1A] font-medium px-6 py-2.5 rounded-lg hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        >
          Ver Todos os Produtos
        </a>
      </div>
    )}

    <!-- Card: Análise Gratuita (aparece só uma vez, antes de adquirir qualquer produto) -->
    {mostrarCardGratuito && (
      <div>
        <h2 class="font-cinzel text-xl font-bold text-gray-100 mb-4">Disponível para Você</h2>
        <a
          href="/app/analise-gratuita"
          class="block group bg-gradient-to-br from-[#d7c6ff]/8 to-[#bea5ff]/5 border border-[#d7c6ff]/20 rounded-2xl p-6 hover:border-[#d7c6ff]/40 hover:from-[#d7c6ff]/12 hover:to-[#bea5ff]/8 transition-all duration-300 hover:scale-[1.01] cursor-pointer"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl">🔮</span>
                <span class="text-xs bg-[#d7c6ff]/15 text-[#d7c6ff] px-3 py-1 rounded-full border border-[#d7c6ff]/20 font-semibold uppercase tracking-wider">
                  Grátis
                </span>
              </div>
              <h3 class="font-cinzel text-xl font-bold text-white mb-2 group-hover:text-[#d7c6ff] transition-colors">
                Análise do Seu Nome de Nascimento
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed mb-4">
                Descubra os bloqueios energéticos, lições kármicas e tendências ocultas do seu nome atual. Análise completa com os 4 triângulos numerológicos.
              </p>
              <div class="flex items-center gap-2 text-[#d7c6ff] text-sm font-medium">
                <span>Analisar meu nome agora</span>
                <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
              </div>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-[#d7c6ff]/10">
            <p class="text-xs text-gray-500">
              Disponível uma única vez · Relatório completo com PDF · Acesso permanente em Minhas Análises
            </p>
          </div>
        </a>
      </div>
    )}

    <!-- Produtos -->
    <div>
      <h2 class="font-cinzel text-xl font-bold text-gray-100 mb-4">Seus Produtos</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {products.map(product => {
          return product.hasAccess ? (
            <a
              data-product-id={product.id}
              href={product.href}
              class="product-card block group bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 hover:border-[#D4AF37]/40 hover:bg-white/8 transition-all duration-300 hover:scale-[1.02] cursor-pointer"
            >
              <div class="text-4xl mb-4">{product.icon}</div>
              <h3 class="font-cinzel text-xl font-bold text-white mb-2 group-hover:text-[#D4AF37] transition-colors">
                {product.name}
              </h3>
              <p class="text-gray-400 text-sm">{product.description}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-[#D4AF37] text-sm font-medium">Iniciar análise →</span>
                {isAdmin && (
                  <span class="text-xs bg-purple-500/20 border border-purple-500/30 text-purple-400 px-2 py-0.5 rounded-full">Admin</span>
                )}
              </div>
            </a>
          ) : isExpired ? (
            <a href={'/comprar?produto=' + product.id} class="block group bg-white/3 border border-red-500/10 hover:border-red-500/30 rounded-2xl p-6 relative transition-all duration-300 hover:scale-[1.02] cursor-pointer">
              <div class="absolute top-3 right-3 text-gray-600 text-lg">🔒</div>
              <div class="text-4xl mb-4 opacity-40 group-hover:opacity-60 transition-opacity">{product.icon}</div>
              <h3 class="font-cinzel text-xl font-bold text-gray-500 mb-2 group-hover:text-red-400 transition-colors">
                {product.name}
              </h3>
              <p class="text-gray-600 text-sm">{product.description}</p>
              <div class="mt-4 inline-block bg-red-500/10 border border-red-500/30 text-red-400 text-sm font-bold px-4 py-2 rounded-lg group-hover:bg-red-500/20 transition-all duration-300">
                Renovar
              </div>
            </a>
          ) : (
            <a href={'/comprar?produto=' + product.id} class="block group bg-white/3 border border-white/10 hover:border-[#D4AF37]/30 rounded-2xl p-6 relative transition-all duration-300 hover:scale-[1.02] cursor-pointer">
              <div class="absolute top-3 right-3 text-gray-600 text-lg">🔒</div>
              <div class="text-4xl mb-4 opacity-50 group-hover:opacity-80 transition-opacity">{product.icon}</div>
              <h3 class="font-cinzel text-xl font-bold text-gray-500 mb-2 group-hover:text-[#D4AF37] transition-colors">
                {product.name}
              </h3>
              <p class="text-gray-600 text-sm">{product.description}</p>
              <p class="text-gray-500 text-xs mt-2 group-hover:text-gray-400 transition-colors">Ainda não adquirido</p>
              <div class="mt-4 inline-block bg-[#D4AF37]/10 border border-[#D4AF37]/30 text-[#D4AF37] text-sm font-bold px-4 py-2 rounded-lg group-hover:bg-[#D4AF37]/20 transition-all duration-300">
                Adquirir
              </div>
            </a>
          )
        })}
      </div>
    </div>

  </div>
  
  {showFreeUsedModal && <FreeUsedModal client:only="react" />}

</AppLayout>
