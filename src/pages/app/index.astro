---
import AppLayout from '../../layouts/AppLayout.astro';
import { supabase } from '../../backend/db/supabase';
import { getUserAnalyses } from '../../backend/db/analyses';
import { hasActiveSubscription } from '../../backend/db/subscriptions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const [analyses, hasAccess] = await Promise.all([
  getUserAnalyses(user.id, 'nome_magnetico'),
  hasActiveSubscription(user.id, 'nome_magnetico'),
]);

const recentAnalyses = analyses.slice(0, 5);
---

<AppLayout title="Meu Painel">
  <div class="space-y-8">
    <!-- Boas-vindas -->
    <div>
      <h1 class="font-cinzel text-3xl font-bold text-white mb-1">
        Bem-vindo de volta
      </h1>
      <p class="text-gray-400">{user.email}</p>
    </div>

    {!hasAccess && (
      <div class="bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="font-cinzel text-lg font-bold text-[#D4AF37] mb-1">
            Você não possui acesso ativo
          </h3>
          <p class="text-gray-400 text-sm">Adquira o Nome Magnético para realizar sua análise completa.</p>
        </div>
        <a
          href="/comprar"
          class="flex-shrink-0 bg-[#D4AF37] text-black font-bold px-6 py-3 rounded-xl hover:bg-yellow-300 transition-all duration-300 hover:scale-105"
        >
          Ver Planos
        </a>
      </div>
    )}

    {hasAccess && (
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Nova análise -->
        <a
          href="/app/questionario"
          class="group bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 hover:border-[#D4AF37]/40 hover:bg-white/8 transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-4xl mb-4">✨</div>
          <h3 class="font-cinzel text-xl font-bold text-white mb-2 group-hover:text-[#D4AF37] transition-colors">
            Nova Análise
          </h3>
          <p class="text-gray-400 text-sm">
            Inicie uma nova análise do seu nome ou de outro nome.
          </p>
        </a>

        <!-- Histórico -->
        <a
          href="#historico"
          class="group bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-white/20 transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-4xl mb-4">📋</div>
          <h3 class="font-cinzel text-xl font-bold text-white mb-2">
            Histórico
          </h3>
          <p class="text-gray-400 text-sm">
            {analyses.length > 0
              ? `${analyses.length} análise(s) realizadas`
              : 'Nenhuma análise ainda'}
          </p>
        </a>
      </div>
    )}

    <!-- Histórico de análises -->
    {recentAnalyses.length > 0 && (
      <div id="historico">
        <h2 class="font-cinzel text-xl font-bold text-gray-100 mb-4">Análises Recentes</h2>
        <div class="space-y-3">
          {recentAnalyses.map(analysis => (
            <a
              href={`/app/resultado/${analysis.id}`}
              class="flex items-center justify-between bg-white/5 border border-white/10 rounded-xl px-5 py-4 hover:border-[#D4AF37]/30 hover:bg-white/8 transition-all duration-200"
            >
              <div>
                <p class="text-gray-200 font-medium">{analysis.nome_completo}</p>
                <p class="text-gray-500 text-sm">
                  {new Date(analysis.created_at).toLocaleDateString('pt-BR')}
                </p>
              </div>
              <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${
                analysis.status === 'complete'
                  ? 'bg-emerald-500/20 text-emerald-400'
                  : analysis.status === 'error'
                  ? 'bg-red-500/20 text-red-400'
                  : 'bg-yellow-500/20 text-yellow-400'
              }`}>
                {analysis.status === 'complete' ? 'Completa' :
                 analysis.status === 'error' ? 'Erro' :
                 analysis.status === 'processing' ? 'Processando' : 'Pendente'}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</AppLayout>
