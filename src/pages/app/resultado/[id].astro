---
import ResultadoLayout from '../../../layouts/ResultadoLayout.astro';
import { getAnalysis, getMagneticNames } from '../../../backend/db/analyses';
import { supabase } from '../../../backend/db/supabase';
import { getArcano } from '../../../backend/numerology/arcanos';
import { getArquetipo } from '../../../backend/numerology/archetypes';
import ScoreDisplay from '../../../frontend/components/app/ScoreDisplay';
import { formatAnalysisText } from '../../../utils/textFormatter';
import { marked } from 'marked';
import NomeSocialResultado from '../../../frontend/components/app/resultado/NomeSocialResultado.astro';
import NomeAtualResultado from '../../../frontend/components/app/resultado/NomeAtualResultado.astro';
import NomeBebResultado from '../../../frontend/components/app/resultado/NomeBebResultado.astro';
import NomeEmpresaResultado from '../../../frontend/components/app/resultado/NomeEmpresaResultado.astro';
import { hasActiveSubscription } from '../../../backend/db/subscriptions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const { id } = Astro.params;
if (!id) return Astro.redirect('/app');

const [analysis, magneticNames] = await Promise.all([
  getAnalysis(id),
  getMagneticNames(id),
]);

if (!analysis || analysis.user_id !== user.id) {
  return Astro.redirect('/app');
}

// ── Status ──────────────────────────────────────────────────────────
const isProcessing = analysis.status === 'processing' || analysis.status === 'pending';
const isError = analysis.status === 'error';
const errorMessage = (analysis as any).error_message || 'Ocorreu um erro inesperado.';

// ── Tipos locais ─────────────────────────────────────────────────────
type TData = {
  tipo: string;
  linhas: number[][];
  arcanoRegente: number | null;
  arcanosDoMinantes: number[];
  sequenciasNegativas: string[];
};
type BloqueioCard = {
  codigo: string;
  titulo: string;
  descricao: string;
  aspectoSaude?: string;
  triangulos?: string[];
  antidoto?: string;
};
type LicaoCard   = { numero: number; titulo: string; descricao: string; comoTrabalhar: string };
type TendenciaCard = { numero: number; frequencia: number; titulo: string; descricao: string; comoEquilibrar: string };
type DebitoCard  = { numero: number; titulo: string; descricao: string; fontes?: string[]; fixo?: boolean };

// ── Dados dos triângulos ─────────────────────────────────────────────
const tVida    = (analysis as any).triangulo_vida    as TData | null;
const tPessoal = (analysis as any).triangulo_pessoal as TData | null;
const tSocial  = (analysis as any).triangulo_social  as TData | null;
const tDestino = (analysis as any).triangulo_destino as TData | null;
const hasTriangulos = !!(tVida && tPessoal && tSocial && tDestino);

// ── Arrays de dados ──────────────────────────────────────────────────
const bloqueios     = (Array.isArray(analysis.bloqueios) ? analysis.bloqueios : []) as BloqueioCard[];
const licoesRaw     = (analysis as any).licoes_carmicas as LicaoCard[] | null;
const tendenciasRaw = (analysis as any).tendencias_ocultas as TendenciaCard[] | null;
const debitosRaw    = (analysis as any).debitos_carmicos as DebitoCard[] | null;

const freqData = (analysis as any).frequencias_numeros as any;
const frequenciasRaw: Record<number, number> | null =
  freqData?.frequencias
    ?? (freqData && !freqData?.ranking && !freqData?.nomesCandidatos ? freqData as Record<number, number> : null);
const rankingBebe    = (analysis.product_type === 'nome_bebe' ? freqData?.ranking : null) ?? null;
const rankingEmpresa = (analysis.product_type === 'nome_empresa' ? freqData : null) as any;
const rankingSocial  = (analysis.product_type === 'nome_social' && freqData?.ranking) ? freqData.ranking : null;

// ── Helpers de produto (declarados cedo pois são usados abaixo) ──────
const isAnaliseGratuita = analysis.product_type === 'analise_gratuita';
const isNomeSocial  = analysis.product_type === 'nome_social';
const isNomeBebe    = analysis.product_type === 'nome_bebe';
const isNomeEmpresa = analysis.product_type === 'nome_empresa';
const isFree        = isAnaliseGratuita || (analysis as any).is_free === true;

const { data: profile } = await supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .maybeSingle();
const isAdmin = profile?.role === 'admin';
const canGenerateSocialCandidateReports = isAdmin || await hasActiveSubscription(user.id, 'nome_social');

if (isFree) {
  return Astro.redirect('/app?gen_free_pdf=1');
}

// ── Arcano regente ───────────────────────────────────────────────────
const arcanoRawNum = (analysis as any).arcano_regente as number | null;
const arcanoData = arcanoRawNum ? getArcano(arcanoRawNum) : null;

// ── Arquétipo (derivado do número de Expressão já calculado) ─────────
const expressaoParaArquetipo =
  isNomeBebe    && rankingBebe?.melhorNome?.expressao    ? rankingBebe.melhorNome.expressao
  : isNomeSocial  && rankingSocial?.melhorNome?.expressao ? rankingSocial.melhorNome.expressao
  : isNomeEmpresa && freqData?.melhorNome?.expressao      ? freqData.melhorNome.expressao
  : analysis.numero_expressao;
const arquetipoData = expressaoParaArquetipo ? getArquetipo(expressaoParaArquetipo) : null;

// ── Texto da IA ──────────────────────────────────────────────────────
const analiseHtmlRaw = analysis.analise_texto
  ? String(await marked(formatAnalysisText(analysis.analise_texto))).replace(/\*\*/g, '')
  : null;
const analiseHtml = analiseHtmlRaw && isFree
  ? analiseHtmlRaw
      .replace(/^<h1>[^<]*<\/h1>\s*/i, '')
      .replace(/<h[1-6][^>]*>[^<]*Manual de Assinatura[^<]*<\/h[1-6]>[\s\S]*?(?=<h[1-6]|$)/i, '')
  : analiseHtmlRaw;

// ── Score geral ──────────────────────────────────────────────────────
const scoreGeral = (analysis as any).score as number | null;

// ── Nome exibido ─────────────────────────────────────────────────────
const nomeExibido: string =
  (isNomeBebe    && rankingBebe?.melhorNome?.nomeCompleto)    ? rankingBebe.melhorNome.nomeCompleto
  : (isNomeSocial  && rankingSocial?.melhorNome?.nomeCompleto) ? rankingSocial.melhorNome.nomeCompleto
  : (isNomeEmpresa && rankingEmpresa?.melhorNome?.nomeEmpresa) ? rankingEmpresa.melhorNome.nomeEmpresa
  : analysis.nome_completo;

const primeiroNome = nomeExibido.split(' ')[0];

// ── Nomes magnéticos ─────────────────────────────────────────────────
type MagneticCard = typeof magneticNames[number] & { isTop: boolean };
const topNames: MagneticCard[] = magneticNames.slice(0, 3).map((n, i) => ({ ...n, isTop: i === 0 }));

// (isNomeSocial / isNomeBebe / isNomeEmpresa declarados antes, ver acima)

// ── Data formatada ───────────────────────────────────────────────────
const dataFormatada = analysis.data_nascimento
  ? new Date(analysis.data_nascimento).toLocaleDateString('pt-BR', { timeZone: 'UTC', day: '2-digit', month: 'long', year: 'numeric' })
  : null;

// ── 5 Números com ícones e rótulos ───────────────────────────────────
const cinco_numeros = [
  { label: 'Expressão',   sublabel: 'O Dom', value: analysis.numero_expressao,    icon: '✦' },
  { label: 'Destino',     sublabel: 'O Chamado', value: analysis.numero_destino,  icon: '◈' },
  { label: 'Motivação',   sublabel: 'A Alma', value: analysis.numero_motivacao,   icon: '♡' },
  { label: 'Impressão',   sublabel: 'As Consoantes', value: analysis.numero_impressao, icon: '◎' },
  { label: 'Missão',      sublabel: 'A Vocação', value: analysis.numero_missao, icon: '◇' },
];

// ── 5 Números empresa (lidos do rankingEmpresa, não do analysis) ──────
const cinco_numeros_empresa = isNomeEmpresa && rankingEmpresa?.melhorNome ? [
  { label: 'Expressão',  sublabel: 'O Dom',       value: rankingEmpresa.melhorNome.expressao,  icon: '✦' },
  { label: 'Destino',    sublabel: 'O Chamado',    value: rankingEmpresa.destinoSocio,          icon: '◈' },
  { label: 'Motivação',  sublabel: 'A Alma',       value: rankingEmpresa.melhorNome.motivacao,  icon: '♡' },
  { label: 'Missão',     sublabel: 'O Propósito',  value: rankingEmpresa.melhorNome.missao,     icon: '◎' },
  { label: 'Impressão',  sublabel: 'As Consoantes', value: rankingEmpresa.melhorNome.impressao,  icon: '◉' },
] : cinco_numeros;
---

<ResultadoLayout title="Resultado da Análise" analysisId={analysis.id} productType={analysis.product_type ?? 'nome_social'} isFree={isFree} showActions={analysis.status === 'complete'}>
  <div>

    {/* ── PROCESSANDO ─────────────────────────────────────────────── */}
    {isProcessing && (
      <div class="min-h-[50vh] flex flex-col items-center justify-center px-4">
        
        <div id="processing-state" class="w-full max-w-lg rounded-2xl bg-[#111111] p-8" style="border: 1px solid rgba(212,175,55,0.15); box-shadow: 0 20px 50px rgba(0,0,0,0.6);">
          <div class="flex items-center gap-6">
            <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center">
              <svg class="w-12 h-12 text-[#D4AF37] animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-20" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-[#e5e2e1] text-lg sm:text-xl font-bold leading-tight mb-2">
                Analisando seus dados…
              </h3>
              <p class="text-gray-400 text-sm sm:text-base leading-relaxed">
                Calculando triângulos e bloqueios numéricos <span id="poll-counter-text" class="text-gray-500 font-medium ml-1">(0s)</span>
              </p>
            </div>
          </div>
        </div>

        <div id="timeout-state" class="hidden w-full max-w-lg rounded-2xl bg-[#111111] border border-amber-500/20 p-8 text-center" style="box-shadow: 0 20px 50px rgba(0,0,0,0.6);">
          <div class="text-4xl mb-4">⏱</div>
          <h3 class="font-cinzel text-xl font-bold text-amber-400 mb-3">A análise está demorando mais que o esperado</h3>
          <p class="text-gray-400 text-sm sm:text-base leading-relaxed mb-6">O processamento pode estar lento no momento. Aguarde mais alguns minutos e recarregue a página, ou relate o problema caso persista.</p>
          <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
            <button onclick="window.location.reload()" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#D4AF37] text-black font-semibold px-6 py-3 rounded-full hover:bg-[#f2ca50] transition-all">
              Verificar agora
            </button>
            <a href="/suporte" target="_blank" class="text-amber-400 hover:text-amber-300 text-sm underline underline-offset-4">Relatar atraso no Suporte</a>
          </div>
        </div>

        <script define:vars={{ analysisId: id }}>
          (function () {
            const MAX_POLLS = 84; // 7 minutos (84 × 5s)
            const key = 'poll_' + analysisId;
            const count = parseInt(sessionStorage.getItem(key) || '0', 10);

            if (count >= MAX_POLLS) {
              sessionStorage.removeItem(key);
              document.getElementById('processing-state')?.classList.add('hidden');
              document.getElementById('timeout-state')?.classList.remove('hidden');
              return;
            }

            sessionStorage.setItem(key, String(count + 1));
            const baseSec = count * 5;
            const ctrEl = document.getElementById('poll-counter-text');

            function fmt(sec) {
              const m = Math.floor(sec / 60);
              return sec >= 60 ? m + 'min ' + (sec % 60) + 's' : sec + 's';
            }

            let localSec = 0;
            if (ctrEl) ctrEl.textContent = '(' + fmt(baseSec) + ')';

            const liveInterval = setInterval(() => {
              localSec++;
              if (ctrEl) ctrEl.textContent = '(' + fmt(baseSec + localSec) + ')';
            }, 1000);

            setTimeout(() => {
              clearInterval(liveInterval);
              sessionStorage.setItem(key, String(count + 1));
              window.location.reload();
            }, 5000);
          })();
        </script>
      </div>
    )}

    {/* ── ERRO ────────────────────────────────────────────────────── */}
    {isError && (
      <div class="rounded-2xl bg-red-500/10 p-8 text-center">
        <h3 class="font-cinzel text-xl font-bold text-red-400 mb-2">Erro na Análise</h3>
        <p class="text-gray-400 mb-4">{errorMessage}</p>
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <a href={isFree ? "/app/analise-gratuita" : `/app/analise/${analysis.product_type?.replace('_', '-') ?? 'nome-social'}`} class="inline-flex items-center gap-2 bg-[#D4AF37] text-[#1A1A1A] font-medium px-6 py-2.5 rounded-full hover:bg-[#f2ca50] transition-all duration-300">
            Tentar Novamente
          </a>
          <a href="/suporte" target="_blank" class="text-red-400 hover:text-red-300 text-sm underline underline-offset-4">
            Relatar erro no Suporte
          </a>
        </div>
      </div>
    )}

    {/* ══════════════════════════════════════════════════════════════
        CONTEÚDO COMPLETO (status = complete)
    ══════════════════════════════════════════════════════════════ */}
    {!isProcessing && !isError && (
      <>

        {/* ── SEÇÃO 1: HEADER / CERTIFICADO (oculto para nome_social) ── */}
        {!isNomeSocial && (
        <section class="rounded-2xl bg-white/5 p-6 md:p-8 mb-6">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
            <div class="flex-1 min-w-0">
              <p class="font-cinzel text-xs uppercase tracking-[0.2em] text-[#76746a] mb-2">
                {isFree      ? 'Análise do Nome de Nascimento — Diagnóstico Cabalístico' :
                 isNomeSocial ? 'Análise de Nome Social — Certificado Cabalístico' :
                 isNomeBebe   ? 'Análise de Nome de Bebê — O Portal do Nascimento' :
                                'Análise de Nome de Empresa — Relatório Estratégico'}
              </p>
              <h1 class="font-cinzel text-3xl md:text-4xl font-bold text-white mb-1">{nomeExibido}</h1>
              {dataFormatada && (
                <p class="text-gray-500 text-xs mt-1">{dataFormatada}</p>
              )}
            </div>
            <div class="shrink-0 md:w-48">
              {scoreGeral !== null && scoreGeral !== undefined ? (
                <ScoreDisplay client:load score={scoreGeral} size="lg" />
              ) : (
                <div class="px-3 py-1.5 rounded-full text-sm font-medium bg-emerald-500/20 text-emerald-400 inline-block">
                  ✓ Concluída
                </div>
              )}
            </div>
            {isNomeBebe && (
              <div class="shrink-0 rounded-2xl bg-black/20 border border-[#D4AF37]/20 p-4 flex flex-col items-center justify-center text-center gap-1 min-w-[110px]">
                <span class="font-cinzel text-[10px] uppercase tracking-[0.12em] text-[#76746a]">Destino do Bebê</span>
                <span class="font-cinzel text-4xl font-bold text-[#D4AF37] leading-none">{analysis.numero_destino ?? '?'}</span>
                {arcanoData && <p class="text-xs text-[#c084fc] mt-0.5">{arcanoData.palavraChave}</p>}
              </div>
            )}
          </div>
          {isNomeBebe && rankingBebe?.melhorNome && (
            <div class="mt-5 pt-5 border-t border-white/10 flex flex-wrap gap-x-6 gap-y-2">
              <div class="flex items-center gap-1.5">
                <span class="text-[10px] font-cinzel uppercase tracking-wider text-[#76746a]">Expressão</span>
                <span class="font-cinzel text-lg font-bold text-[#D4AF37]/80">{(rankingBebe.melhorNome as any).expressao}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-[10px] font-cinzel uppercase tracking-wider text-[#76746a]">Motivação</span>
                <span class="font-cinzel text-lg font-bold text-[#D4AF37]/80">{(rankingBebe.melhorNome as any).motivacao}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-[10px] font-cinzel uppercase tracking-wider text-[#76746a]">Missão</span>
                <span class="font-cinzel text-lg font-bold text-[#D4AF37]/80">{(rankingBebe.melhorNome as any).missao}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-[10px] font-cinzel uppercase tracking-wider text-[#76746a]">Impressão</span>
                <span class="font-cinzel text-lg font-bold text-[#D4AF37]/80">{(rankingBebe.melhorNome as any).impressao}</span>
              </div>
            </div>
          )}
        </section>
        )}

        {/* ══════════════════════════════════════════════════
            NOME ATUAL (análise gratuita) — ESTRUTURA SEPARADA
        ══════════════════════════════════════════════════ */}
        {(isAnaliseGratuita || (isNomeSocial && isFree)) && (
          <NomeAtualResultado
            analysis={analysis}
            nomeExibido={nomeExibido}
            cincoNumeros={cinco_numeros}
            expressao={analysis.numero_expressao}
            arquetipoData={arquetipoData}
            tVida={tVida}
            tPessoal={tPessoal}
            tSocial={tSocial}
            tDestino={tDestino}
            hasTriangulos={hasTriangulos}
            bloqueios={bloqueios}
            arcanoData={arcanoData}
            licoesRaw={licoesRaw}
            debitosRaw={debitosRaw}
            tendenciasRaw={tendenciasRaw}
            frequenciasRaw={frequenciasRaw}
            analiseHtml={analiseHtml}
          />
        )}

        {/* ══════════════════════════════════════════════════
            NOME SOCIAL — ESTRUTURA PRINCIPAL (pago)
        ══════════════════════════════════════════════════ */}
        {isNomeSocial && !isFree && (
          <NomeSocialResultado
            analysis={analysis}
            nomeExibido={nomeExibido}
            cincoNumeros={cinco_numeros}
            expressao={analysis.numero_expressao}
            arquetipoData={arquetipoData}
            tVida={tVida}
            tPessoal={tPessoal}
            tSocial={tSocial}
            tDestino={tDestino}
            hasTriangulos={hasTriangulos}
            bloqueios={bloqueios}
            arcanoData={arcanoData}
            licoesRaw={licoesRaw}
            debitosRaw={debitosRaw}
            tendenciasRaw={tendenciasRaw}
            frequenciasRaw={frequenciasRaw}
            analiseHtml={analiseHtml}
            topNames={topNames}
            rankingSocial={rankingSocial}
            canGenerateCandidateReports={canGenerateSocialCandidateReports}
          />
        )}

        {/* ══════════════════════════════════════════════════
            NOME DO BEBÊ — ESTRUTURA ESPECÍFICA
        ══════════════════════════════════════════════════ */}
        {isNomeBebe && (
          <NomeBebResultado
            analysis={analysis}
            nomeExibido={nomeExibido}
            rankingBebe={rankingBebe}
            arquetipoData={arquetipoData}
            analiseHtml={analiseHtml}
            tVida={tVida}
            tPessoal={tPessoal}
            tSocial={tSocial}
            tDestino={tDestino}
            hasTriangulos={hasTriangulos}
            bloqueios={bloqueios}
          />
        )}

        {/* ══════════════════════════════════════════════════
            NOME EMPRESA — ESTRUTURA ESPECÍFICA
        ══════════════════════════════════════════════════ */}
        {isNomeEmpresa && (
          <NomeEmpresaResultado
            analysis={analysis}
            nomeExibido={nomeExibido}
            cincoNumerosEmpresa={cinco_numeros_empresa}
            arquetipoData={arquetipoData}
            rankingEmpresa={rankingEmpresa}
            tVida={tVida}
            tPessoal={tPessoal}
            tSocial={tSocial}
            tDestino={tDestino}
            hasTriangulos={hasTriangulos}
            bloqueios={bloqueios}
            analiseHtml={analiseHtml}
          />
        )}

      </>
    )}
  </div>
</ResultadoLayout>

<script define:vars={{ analysisId: id, isComplete: !isProcessing && !isError }}>
  // Limpar contador de polling quando a análise estiver completa
  if (isComplete) {
    sessionStorage.removeItem('poll_' + analysisId);
  }
</script>

<script>
  // Variation card clicks — POST to /api/analyze (JSON) then redirect
  document.querySelectorAll<HTMLButtonElement>('[data-variation-nome]').forEach((btn, idx) => {
    btn.addEventListener('click', async () => {
      const nome = btn.dataset.variationNome;
      const data = btn.dataset.variationData;
      if (!nome || !data) return;

      const loader = document.getElementById(`variation-loading-${idx}`);
      if (loader) loader.classList.remove('hidden');
      btn.disabled = true;

      try {
        const res = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nome_completo: nome,
            data_nascimento: data,
            product_type: 'nome_social',
          }),
        });
        const result = await res.json();
        if (result.analysisId) {
          window.location.href = `/app/resultado/${result.analysisId}`;
        } else {
          throw new Error(result.error ?? 'Erro ao iniciar análise');
        }
      } catch (err) {
        if (loader) loader.classList.add('hidden');
        btn.disabled = false;
        alert('Não foi possível iniciar a análise. Tente novamente.');
      }
    });
  });
</script>
