---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { GlossaryHeader } from '../../frontend/components/blog/GlossaryHeader';
import { LandingFooter } from '../../frontend/components/landing/LandingFooter';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: terms } = await supabase
  .from('glossary_terms')
  .select('id, slug, term, related_number, tags')
  .eq('is_published', true)
  .order('term', { ascending: true });

// Agrupa termos por primeira letra (normaliza acentos para a letra base)
const grouped: Record<string, typeof terms> = {};
if (terms) {
  for (const t of terms) {
    const letter = t.term.charAt(0).toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    if (!grouped[letter]) grouped[letter] = [];
    grouped[letter]!.push(t);
  }
}
const letters = Object.keys(grouped).sort();
const hasTerms = terms && terms.length > 0;
---

<BaseLayout
  title="Glossário de Numerologia Cabalística | Nome Magnético"
  description="Dicionário completo de termos da numerologia cabalística: número de expressão, número de destino, triângulos cabalísticos, bloqueios energéticos e muito mais."
  keywords="glossário numerologia cabalística, termos numerologia, o que é número de expressão, o que é número de destino, triângulo cabalístico, bloqueio energético nome"
>
  <link rel="canonical" href="https://nomemagnetico.com.br/glossario" />

  <GlossaryHeader client:load />

  <main class="min-h-screen bg-[#111111] pt-[72px] pb-12 md:pb-20">

    {/* ── HERO ── */}
    <section class="max-w-5xl mx-auto px-4 pt-8 pb-6 md:pt-10 md:pb-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
        <div>
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-2">Referência</p>
          <h1 class="font-cinzel text-2xl sm:text-3xl font-bold text-[#e5e2e1]">Glossário</h1>
          <p class="text-gray-500 text-sm mt-1.5 max-w-lg leading-relaxed">
            Definições dos principais conceitos da numerologia cabalística.
          </p>
        </div>
        {hasTerms && (
          <p class="text-gray-700 text-xs flex-shrink-0">
            {terms!.length} termo{terms!.length !== 1 ? 's' : ''}
          </p>
        )}
      </div>
    </section>

    <div class="max-w-5xl mx-auto px-4">

      {hasTerms ? (
        <div>
          {/* ── GRUPOS POR LETRA ── */}
          {letters.map(letter => (
            <div data-letter-group class="mb-8 sm:mb-10">

              {/* Cabeçalho da letra */}
              <div class="flex items-center gap-3 mb-4">
                <span class="font-cinzel text-2xl sm:text-3xl font-bold text-[#D4AF37]/40 w-8 sm:w-10 flex-shrink-0 select-none leading-none">
                  {letter}
                </span>
                <div class="flex-1 h-px bg-white/6"></div>
              </div>

              {/* Grid de termos */}
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4 pl-0 sm:pl-11 lg:pl-12">
                {grouped[letter]!.map(term => (
                  <a
                    href={`/glossario/${term.slug}`}
                    data-searchable={`${term.term} ${(term.tags ?? []).join(' ')}`}
                    class="group flex items-start justify-between bg-white/3 border border-white/8 rounded-2xl
                           px-4 py-4 sm:px-5
                           hover:border-[#D4AF37]/30 hover:bg-white/5
                           transition-all duration-300 hover:shadow-[0_8px_30px_rgba(212,175,55,0.06)]"
                  >
                    <div class="min-w-0 flex-1">
                      <span class="font-cinzel text-sm font-bold text-[#e5e2e1] leading-snug
                                   group-hover:text-[#D4AF37] transition-colors duration-300 block">
                        {term.term}
                      </span>
                      {term.related_number && (
                        <span class="inline-block mt-1.5 text-[10px] font-medium px-2 py-0.5 rounded-full
                                     bg-[#D4AF37]/10 text-[#D4AF37]/70">
                          Número {term.related_number}
                        </span>
                      )}
                    </div>
                    <span class="text-[#D4AF37]/30 group-hover:text-[#D4AF37] transition-colors ml-3 flex-shrink-0 text-base mt-0.5">
                      →
                    </span>
                  </a>
                ))}
              </div>
            </div>
          ))}

          {/* ── Sem resultados na busca ── */}
          <div id="no-results" class="hidden text-center py-12">
            <p class="font-cinzel text-lg font-bold text-white mb-2">Nenhum termo encontrado</p>
            <p class="text-gray-500 text-sm">
              Tente outro termo ou
              <button
                onclick="window.dispatchEvent(new CustomEvent('glossary:clear'))"
                class="text-[#D4AF37] hover:underline ml-1"
              >
                limpe a busca
              </button>.
            </p>
          </div>
        </div>

      ) : (
        /* ── EMPTY STATE ── */
        <div class="text-center py-16 sm:py-24 max-w-sm sm:max-w-lg mx-auto">
          <div class="relative inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 mb-6 sm:mb-8">
            <div class="absolute inset-0 rounded-full bg-[#D4AF37]/8 blur-xl"></div>
            <span class="font-cinzel text-3xl sm:text-4xl text-[#D4AF37]/25 select-none relative">✦</span>
          </div>
          <h2 class="font-cinzel text-xl sm:text-2xl font-bold text-white mb-3 sm:mb-4">
            Termos chegando em breve
          </h2>
          <p class="text-gray-500 text-sm leading-relaxed mb-8">
            Estamos preparando definições sobre numerologia cabalística, bloqueios energéticos, triângulos e muito mais.
          </p>
          <a href="/analise-gratis"
            class="inline-flex items-center justify-center gap-2 bg-[#D4AF37] text-[#1A1A1A] font-bold px-6 py-3 rounded-full hover:bg-[#f2ca50] transition-all duration-300 shadow-lg shadow-[#D4AF37]/20 text-sm">
            Fazer Análise Gratuita →
          </a>
        </div>
      )}

    </div>
  </main>

  <LandingFooter client:visible />

  <script>
    function filterGlossary(query: string) {
      const q = (query || '').toLowerCase().trim();
      const cards = document.querySelectorAll<HTMLElement>('[data-searchable]');
      let visible = 0;

      cards.forEach(card => {
        const text = (card.getAttribute('data-searchable') || '').toLowerCase();
        const matches = !q || text.includes(q);
        card.style.display = matches ? '' : 'none';
        if (matches) visible++;
      });

      // Oculta grupos de letras quando todos os cards estão escondidos
      document.querySelectorAll<HTMLElement>('[data-letter-group]').forEach(group => {
        const visibleCards = Array.from(
          group.querySelectorAll<HTMLElement>('[data-searchable]')
        ).filter(c => c.style.display !== 'none').length;
        group.style.display = visibleCards === 0 ? 'none' : '';
      });

      const noResults = document.getElementById('no-results');
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    window.addEventListener('glossary:search', (e: Event) => {
      filterGlossary((e as CustomEvent<string>).detail);
    });
    window.addEventListener('glossary:clear', () => filterGlossary(''));
  </script>
</BaseLayout>
