---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { getSupabaseFaqs } from '../backend/faqs/getSupabaseFaqs';
import type { FaqItemProps } from '../frontend/components/landing/FAQSection';
import { FAQSection } from '../frontend/components/landing/FAQSection';
import { getHqPricesAndPromo } from '../backend/payments/prices';
import type { PriceInfo, ActivePromotion } from '../backend/payments/prices';
import { LandingCheckout } from '../frontend/components/purchase/LandingCheckout';

const user = Astro.locals.user;

let faqItems: FaqItemProps[] = [];
try {
  faqItems = await getSupabaseFaqs({ featuredOnly: true });
} catch {
  // fallback silencioso
}

let hqPrices: Record<string, PriceInfo> | undefined;
let promotion: ActivePromotion | null = null;
try {
  const result = await getHqPricesAndPromo();
  hqPrices = result.prices;
  promotion = result.promotion;
} catch (err) {
  console.warn('[nome-social] Falha ao carregar preços do HQ:', err);
}

const FALLBACK_PRICES: Record<string, PriceInfo> = {
  nome_social: { cents: 9700, formatted: 'R$ 97', hasDiscount: false },
};
const prices = hqPrices ?? FALLBACK_PRICES;
function getPrice(id: string) { return prices[id] ?? FALLBACK_PRICES[id]; }

const schemaProduct = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Nome Social — Harmonização de Assinatura',
  description: 'Harmonização de assinatura pelo Nome Social: compare o nome de nascimento com variações de nome social, receba ranking de candidatos, score 0–100, 5 números fundamentais, 4 triângulos cabalísticos, arcanos, bloqueios, débitos, lições kármicas, tendências ocultas e variações harmonizadas para testar.',
  url: 'https://nomemagnetico.com.br/nome-social',
  brand: { '@type': 'Brand', name: 'Nome Magnético' },
  offers: {
    '@type': 'Offer',
    price: (getPrice('nome_social').cents / 100).toFixed(2),
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    url: 'https://nomemagnetico.com.br/comprar?produto=nome_social',
  },
};
---

<LandingLayout
  title="Harmonização de Assinatura e Nome Social | Nome Magnético"
  description="Compare seu nome de nascimento e variações de nome social para escolher uma assinatura harmonizada: ranking, score 0–100, numerologia cabalística, 4 triângulos, arcanos, bloqueios e PDF."
  keywords="harmonização de assinatura, assinatura numerológica, numerologia do nome social, numerologia do nome completo, mudar nome numerologia, assinatura harmonizada, nome sem bloqueios energéticos, análise vibracional nome, nome magnético numerologia, numerologia cabalística nome"
  showChatwoot={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />
  <link rel="canonical" href="https://nomemagnetico.com.br/nome-social" />

  <LandingHeader client:load />

  <main class="bg-[#111111] pt-24">

    {/* ── HERO ── */}
    <section class="pt-12 pb-16 relative overflow-hidden animate-on-scroll">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-[#D4AF37]/5 rounded-full blur-3xl" />
        <div class="absolute bottom-1/3 right-1/4 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl" />
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">

        <div class="inline-flex items-center gap-2 bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-full px-4 py-1.5 mb-6">
          <span class="text-[#D4AF37] text-xs" aria-hidden="true">✦</span>
          <span class="text-[#D4AF37] text-sm font-medium">Harmonização de Assinatura · {getPrice('nome_social').formatted}</span>
          <span class="text-[#D4AF37] text-xs" aria-hidden="true">✦</span>
        </div>

        <h1 class="font-cinzel text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Sua Assinatura Tem Mais Poder<br/>
          <span style="background: linear-gradient(135deg, #D4AF37, #E8C84A, #B8960E); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            Do Que Você Imagina
          </span>
        </h1>

        <p class="text-[#e5e2e1]/70 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
          Harmonize sua assinatura com uma análise de Nome Social que compara seu nome de nascimento com variações possíveis e mostra qual assinatura tem mais fluidez para o seu destino. Você recebe ranking dos candidatos, score 0–100, 5 números, 4 triângulos, arcanos, bloqueios e variações harmonizadas para testar no uso social, profissional e digital.
        </p>

        <LandingCheckout
          client:load
          product="nome_social"
          isLoggedIn={!!user}
          priceInfo={getPrice('nome_social')}
          promotion={promotion}
          label="Harmonizar Minha Assinatura →"
          className="inline-block bg-[#D4AF37] text-[#1A1A1A] font-bold text-lg px-10 py-4 rounded-xl hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-xl shadow-[#D4AF37]/20 cursor-pointer"
        />

        <div class="flex items-center justify-center gap-6 mt-5 flex-wrap">
          <p class="text-gray-600 text-sm">Pagamento único · {getPrice('nome_social').formatted} · Acesso imediato</p>
          <div class="flex items-center gap-2">
            <span class="text-[#D4AF37] text-xs">✦</span>
            <p class="text-gray-600 text-sm">PDF completo com ranking e recomendação</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── CONTEXTO IDENTIDADE ── */}
    <section class="py-12 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="rounded-2xl bg-white/3 p-7 md:p-8">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Momento de Identidade</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">
            O Brasil Está Atualizando a Identidade. E Você?
          </h2>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">
            Com a Carteira de Identidade Nacional, a identificação brasileira entra em uma nova fase: CPF como número único, documento físico e digital, integração com o GOV.BR e dados mais padronizados. O RG antigo segue válido até 2032, então não existe pressa documental.
          </p>
          <p class="text-gray-400 text-sm leading-relaxed">
            Mas existe um convite simbólico e prático: antes de usar um nome em assinaturas, cadastros, redes, contratos, crachás ou apresentações, vale saber se essa assinatura trabalha a favor da sua frequência. Harmonização de assinatura é exatamente isso: escolher com consciência o nome que você usa e emite todos os dias. O Nome Social não é um serviço de alteração civil.
          </p>
        </div>
      </div>
    </section>

    {/* ── SINTOMAS — Gatilho Dor ── */}
    <section class="py-16 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Você Reconhece Isso?</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">
            Sinais de que Seu Nome Pode Estar Te Bloqueando
          </h2>
          <p class="text-gray-500 max-w-xl mx-auto text-sm">87% dos nomes têm ao menos um bloqueio energético detectável. A maioria das pessoas vive anos sem saber a origem dessas resistências.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          {[
            {
              icone: '◈',
              titulo: 'O esforço não converte em resultado',
              desc: 'Você trabalha mais do que todos ao redor, mas os resultados aparecem com muito mais dificuldade — como se houvesse um filtro invisível entre sua dedicação e o reconhecimento merecido.',
            },
            {
              icone: '◈',
              titulo: 'Relacionamentos que não avançam',
              desc: 'Conexões intensas que chegam de repente e somem sem explicação. Ciclos de aproximação e afastamento que se repetem, como se você atraísse sempre o mesmo padrão de pessoas.',
            },
            {
              icone: '◈',
              titulo: 'Um teto invisível no crescimento',
              desc: 'Chega num certo ponto e trava. Na carreira, nos negócios, na renda. Parece que existe um limite que você não consegue ultrapassar, não importa o quanto se prepare ou se qualifique.',
            },
            {
              icone: '◈',
              titulo: 'Dinheiro que entra mas não fica',
              desc: 'A renda aumenta mas a estabilidade financeira não vem. Imprevistos que surgem sempre no momento errado, gastos que consomem os avanços antes que você possa consolidar o que construiu.',
            },
          ].map(s => (
            <div class="flex gap-4 bg-white/3 rounded-2xl p-6 transition-all duration-700 hover:bg-white/5 hover:-translate-y-0.5 group cursor-default">
              <div class="text-[#D4AF37] text-lg flex-shrink-0 mt-0.5 group-hover:text-[#f2ca50] transition-colors duration-700">{s.icone}</div>
              <div>
                <h3 class="text-[#e5e2e1] font-semibold text-sm mb-2">{s.titulo}</h3>
                <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <p class="text-center text-gray-600 text-sm mt-8">
          Esses padrões têm origem vibracional — e podem ser rastreados matematicamente nas letras do seu nome.
          <a href="/analise-gratuita" class="text-[#D4AF37] hover:text-[#f2ca50] transition-colors ml-1">Análise gratuita →</a>
        </p>
      </div>
    </section>

    {/* ── O QUE É UM BLOQUEIO ── */}
    <section class="py-16 bg-[#0f0f0f] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">O Que É um Bloqueio Energético no Nome?</h2>
          <p class="text-gray-500 max-w-2xl mx-auto text-sm">Quando certas sequências numéricas se repetem três ou mais vezes nos triângulos cabalísticos do seu nome, criam-se padrões que bloqueiam áreas específicas da sua vida.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {[
            { numero: '333', titulo: 'Bloqueio de Expressão', desc: 'Dificuldade em se comunicar, criar e se posicionar. Talentos reprimidos. Manifestação física: tensão crônica no pescoço e garganta.' },
            { numero: '444', titulo: 'Bloqueio de Estrutura', desc: 'Obstáculos na carreira, dificuldade de concluir projetos e construir estabilidade. Manifestação física: fadiga e tensão nos ombros.' },
            { numero: '555', titulo: 'Bloqueio de Liberdade', desc: 'Sensação de estar preso em padrões que se repetem. Resistência a mudanças necessárias. Manifestação física: ansiedade generalizada.' },
            { numero: '666', titulo: 'Bloqueio de Harmonia', desc: 'Conflitos frequentes em relacionamentos e família. Dificuldade em estabelecer limites saudáveis. Manifestação física: problemas digestivos.' },
            { numero: '888', titulo: 'Bloqueio de Abundância', desc: 'Relação conflituosa com dinheiro, poder e reconhecimento. Manifestação física: dores lombares e pressão arterial elevada.' },
            { numero: '999', titulo: 'Bloqueio de Compaixão', desc: 'Dificuldade em fechar ciclos e perdoar. Apego ao passado que impede evolução. Manifestação física: baixa imunidade e exaustão.' },
          ].map(b => (
            <div class="bg-white/3 rounded-2xl p-6 transition-all duration-700 ease-out hover:bg-white/6 hover:shadow-[0_20px_50px_rgba(0,0,0,0.6)] hover:-translate-y-1 group cursor-default">
              <div class="font-cinzel text-3xl font-bold text-[#D4AF37] mb-3 group-hover:text-[#f2ca50] transition-colors duration-700">{b.numero}</div>
              <h3 class="text-[#e5e2e1] font-semibold text-sm mb-2">{b.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{b.desc}</p>
            </div>
          ))}
        </div>
        <p class="text-center text-gray-600 text-sm mt-6">A análise completa verifica <strong class="text-gray-400">9 tipos de bloqueios</strong> em <strong class="text-gray-400">4 triângulos</strong> diferentes do seu nome.</p>
      </div>
    </section>

    {/* ── BEFORE / AFTER — Gatilho Transformação ── */}
    <section class="py-16 bg-[#111111] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Transformação</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">A Diferença que a Harmonização de Assinatura Faz</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-red-950/20 border border-red-500/15 rounded-2xl p-7">
            <p class="text-red-400 text-xs font-medium uppercase tracking-widest mb-5">Antes da Harmonização</p>
            <ul class="space-y-4">
              {[
                'Esforço constante com resultados abaixo do esperado',
                'Sensação de estar sempre a um passo do que quer',
                'Relacionamentos que repetem os mesmos padrões',
                'Energia dispersa — muitos começos, poucas conclusões',
                'Dificuldade de ser reconhecido pelo que realmente é',
              ].map(item => (
                <li class="flex items-start gap-3 text-gray-400 text-sm">
                  <span class="text-red-500 flex-shrink-0 mt-0.5">✕</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-emerald-950/20 border border-emerald-500/15 rounded-2xl p-7">
            <p class="text-emerald-400 text-xs font-medium uppercase tracking-widest mb-5">Depois da Harmonização</p>
            <ul class="space-y-4">
              {[
                'Esforço alinhado com resultados — menos resistência, mais fluxo',
                'Clareza sobre o próximo passo certo a dar',
                'Relacionamentos com mais profundidade e reciprocidade',
                'Foco natural — projetos que começam e chegam ao fim',
                'Presença magnética — as pessoas certas passam a notar você',
              ].map(item => (
                <li class="flex items-start gap-3 text-[#e5e2e1] text-sm">
                  <span class="text-emerald-400 flex-shrink-0 mt-0.5">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── COMO FUNCIONA ── */}
    <section class="py-16 bg-[#0f0f0f] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Processo</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">Como Funciona a Análise</h2>
        </div>
        <div class="grid md:grid-cols-4 gap-6">
          {[
            { n: '01', t: 'Essência original', d: 'Lemos seu nome de nascimento e sua data para revelar Destino, Expressão, Motivação, Missão e Impressão.' },
            { n: '02', t: 'Geometria completa', d: 'Calculamos os 4 triângulos — Vida, Pessoal, Social e Destino — com bloqueios e arcanos por dimensão.' },
            { n: '03', t: 'Ranking de assinaturas', d: 'Comparamos candidatos e sugestões em uma lista ordenada por score, compatibilidade e ausência de bloqueios.' },
            { n: '04', t: 'Harmonização de assinatura', d: 'Você recebe a assinatura recomendada e variações harmonizadas para testar no uso social, profissional e digital.' },
          ].map(s => (
            <div class="text-center transition-all duration-700 ease-out hover:-translate-y-1 group cursor-default">
              <div class="font-cinzel text-4xl font-bold text-[#D4AF37]/30 mb-3 group-hover:text-[#D4AF37]/60 transition-colors duration-700">{s.n}</div>
              <h3 class="text-[#e5e2e1] font-medium text-sm mb-2">{s.t}</h3>
              <p class="text-gray-500 text-xs leading-relaxed">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── O QUE VOCÊ ACESSA ── */}
    <section class="py-16 bg-[#111111] animate-on-scroll">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Incluído na Análise</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">O Dossiê Completo da Harmonização de Assinatura</h2>
          <p class="text-gray-500 text-sm max-w-xl mx-auto">Você acessa um relatório completo gerado pelo sistema, com leitura do nome de nascimento, comparação de candidatos e recomendação da assinatura mais fluida para o seu campo vibracional.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            { icon: '◎', titulo: 'Ranking das Assinaturas', desc: 'Todos os nomes avaliados do maior para o menor potencial de fluidez, com recomendação principal.' },
            { icon: '◇', titulo: 'Score 0–100', desc: 'Pontuação objetiva por bloqueios, débitos, tendências, lições kármicas e compatibilidade vibracional.' },
            { icon: '⬠', titulo: '5 Números Principais', desc: 'Expressão, Destino, Motivação, Missão e Impressão com leitura aplicada ao seu caso.' },
            { icon: '△', titulo: '4 Triângulos Cabalísticos', desc: 'Vida, Pessoal, Social e Destino — as quatro dimensões do fluxo do seu nome.' },
            { icon: '✦', titulo: 'Arcanos do Nome', desc: 'Arcano regente, sequência de passagem e arcano de trânsito para cada triângulo.' },
            { icon: '⚠', titulo: 'Bloqueios e Débitos', desc: 'Sequências repetidas, débitos kármicos e impactos simbólicos mapeados com clareza.' },
            { icon: '☯', titulo: 'Lições e Tendências', desc: 'Vibrações ausentes e excessos ocultos que revelam pontos cegos e padrões de comportamento.' },
            { icon: '⬇', titulo: 'PDF Premium', desc: 'Relatório completo para baixar, consultar e comparar suas opções sempre que precisar.' },
          ].map(c => (
            <div class="bg-white/3 rounded-2xl p-5 transition-all duration-700 ease-out hover:bg-white/6 hover:shadow-[0_20px_50px_rgba(0,0,0,0.6)] hover:-translate-y-1 group cursor-default">
              <div class="text-[#D4AF37] text-2xl mb-3 group-hover:text-[#f2ca50] transition-colors duration-700">{c.icon}</div>
              <h3 class="text-[#e5e2e1] font-semibold text-sm mb-2">{c.titulo}</h3>
              <p class="text-gray-500 text-xs leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── DEPOIMENTOS — Gatilho Prova Social ── */}
    <section class="py-16 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Resultados Reais</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">O Que Dizem Após a Análise</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {[
            {
              inicial: 'C',
              nome: 'Camila R.',
              area: 'Empreendedora · São Paulo',
              texto: 'Tinha bloqueio 444 e 888 ao mesmo tempo. Depois de mudar como assino meu nome nos contratos, em três meses fechei duas parcerias que estavam travadas há um ano. Não sei explicar racionalmente, mas os números são reais.',
            },
            {
              inicial: 'M',
              nome: 'Marcos V.',
              area: 'Designer · Rio de Janeiro',
              texto: 'Sempre achei que era sabotagem minha. A análise mostrou que meu nome tinha sequência 333 — bloqueio de expressão. Faz sentido: eu travava na hora de me posicionar. Adotei uma variação do nome e a confiança para apresentar meu trabalho mudou.',
            },
            {
              inicial: 'A',
              nome: 'Ana L.',
              area: 'Psicóloga · Curitiba',
              texto: 'Como psicóloga, fui cética. Mas a profundidade da análise — os 4 triângulos, as lições kármicas — vai muito além do que eu esperava. É uma ferramenta de autoconhecimento séria. Recomendo para clientes e já fiz a análise de toda a minha família.',
            },
          ].map(d => (
            <div class="bg-white/3 rounded-2xl p-6 flex flex-col gap-4 transition-all duration-700 hover:bg-white/5 hover:-translate-y-0.5">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-[#D4AF37]/20 flex items-center justify-center flex-shrink-0">
                  <span class="font-cinzel font-bold text-[#D4AF37]">{d.inicial}</span>
                </div>
                <div>
                  <p class="text-[#e5e2e1] text-sm font-medium">{d.nome}</p>
                  <p class="text-gray-600 text-xs">{d.area}</p>
                </div>
                <div class="ml-auto flex gap-0.5">
                  {[1,2,3,4,5].map(() => (
                    <span class="text-[#D4AF37] text-xs">★</span>
                  ))}
                </div>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed italic">"{d.texto}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── FAQ ── */}
    {faqItems.length > 0 && (
      <FAQSection items={faqItems} client:visible />
    )}

    {/* ── GARANTIA — Gatilho Risk Reversal ── */}
    <section class="py-12 bg-[#111111] animate-on-scroll">
      <div class="max-w-2xl mx-auto px-4">
        <div class="bg-[#D4AF37]/8 border border-[#D4AF37]/25 rounded-2xl p-8 text-center">
          <div class="text-4xl mb-4">🛡</div>
          <h3 class="font-cinzel text-xl font-bold text-white mb-3">Garantia de 7 Dias</h3>
          <p class="text-gray-400 text-sm leading-relaxed max-w-md mx-auto">
            Se por qualquer motivo você não estiver satisfeito com a análise, devolvemos 100% do valor sem burocracia. O risco é zero. A única coisa que você pode perder é continuar sem saber o que está bloqueando seu nome.
          </p>
        </div>
      </div>
    </section>

    {/* ── CTA FINAL ── */}
    <section class="py-20 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-xl mx-auto px-4 text-center">
        <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Investimento</p>
        <h2 class="font-cinzel text-3xl font-bold text-white mb-4">Harmonize Sua Assinatura</h2>
