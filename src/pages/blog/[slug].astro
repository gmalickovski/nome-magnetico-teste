---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { BlogHeader } from '../../frontend/components/blog/BlogHeader';
import { ShareButton } from '../../frontend/components/blog/ShareButton';
import { ArticleReactions } from '../../frontend/components/blog/ArticleReactions';
import { MobileTOC } from '../../frontend/components/blog/MobileTOC';
import { LandingFooter } from '../../frontend/components/landing/LandingFooter';
import { createClient } from '@supabase/supabase-js';
import { marked } from 'marked';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { slug } = Astro.params;

const { data: post } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('is_published', true)
  .single();

if (!post) {
  return Astro.redirect('/blog', 302);
}

// Parse markdown
let contentHtml = await marked.parse(post.content_markdown ?? '', { gfm: true });

// ── Remove o primeiro H1 do conteúdo markdown se existir.
// O título já é renderizado pela página — não duplicar.
contentHtml = contentHtml.replace(/^<h1[^>]*>[\s\S]*?<\/h1>\s*/i, '');

// ── Adiciona IDs aos H2/H3 para navegação por âncora
contentHtml = contentHtml.replace(
  /<h([23])([^>]*)>([\s\S]*?)<\/h[23]>/gi,
  (_match, level, attrs, inner) => {
    const text = inner.replace(/<[^>]+>/g, '').trim();
    const id = text
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .slice(0, 60);
    return `<h${level}${attrs} id="${id}">${inner}</h${level}>`;
  }
);

// ── Extrai TOC (H2s apenas) para sumário lateral
interface TocItem { id: string; text: string }
const toc: TocItem[] = [];
const tocRegex = /<h2[^>]*id="([^"]+)"[^>]*>([\s\S]*?)<\/h2>/gi;
let m: RegExpExecArray | null;
while ((m = tocRegex.exec(contentHtml)) !== null) {
  toc.push({ id: m[1], text: m[2].replace(/<[^>]+>/g, '').trim() });
}

// Artigos relacionados (mesma categoria ou mesmo produto, excluindo o atual)
const { data: related } = await supabase
  .from('blog_posts')
  .select('slug, title, description, category, produto_relacionado, published_at, content_markdown')
  .eq('is_published', true)
  .neq('slug', slug)
  .or(
    post.category
      ? `category.eq.${post.category},produto_relacionado.eq.${post.produto_relacionado ?? 'null'}`
      : `produto_relacionado.eq.${post.produto_relacionado ?? 'null'}`
  )
  .order('published_at', { ascending: false })
  .limit(3);

const PRODUTO_HREF: Record<string, string> = {
  nome_social:  '/nome-social',
  nome_bebe:    '/nome-bebe',
  nome_empresa: '/nome-empresarial',
};

const PRODUTO_LABEL: Record<string, string> = {
  nome_social:  'Nome Social',
  nome_bebe:    'Nome Bebê',
  nome_empresa: 'Nome Empresarial',
};

const CATEGORIA_LABEL: Record<string, string> = {
  numerologia:    'Numerologia',
  bloqueios:      'Bloqueios',
  'nome-social':  'Nome Social',
  'nome-bebe':    'Nome Bebê',
  'nome-empresa': 'Nome Empresarial',
  desenvolvimento:'Desenvolvimento',
  espiritualidade:'Espiritualidade',
};

const CATEGORY_COLOR: Record<string, string> = {
  numerologia:    'bg-[#D4AF37]/15 text-[#D4AF37]',
  bloqueios:      'bg-amber-500/15 text-amber-400',
  'nome-social':  'bg-[#D4AF37]/15 text-[#D4AF37]',
  'nome-bebe':    'bg-purple-500/15 text-purple-300',
  'nome-empresa': 'bg-sky-500/15 text-sky-300',
  desenvolvimento:'bg-emerald-500/15 text-emerald-400',
  espiritualidade:'bg-violet-500/15 text-violet-300',
};

function catLabel(p: { category?: string | null; produto_relacionado?: string | null }): string | null {
  if (p.category) return CATEGORIA_LABEL[p.category] ?? p.category;
  if (p.produto_relacionado) return PRODUTO_LABEL[p.produto_relacionado] ?? null;
  return null;
}

function catColor(p: { category?: string | null; produto_relacionado?: string | null }): string {
  const key = p.category ?? (p.produto_relacionado?.replace('_', '-') ?? '');
  return CATEGORY_COLOR[key] ?? 'bg-white/10 text-gray-400';
}

function readingTime(md?: string | null): number {
  return Math.max(1, Math.ceil((md?.trim().split(/\s+/).length ?? 0) / 200));
}

function formatDateFull(dateStr?: string | null): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

function formatDateShort(dateStr?: string | null): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}

const readMins = readingTime(post.content_markdown);
const seoKeywords = (post.keywords ?? post.meta_tags ?? []).join(', ');
const categorySlug = post.category ?? null;
---

<BlogLayout
  title={post.title}
  description={post.description ?? `Leia sobre ${post.title} no blog de numerologia cabalística do Nome Magnético.`}
  keywords={seoKeywords || 'numerologia cabalística, nome magnético, bloqueios energéticos'}
  ogImage={post.cover_image_url ?? undefined}
  isArticle={true}
  articleSlug={post.slug}
  articlePublishedTime={post.published_at ?? post.created_at}
  articleModifiedTime={post.updated_at ?? post.published_at ?? post.created_at}
  articleAuthor={post.author ?? 'Nome Magnético'}
>
  <link rel="canonical" href={`https://nomemagnetico.com.br/blog/${post.slug}`} />

  <BlogHeader client:load activeCategory={categorySlug ?? ''} />

  <main class="blog-main min-h-screen pt-[72px] pb-12 md:pb-20">
    <div class="max-w-6xl mx-auto px-4">

      {/* ── LAYOUT: conteúdo + sidebar (quando há TOC) ── */}
      <div class={`${toc.length >= 3 ? 'lg:grid lg:grid-cols-[1fr_240px] lg:gap-12' : ''} mt-6 sm:mt-8`}>

        {/* ── COLUNA PRINCIPAL ── */}
        <article class="min-w-0">

          {/* Breadcrumb */}
          <nav class="flex flex-wrap items-center gap-1 sm:gap-2 text-[10px] sm:text-xs text-gray-600 mb-5 sm:mb-6" aria-label="Navegação estrutural">
            <a href="/" class="hover:text-[#D4AF37] transition-colors">Início</a>
            <span aria-hidden="true">›</span>
            <a href="/blog" class="hover:text-[#D4AF37] transition-colors">Blog</a>
            {categorySlug && (
              <>
                <span aria-hidden="true">›</span>
                <a href={`/blog?categoria=${categorySlug}`} class="hover:text-[#D4AF37] transition-colors">
                  {CATEGORIA_LABEL[categorySlug] ?? categorySlug}
                </a>
              </>
            )}
          </nav>

          {/* ── HERO IMAGE ── */}
          {post.cover_image_url && (
            <div class="relative w-full overflow-hidden rounded-2xl mb-8" style="max-height:480px">
              <img
                src={post.cover_image_url}
                alt={`Imagem de capa: ${post.title}`}
                width={1080}
                height={1080}
                loading="eager"
                decoding="async"
                class="w-full object-cover object-center"
                style="aspect-ratio:16/9"
              />
            </div>
          )}

          {/* ── CABEÇALHO DO ARTIGO ── */}
          <header class="mb-6 sm:mb-8">
            {/* Linha superior: badge de categoria + botão compartilhar */}
            <div class="flex items-center justify-between gap-3 mb-4">
              <div>
                {catLabel(post) && (
                  <span class={`inline-block text-xs font-medium px-3 py-1 rounded-full ${catColor(post)}`}>
                    {catLabel(post)}
                  </span>
                )}
              </div>
              <ShareButton
                client:load
                title={post.title}
                description={post.description ?? ''}
              />
            </div>

            {/* Título */}
            <h1 class="font-cinzel text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-[#e5e2e1] leading-tight mb-4 sm:mb-5">
              {post.title}
            </h1>

            {/* Description / lead */}
            {post.description && (
              <p class="text-gray-400 text-sm sm:text-base md:text-lg leading-relaxed mb-5 sm:mb-6 max-w-2xl">
                {post.description}
              </p>
            )}

            {/* Metadados (sem botão de compartilhamento — movido para cima) */}
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-gray-600">
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                {post.author ?? 'Nome Magnético'}
              </span>
              {post.published_at && (
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <time datetime={post.published_at}>{formatDateFull(post.published_at)}</time>
                </span>
              )}
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {readMins} min de leitura
              </span>
            </div>

            {/* Divisor */}
            <div class="mt-6 h-px w-full opacity-20"
              style="background: linear-gradient(90deg, transparent, #D4AF37 30%, #D4AF37 70%, transparent);">
            </div>
          </header>

          {/* ── AD SLOT 1: antes do conteúdo (leaderboard) ── */}
          {/* Ativar quando tiver AdSense aprovado — remova o comentário e adicione o script: */}
          {/*
          <div class="ad-slot my-6 flex items-center justify-center rounded-xl border border-dashed border-white/8 h-20 text-gray-700 text-xs" data-ad="before-content">
            [ Publicidade ]
          </div>
          */}

          {/* ── CONTEÚDO MARKDOWN ── */}
          <div
            class="prose prose-invert prose-sm sm:prose-base max-w-none
              prose-headings:font-cinzel prose-headings:text-[#e5e2e1] prose-headings:font-bold
              prose-h2:text-xl sm:prose-h2:text-2xl prose-h2:mt-8 sm:prose-h2:mt-10 prose-h2:mb-3 sm:prose-h2:mb-4
              prose-h3:text-lg sm:prose-h3:text-xl prose-h3:mt-6 sm:prose-h3:mt-8 prose-h3:mb-2 sm:prose-h3:mb-3
              prose-p:text-gray-400 prose-p:leading-relaxed prose-p:mb-4
              prose-a:text-[#D4AF37] prose-a:no-underline hover:prose-a:underline
              prose-strong:text-[#e5e2e1] prose-strong:font-semibold
              prose-em:text-gray-300
              prose-blockquote:border-l-[#D4AF37] prose-blockquote:border-l-4 prose-blockquote:bg-white/3 prose-blockquote:rounded-r-xl prose-blockquote:py-3 prose-blockquote:px-5 prose-blockquote:not-italic
              prose-blockquote:text-gray-300
              prose-code:text-[#D4AF37] prose-code:bg-white/5 prose-code:rounded prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm
              prose-pre:bg-[#0d0d0d] prose-pre:border prose-pre:border-white/8 prose-pre:rounded-2xl
              prose-ul:text-gray-400 prose-ol:text-gray-400
              prose-li:mb-1
              prose-hr:border-white/10"
          >
            <Fragment set:html={contentHtml} />
          </div>

          {/* ── AD SLOT 2: após o conteúdo ── */}
          {/*
          <div class="ad-slot my-10 flex items-center justify-center rounded-xl border border-dashed border-white/8 h-24 text-gray-700 text-xs" data-ad="after-content">
            [ Publicidade ]
          </div>
          */}

          {/* Tags / Keywords */}
          {(post.meta_tags ?? post.keywords)?.length > 0 && (
            <div class="mt-10 pt-6 border-t border-white/8">
              <div class="flex flex-wrap gap-2">
                {(post.meta_tags ?? post.keywords).map((tag: string) => (
                  <span class="text-xs text-gray-600 bg-white/3 border border-white/8 px-3 py-1 rounded-full">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          {/* ── REACTIONS ── */}
          <div class="mt-10 pt-6 border-t border-white/8">
            <ArticleReactions client:visible slug={post.slug} />
          </div>

          {/* ── CTA PRODUTO RELACIONADO ── */}
          {post.produto_relacionado && (
            <div class="blog-cta-outer blog-card mt-10 sm:mt-12 relative rounded-2xl sm:rounded-3xl overflow-hidden p-px"
              style="background: linear-gradient(135deg, rgba(212,175,55,0.5) 0%, rgba(212,175,55,0.08) 100%);">
              <div class="blog-cta-inner blog-card rounded-2xl sm:rounded-3xl p-6 sm:p-8 text-center"
                style="background: radial-gradient(ellipse at top, #1d1a0d 0%, #131313 65%);">
                <p class="blog-cta-label text-[#D4AF37] text-[10px] sm:text-xs font-medium tracking-widest uppercase mb-2 sm:mb-3">Próximo Passo</p>
                <h3 class="blog-cta-title font-cinzel text-lg sm:text-xl font-bold text-white mb-2 sm:mb-3">
                  Descubra os Bloqueios do Seu Nome
                </h3>
                <p class="blog-cta-desc text-gray-400 text-xs sm:text-sm mb-5 sm:mb-6 max-w-md mx-auto leading-relaxed">
                  A análise completa vai além deste artigo — veja os 4 triângulos cabalísticos, bloqueios energéticos, lições kármicas e sugestões de nome harmonizado.
                </p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                  <a
                    href={PRODUTO_HREF[post.produto_relacionado] ?? '/precos'}
                    class="inline-block bg-[#D4AF37] text-[#1A1A1A] font-bold px-6 sm:px-8 py-3 sm:py-3.5 rounded-2xl hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.99] shadow-lg shadow-[#D4AF37]/20 text-sm"
                  >
                    Ver Análise de {PRODUTO_LABEL[post.produto_relacionado] ?? 'Nome'} →
                  </a>
                  <a
                    href="/analise-gratuita"
                    class="blog-cta-secondary inline-block border border-[#D4AF37]/40 text-[#D4AF37] font-medium px-6 sm:px-8 py-3 sm:py-3.5 rounded-2xl hover:bg-[#D4AF37]/10 transition-all duration-300 text-sm"
                  >
                    Teste Gratuito Primeiro
                  </a>
                </div>
              </div>
            </div>
          )}

          {/* ── ARTIGOS RELACIONADOS ── */}
          {related && related.length > 0 && (
            <div class="mt-10 sm:mt-14">
              <p class="text-gray-600 text-[10px] sm:text-xs font-medium uppercase tracking-widest mb-4 sm:mb-5">Continue lendo</p>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {related.map(rel => (
                  <a
                    href={`/blog/${rel.slug}`}
                    class="blog-card group flex flex-col bg-white/3 border border-white/8 rounded-2xl p-5 hover:border-[#D4AF37]/25 hover:bg-white/4 transition-all duration-300"
                  >
                    {catLabel(rel) && (
                      <span class={`text-xs font-medium px-2 py-0.5 rounded-full mb-3 w-fit ${catColor(rel)}`}>
                        {catLabel(rel)}
                      </span>
                    )}
                    <h3 class="font-cinzel text-sm font-bold text-white leading-snug line-clamp-3 group-hover:text-[#D4AF37] transition-colors mb-3 flex-1">
                      {rel.title}
                    </h3>
                    <div class="flex items-center justify-between text-gray-700 text-xs mt-auto pt-3 border-t border-white/5">
                      <span>{formatDateShort(rel.published_at)}</span>
                      <span class="text-[#D4AF37]/40 group-hover:text-[#D4AF37] transition-colors">→</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Navegação final */}
          <div class="mt-10 sm:mt-12 pt-5 sm:pt-6 border-t border-white/8 flex items-center justify-between">
            <a href="/blog" class="text-gray-600 hover:text-[#D4AF37] text-xs sm:text-sm transition-colors">
              ← Voltar para o Blog
            </a>
            <div class="flex items-center gap-3">
              <ShareButton
                client:load
                title={post.title}
                description={post.description ?? ''}
              />
            </div>
          </div>

        </article>

        {/* ── SIDEBAR: TOC (só quando artigo tem ≥3 H2s) ── */}
        {toc.length >= 3 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24 flex flex-col" style="max-height: calc(100vh - 120px);">
              <p class="flex-shrink-0 text-gray-600 text-xs font-medium uppercase tracking-widest mb-4">Neste artigo</p>
              {/* overflow-y-auto mas sem scrollbar visível.
                  O browser roteia o evento de roda para este elemento
                  quando o ponteiro está sobre ele. */}
              <nav class="toc-nav flex-1 overflow-y-auto space-y-1 mr-2">
                {toc.map(item => (
                  <a
                    href={`#${item.id}`}
                    class="block text-gray-500 hover:text-[#D4AF37] text-xs leading-relaxed py-1 border-l-2 border-white/5 hover:border-[#D4AF37]/40 pl-3 transition-all duration-200 line-clamp-2"
                  >
                    {item.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}

        {/* ── MOBILE TOC: botão flutuante + bottom sheet (só quando há TOC) ── */}
        {toc.length >= 3 && (
          <MobileTOC client:load items={toc} />
        )}

      </div>
    </div>
  </main>

  <LandingFooter client:visible />
</BlogLayout>

<style is:global>
  /* ── TOC Sidebar: scrollbar oculto por padrão ──────────────────────────── */
  /* Firefox */
  .toc-nav {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  /* Chrome / Safari / Edge */
  .toc-nav::-webkit-scrollbar {
    display: none;
  }
</style>
