---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { BlogHeader } from '../../frontend/components/blog/BlogHeader';
import { LandingFooter } from '../../frontend/components/landing/LandingFooter';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const activeCategory = Astro.url.searchParams.get('categoria') ?? '';

let query = supabase
  .from('blog_posts')
  .select('id, slug, title, description, category, produto_relacionado, published_at, content_markdown, is_featured, cover_image_url')
  .eq('is_published', true)
  .order('is_featured', { ascending: false })
  .order('published_at', { ascending: false });

if (activeCategory) {
  query = query.eq('category', activeCategory);
}

const { data: posts } = await query;

const CATEGORIA_LABEL: Record<string, string> = {
  numerologia:    'Numerologia',
  bloqueios:      'Bloqueios',
  'nome-social':  'Nome Social',
  'nome-bebe':    'Nome Bebê',
  'nome-empresa': 'Nome Empresarial',
  desenvolvimento:'Desenvolvimento',
  espiritualidade:'Espiritualidade',
};

const PRODUTO_LABEL: Record<string, string> = {
  nome_social: 'Nome Social',
  nome_bebe:   'Nome Bebê',
  nome_empresa:'Nome Empresarial',
};

const CATEGORY_COLOR: Record<string, string> = {
  numerologia:    'bg-[#D4AF37]/15 text-[#D4AF37]',
  bloqueios:      'bg-amber-500/15 text-amber-400',
  'nome-social':  'bg-[#D4AF37]/15 text-[#D4AF37]',
  'nome-bebe':    'bg-purple-500/15 text-purple-300',
  'nome-empresa': 'bg-sky-500/15 text-sky-300',
  desenvolvimento:'bg-emerald-500/15 text-emerald-400',
  espiritualidade:'bg-violet-500/15 text-violet-300',
};

type PostLike = { category?: string | null; produto_relacionado?: string | null };

function categoryLabel(p: PostLike): string | null {
  if (p.category) return CATEGORIA_LABEL[p.category] ?? p.category;
  if (p.produto_relacionado) return PRODUTO_LABEL[p.produto_relacionado] ?? null;
  return null;
}

function categoryColor(p: PostLike): string {
  const key = p.category ?? (p.produto_relacionado?.replace('_', '-') ?? '');
  return CATEGORY_COLOR[key] ?? 'bg-white/10 text-gray-400';
}

function readingTime(md?: string | null): number {
  return Math.max(1, Math.ceil((md?.trim().split(/\s+/).length ?? 0) / 200));
}

function formatDate(dateStr?: string | null): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}

const hasPosts = posts && posts.length > 0;
const [featured, ...rest] = hasPosts ? posts : [];

const pageTitle = activeCategory
  ? `${CATEGORIA_LABEL[activeCategory] ?? activeCategory} — Blog`
  : 'Blog de Numerologia Cabalística';
---

<BlogLayout
  title={pageTitle}
  description="Artigos sobre numerologia cabalística, bloqueios energéticos no nome, análise de nomes e desenvolvimento pessoal."
  keywords="blog numerologia cabalística, artigos numerologia, bloqueio energético nome, calcular número expressão, nome magnético"
  activeCategory={activeCategory}
>
  <link rel="canonical" href={`https://nomemagnetico.com.br/blog${activeCategory ? `?categoria=${activeCategory}` : ''}`} />

  <BlogHeader client:load activeCategory={activeCategory} />

  <main class="blog-main min-h-screen pt-[72px] pb-16 md:pb-20">

    {/* ── HERO ── */}
    <section class="max-w-5xl mx-auto px-4 pt-8 pb-8 md:pt-10 md:pb-10">
      {activeCategory ? (
        <div>
          <a href="/blog" class="inline-flex items-center gap-1.5 text-gray-600 hover:text-[#D4AF37] text-xs transition-colors mb-3">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Todos os artigos
          </a>
          <h1 class="font-cinzel text-2xl sm:text-3xl font-bold text-[#e5e2e1]">
            {CATEGORIA_LABEL[activeCategory] ?? activeCategory}
          </h1>
        </div>
      ) : (
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
          <div>
            <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-2">Numerologia Cabalística</p>
            <h1 class="font-cinzel text-2xl sm:text-3xl font-bold text-[#e5e2e1]">Blog</h1>
            <p class="text-gray-500 text-sm mt-1.5 max-w-lg leading-relaxed">
              Artigos sobre como o nome influencia carreira, relacionamentos e prosperidade.
            </p>
          </div>
          {posts && posts.length > 0 && (
            <p class="text-gray-700 text-xs flex-shrink-0 self-end sm:self-auto">
              {posts.length} artigo{posts.length !== 1 ? 's' : ''}
            </p>
          )}
        </div>
      )}
    </section>

    <div class="max-w-5xl mx-auto px-4">

      {hasPosts ? (
        <div>
          {/* ── CARD DESTAQUE ── */}
          {featured && (
            <a
              id="section-featured"
              href={`/blog/${featured.slug}`}
              data-searchable={`${featured.title ?? ''} ${featured.description ?? ''} ${categoryLabel(featured) ?? ''}`}
              class="blog-card group block mb-8 md:mb-10 rounded-2xl bg-white/3 border border-white/8
                     hover:border-[#D4AF37]/30 hover:bg-white/4
                     transition-all duration-500 hover:shadow-[0_20px_60px_rgba(212,175,55,0.08)]
                     overflow-hidden"
            >
              <div class={featured.cover_image_url ? 'md:grid md:grid-cols-[1fr_280px]' : ''}>
                {/* Conteúdo textual */}
                <div class="p-5 sm:p-7 md:p-9 flex flex-col justify-between">
                  {/* Topo: badge + meta */}
                  <div>
                    <div class="flex flex-wrap items-center gap-2 mb-3 md:mb-4">
                      <span class="text-[#D4AF37] text-[10px] font-bold tracking-widest uppercase">Destaque</span>
                      {categoryLabel(featured) && (
                        <span class={`text-[10px] font-medium px-2 py-0.5 rounded-full ${categoryColor(featured)}`}>
                          {categoryLabel(featured)}
                        </span>
                      )}
                      <span class="text-gray-700 text-[10px] ml-auto hidden sm:inline">
                        {formatDate(featured.published_at)}{featured.content_markdown ? ` · ${readingTime(featured.content_markdown)} min` : ''}
                      </span>
                    </div>

                    {/* Título */}
                    <h2 class="font-cinzel text-xl sm:text-2xl md:text-3xl font-bold text-white
                               leading-snug mb-3 md:mb-4
                               group-hover:text-[#D4AF37] transition-colors duration-300">
                      {featured.title}
                    </h2>

                    {/* Descrição */}
                    {featured.description && (
                      <p class="text-gray-400 text-sm sm:text-base leading-relaxed line-clamp-2 sm:line-clamp-3 mb-4 md:mb-5 max-w-3xl">
                        {featured.description}
                      </p>
                    )}
                  </div>

                  {/* Rodapé do card */}
                  <div class="flex items-center justify-between">
                    <span class="text-gray-700 text-xs sm:hidden">
                      {formatDate(featured.published_at)}{featured.content_markdown ? ` · ${readingTime(featured.content_markdown)} min` : ''}
                    </span>
                    <span class="text-[#D4AF37]/60 group-hover:text-[#D4AF37] text-xs sm:text-sm font-medium transition-colors ml-auto">
                      Ler artigo completo →
                    </span>
                  </div>
                </div>

                {/* Imagem (só quando disponível) */}
                {featured.cover_image_url && (
                  <div class="hidden md:block relative overflow-hidden">
                    <img
                      src={featured.cover_image_url}
                      alt={featured.title}
                      width={560}
                      height={560}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                    />
                  </div>
                )}

                {/* Imagem mobile (banda horizontal) */}
                {featured.cover_image_url && (
                  <div class="md:hidden w-full overflow-hidden" style="max-height:200px">
                    <img
                      src={featured.cover_image_url}
                      alt={featured.title}
                      width={800}
                      height={400}
                      loading="lazy"
                      decoding="async"
                      class="w-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                      style="aspect-ratio:16/9"
                    />
                  </div>
                )}
              </div>
            </a>
          )}

          {/* ── GRID DOS DEMAIS POSTS ── */}
          {rest.length > 0 && (
            <div id="section-grid">
              <div id="grid-header" class="mb-5">
                <p class="text-gray-600 text-[10px] font-medium uppercase tracking-widest">
                  {activeCategory ? 'Artigos' : 'Mais Recentes'}
                </p>
              </div>

              {/* 1 col mobile → 2 col sm/tablet → 3 col lg/desktop */}
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                {rest.map(post => (
                  <a
                    href={`/blog/${post.slug}`}
                    data-searchable={`${post.title ?? ''} ${post.description ?? ''} ${categoryLabel(post) ?? ''}`}
                    class="blog-card group flex flex-col bg-white/3 border border-white/8 rounded-2xl overflow-hidden
                           hover:border-[#D4AF37]/25 hover:bg-white/4
                           hover:shadow-[0_16px_40px_rgba(212,175,55,0.07)]
                           transition-all duration-500"
                  >
                    {/* Imagem de capa (quando disponível) */}
                    {post.cover_image_url && (
                      <div class="w-full overflow-hidden" style="aspect-ratio:16/9">
                        <img
                          src={post.cover_image_url}
                          alt={post.title}
                          width={600}
                          height={338}
                          loading="lazy"
                          decoding="async"
                          class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                        />
                      </div>
                    )}

                    <div class="flex flex-col flex-1 p-5">
                    {/* Categoria + tempo */}
                    <div class="flex items-center gap-2 mb-3">
                      {categoryLabel(post) && (
                        <span class={`text-[10px] font-medium px-2 py-0.5 rounded-full ${categoryColor(post)}`}>
                          {categoryLabel(post)}
                        </span>
                      )}
                      {post.content_markdown && (
                        <span class="text-gray-700 text-[10px] ml-auto">{readingTime(post.content_markdown)} min</span>
                      )}
                    </div>

                    {/* Título */}
                    <h2 class="font-cinzel text-sm font-bold text-white leading-snug
                               mb-2.5 line-clamp-3
                               group-hover:text-[#D4AF37] transition-colors duration-300 flex-1">
                      {post.title}
                    </h2>

                    {/* Descrição */}
                    {post.description && (
                      <p class="text-gray-500 text-xs leading-relaxed line-clamp-2 mb-4">
                        {post.description}
                      </p>
                    )}

                    {/* Data + seta */}
                    <div class="flex items-center justify-between mt-auto pt-3 border-t border-white/5">
                      <span class="text-gray-700 text-[10px]">{formatDate(post.published_at)}</span>
                      <span class="text-[#D4AF37]/40 group-hover:text-[#D4AF37] text-sm transition-colors">→</span>
                    </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
          {/* ── Sem resultados na busca ── */}
          <div id="no-results" class="hidden text-center py-12">
            <p class="font-cinzel text-lg font-bold text-white mb-2">Nenhum artigo encontrado</p>
            <p class="text-gray-500 text-sm">Tente outro termo ou <button onclick="window.dispatchEvent(new CustomEvent('blog:clear'))" class="text-[#D4AF37] hover:underline">limpe a busca</button>.</p>
          </div>
        </div>

      ) : (
        /* ── EMPTY STATE ── */
        <div class="text-center py-16 sm:py-24 max-w-sm sm:max-w-lg mx-auto">
          <div class="relative inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 mb-6 sm:mb-8">
            <div class="absolute inset-0 rounded-full bg-[#D4AF37]/8 blur-xl"></div>
            <span class="font-cinzel text-3xl sm:text-4xl text-[#D4AF37]/25 select-none relative">✦</span>
          </div>
          <h2 class="font-cinzel text-xl sm:text-2xl font-bold text-white mb-3 sm:mb-4">
            {activeCategory
              ? `Nenhum artigo em "${CATEGORIA_LABEL[activeCategory] ?? activeCategory}"`
              : 'Artigos chegando em breve'}
          </h2>
          <p class="text-gray-500 text-sm leading-relaxed mb-8">
            {activeCategory
              ? 'Ainda não há artigos nesta categoria. Veja todos os artigos ou experimente o diagnóstico gratuito.'
              : 'Estamos preparando conteúdo sobre numerologia cabalística, bloqueios energéticos e análise de nomes.'}
          </p>
          <div class="flex flex-col gap-3 items-center">
            {activeCategory && (
              <a href="/blog"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-white/15 text-gray-400 font-medium px-6 py-3 rounded-full hover:border-[#D4AF37]/30 hover:text-[#D4AF37] transition-all duration-300 text-sm">
                ← Ver todos os artigos
              </a>
            )}
            <a href="/analise-gratuita"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#D4AF37] text-[#1A1A1A] font-bold px-6 py-3 rounded-full hover:bg-[#f2ca50] transition-all duration-300 shadow-lg shadow-[#D4AF37]/20 text-sm">
              Fazer Análise Gratuita →
            </a>
          </div>
        </div>
      )}

    </div>
  </main>

  <LandingFooter client:visible />

  <script>
    function filterBlog(query: string) {
      const q = (query || '').toLowerCase().trim();
      const cards = document.querySelectorAll<HTMLElement>('[data-searchable]');
      let visible = 0;

      cards.forEach(card => {
        const text = (card.getAttribute('data-searchable') || '').toLowerCase();
        const matches = !q || text.includes(q);
        card.style.display = matches ? '' : 'none';
        if (matches) visible++;
      });

      // Cabeçalho da seção grid
      const gridHeader = document.getElementById('grid-header');
      if (gridHeader) {
        const gridCards = document.querySelectorAll<HTMLElement>('#section-grid [data-searchable]');
        const visibleGrid = Array.from(gridCards).filter(c => c.style.display !== 'none').length;
        gridHeader.style.display = visibleGrid === 0 ? 'none' : '';
      }

      const noResults = document.getElementById('no-results');
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    window.addEventListener('blog:search', (e: Event) => {
      filterBlog((e as CustomEvent<string>).detail);
    });
    window.addEventListener('blog:clear', () => filterBlog(''));
  </script>
</BlogLayout>
