---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { LandingHeader } from '../../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../../frontend/components/landing/LandingFooter';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: posts } = await supabase
  .from('blog_posts')
  .select('id, slug, title, description, produto_relacionado, published_at, cover_image_url, content_markdown')
  .eq('is_published', true)
  .order('published_at', { ascending: false });

const PRODUTO_LABEL: Record<string, string> = {
  nome_social: 'Nome Social',
  nome_bebe: 'Nome Bebê',
  nome_empresa: 'Nome Empresarial',
};

const PRODUTO_COLOR: Record<string, string> = {
  nome_social: 'bg-[#D4AF37]/15 text-[#D4AF37]',
  nome_bebe: 'bg-purple-500/15 text-purple-300',
  nome_empresa: 'bg-sky-500/15 text-sky-300',
};

function readingTime(markdown: string): number {
  const words = markdown?.trim().split(/\s+/).length ?? 0;
  return Math.max(1, Math.ceil(words / 200));
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

const hasPosts = posts && posts.length > 0;
const [featured, ...rest] = hasPosts ? posts : [];
---

<LandingLayout
  title="Blog de Numerologia Cabalística | Nome Magnético"
  description="Artigos sobre numerologia cabalística, bloqueios energéticos no nome, como calcular o número de expressão, nome para bebê e muito mais."
  keywords="blog numerologia cabalística, artigos numerologia, numerologia do nome, bloqueio energético nome, calcular número expressão"
>
  <link rel="canonical" href="https://nomemagnetico.com.br/blog" />

  <LandingHeader client:load />

  <main class="min-h-screen bg-[#111111] pt-24 pb-20">
    <div class="max-w-5xl mx-auto px-4">

      {/* Hero */}
      <div class="text-center mb-14">
        <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Conteúdo</p>
        <h1 class="font-cinzel text-3xl md:text-4xl font-bold text-[#e5e2e1] mb-4">
          Blog de Numerologia Cabalística
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-base leading-relaxed">
          Artigos educativos sobre como o nome influencia sua vida, como detectar bloqueios energéticos e como a numerologia cabalística transforma trajetórias.
        </p>
      </div>

      {hasPosts ? (
        <div>
          {/* Card destaque — primeiro post */}
          {featured && (
            <a
              href={`/blog/${featured.slug}`}
              class="group block mb-8 rounded-2xl overflow-hidden bg-white/3 border border-white/8 hover:border-[#D4AF37]/30 transition-all duration-500 hover:shadow-[0_20px_50px_rgba(212,175,55,0.12)] md:flex"
            >
              {/* Imagem / placeholder */}
              <div class="md:w-2/5 h-52 md:h-auto flex-shrink-0 relative overflow-hidden">
                {featured.cover_image_url ? (
                  <img
                    src={featured.cover_image_url}
                    alt={featured.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center"
                    style="background: linear-gradient(135deg, #1a1a0e 0%, #2a2208 50%, #111111 100%);">
                    <span class="font-cinzel text-6xl font-bold text-[#D4AF37]/20 select-none">✦</span>
                  </div>
                )}
                {featured.produto_relacionado && (
                  <span class={`absolute top-4 left-4 text-xs font-medium px-3 py-1.5 rounded-full backdrop-blur-sm ${PRODUTO_COLOR[featured.produto_relacionado] ?? 'bg-white/10 text-gray-300'}`}>
                    {PRODUTO_LABEL[featured.produto_relacionado] ?? featured.produto_relacionado}
                  </span>
                )}
              </div>
              {/* Conteúdo */}
              <div class="p-7 flex flex-col justify-center">
                <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-2">Destaque</p>
                <h2 class="font-cinzel text-xl md:text-2xl font-bold text-white mb-3 leading-snug group-hover:text-[#D4AF37] transition-colors duration-300">
                  {featured.title}
                </h2>
                {featured.description && (
                  <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-4">{featured.description}</p>
                )}
                <div class="flex items-center gap-3 text-gray-600 text-xs">
                  {featured.published_at && <span>{formatDate(featured.published_at)}</span>}
                  {featured.content_markdown && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>{readingTime(featured.content_markdown)} min de leitura</span>
                    </>
                  )}
                  <span class="ml-auto text-[#D4AF37]/60 group-hover:text-[#D4AF37] transition-colors">Ler artigo →</span>
                </div>
              </div>
            </a>
          )}

          {/* Grid dos demais posts */}
          {rest.length > 0 && (
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {rest.map(post => (
                <a
                  href={`/blog/${post.slug}`}
                  class="group flex flex-col bg-white/3 border border-white/8 rounded-2xl overflow-hidden hover:border-[#D4AF37]/30 hover:shadow-[0_20px_50px_rgba(212,175,55,0.10)] transition-all duration-500"
                >
                  {/* Thumb */}
                  <div class="h-44 relative overflow-hidden flex-shrink-0">
                    {post.cover_image_url ? (
                      <img
                        src={post.cover_image_url}
                        alt={post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center"
                        style="background: linear-gradient(135deg, #1a1a0e 0%, #2a2208 60%, #111111 100%);">
                        <span class="font-cinzel text-4xl font-bold text-[#D4AF37]/15 select-none">✦</span>
                      </div>
                    )}
                    {post.produto_relacionado && (
                      <span class={`absolute top-3 left-3 text-xs font-medium px-2.5 py-1 rounded-full backdrop-blur-sm ${PRODUTO_COLOR[post.produto_relacionado] ?? 'bg-white/10 text-gray-300'}`}>
                        {PRODUTO_LABEL[post.produto_relacionado] ?? post.produto_relacionado}
                      </span>
                    )}
                  </div>
                  {/* Texto */}
                  <div class="p-5 flex flex-col flex-1">
                    <h2 class="font-cinzel text-sm font-bold text-white mb-2 leading-snug group-hover:text-[#D4AF37] transition-colors duration-300 line-clamp-2">
                      {post.title}
                    </h2>
                    {post.description && (
                      <p class="text-gray-500 text-xs leading-relaxed line-clamp-3 mb-4 flex-1">{post.description}</p>
                    )}
                    <div class="flex items-center justify-between text-gray-600 text-xs mt-auto">
                      {post.published_at && <span>{formatDate(post.published_at)}</span>}
                      {post.content_markdown && (
                        <span>{readingTime(post.content_markdown)} min</span>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      ) : (
        /* Empty state profissional */
        <div class="text-center py-24 max-w-lg mx-auto">
          <div class="relative inline-flex items-center justify-center w-24 h-24 mb-8">
            <div class="absolute inset-0 rounded-full bg-[#D4AF37]/8" style="filter: blur(20px);"></div>
            <span class="font-cinzel text-5xl text-[#D4AF37]/30 select-none relative">✦</span>
          </div>
          <h2 class="font-cinzel text-2xl font-bold text-white mb-4">Artigos chegando em breve</h2>
          <p class="text-gray-400 text-base leading-relaxed mb-2">
            Estamos preparando conteúdo exclusivo sobre numerologia cabalística, bloqueios energéticos e como o nome influencia cada área da vida.
          </p>
          <p class="text-gray-600 text-sm mb-10">Enquanto isso, experimente o diagnóstico gratuito.</p>
          <a
            href="/calcular-numero"
            class="inline-flex items-center gap-2 bg-[#D4AF37] text-[#1A1A1A] font-bold px-8 py-3.5 rounded-full hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-[#D4AF37]/20"
          >
            Fazer Teste de Bloqueios Grátis →
          </a>
        </div>
      )}

    </div>
  </main>

  <LandingFooter client:visible />
</LandingLayout>
