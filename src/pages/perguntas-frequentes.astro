---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { getSupabaseFaqs } from '../backend/faqs/getSupabaseFaqs';

const faqs = await getSupabaseFaqs().catch(() => []);

const schemaFAQPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer_html.replace(/<[^>]+>/g, ''),
    },
  })),
};
---

<LandingLayout
  title="Perguntas Frequentes — Numerologia Cabalística | Nome Magnético"
  description="Tire suas dúvidas sobre o Nome Magnético: como funciona a numerologia cabalística, o que são bloqueios energéticos no nome, como calcular o número de expressão e muito mais."
  keywords="perguntas frequentes numerologia, dúvidas numerologia cabalística, como funciona numerologia do nome, o que é bloqueio energético nome, numerologia FAQ"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQPage)} />
  <link rel="canonical" href="https://nomemagnetico.com.br/perguntas-frequentes" />

  <LandingHeader client:load />

  <main class="min-h-screen bg-[#111111] pt-24 pb-20">
    <div class="max-w-3xl mx-auto px-4">


      {/* Header */}
      <div class="text-center mb-14">
        <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Suporte</p>
        <h1 class="font-cinzel text-3xl md:text-4xl font-bold text-white mb-4">
          Perguntas Frequentes
        </h1>
        <p class="text-gray-400 max-w-xl mx-auto text-base leading-relaxed">
          Respondemos as dúvidas mais comuns sobre numerologia cabalística, bloqueios energéticos e como o Nome Magnético funciona.
        </p>
      </div>

      {/* FAQ Accordion */}
      {faqs.length > 0 ? (
        <div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
          {faqs.map((faq, i) => (
            <details
              class="group bg-white/3 border border-white/8 rounded-2xl overflow-hidden transition-all duration-300 hover:border-[#D4AF37]/20"
              itemscope
              itemprop="mainEntity"
              itemtype="https://schema.org/Question"
            >
              <summary
                class="flex items-center justify-between px-6 py-5 cursor-pointer list-none select-none"
                aria-label={`Pergunta ${i + 1}: ${faq.question}`}
              >
                <h2 class="text-white font-medium text-sm pr-4 leading-relaxed" itemprop="name">
                  {faq.question}
                </h2>
                <span class="text-[#D4AF37] text-lg flex-shrink-0 transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
              </summary>
              <div
                class="px-6 pb-6 text-gray-400 text-sm leading-relaxed prose prose-invert prose-sm max-w-none"
                itemscope
                itemprop="acceptedAnswer"
                itemtype="https://schema.org/Answer"
              >
                <div itemprop="text" set:html={faq.answer_html} />
              </div>
            </details>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-gray-600">
          <p>Nenhuma pergunta cadastrada ainda.</p>
        </div>
      )}

      {/* CTA */}
      <div class="mt-14 text-center">
        <p class="text-gray-500 text-sm mb-6">Não encontrou o que procurava?</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/suporte"
            class="border border-[#D4AF37]/40 text-[#D4AF37] font-medium px-6 py-3 rounded-xl hover:bg-[#D4AF37]/10 transition-all duration-300 text-sm"
          >
            Abrir Ticket de Suporte
          </a>
          <a
            href="/comprar"
            class="bg-[#D4AF37] text-[#1A1A1A] font-bold px-6 py-3 rounded-xl hover:bg-[#f2ca50] transition-all duration-300 text-sm"
          >
            Ver os Produtos →
          </a>
        </div>
      </div>

    </div>
  </main>

  <LandingFooter client:visible />
</LandingLayout>
