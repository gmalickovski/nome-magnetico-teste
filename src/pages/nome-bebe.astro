---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { getSupabaseFaqs } from '../backend/faqs/getSupabaseFaqs';
import type { FaqItemProps } from '../frontend/components/landing/FAQSection';
import { FAQSection } from '../frontend/components/landing/FAQSection';

let faqItems: FaqItemProps[] = [];
try {
  faqItems = await getSupabaseFaqs({ featuredOnly: true });
} catch {
  // fallback silencioso
}

const schemaProduct = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Nome para Bebê — Análise Numerológica Cabalística',
  description: 'Escolha o nome do seu bebê com base na numerologia cabalística. Ranking de nomes candidatos compatíveis com o Número de Destino da criança e o sobrenome da família.',
  url: 'https://nomemagnetico.com.br/nome-bebe',
  brand: { '@type': 'Brand', name: 'Nome Magnético' },
  offers: {
    '@type': 'Offer',
    price: '147.00',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    url: 'https://nomemagnetico.com.br/comprar?produto=nome_bebe',
  },
};
---

<LandingLayout
  title="Nome para Bebê com Numerologia — Escolha o Nome Ideal | Nome Magnético"
  description="Escolha o nome do seu bebê com base na numerologia cabalística. Ranking de nomes candidatos compatíveis com o Número de Destino da criança, sem bloqueios energéticos."
  keywords="nome para bebê numerologia, significado do nome bebê numerologia, escolher nome bebê espiritualidade, nome bebê cabalístico, numerologia nome bebê compatibilidade, ranking nomes bebê numerologia, nome bebê sem bloqueios"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />
  <link rel="canonical" href="https://nomemagnetico.com.br/nome-bebe" />

  <LandingHeader client:load />

  <main class="bg-[#111111] pt-24">

    {/* Hero */}
    <section class="pt-12 pb-16 relative overflow-hidden animate-on-scroll">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl" />
        <div class="absolute bottom-1/3 left-1/4 w-80 h-80 bg-[#D4AF37]/5 rounded-full blur-3xl" />
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <div class="inline-flex items-center gap-2 bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-full px-4 py-1.5 mb-6">
          <span class="text-[#D4AF37] text-xs" aria-hidden="true">✦</span>
          <span class="text-[#D4AF37] text-sm font-medium">Para o Futuro do Seu Filho · R$ 147</span>
          <span class="text-[#D4AF37] text-xs" aria-hidden="true">✦</span>
        </div>

        <h1 class="font-cinzel text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Dê ao Seu Filho um Nome<br/>
          <span style="background: linear-gradient(135deg, #D4AF37, #E8C84A, #B8960E); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            Que Ressoa com o Destino Dele
          </span>
        </h1>

        <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
          O nome que você escolhe hoje vai acompanhar seu filho para sempre. Com a numerologia cabalística, você garante que esse nome esteja em <strong class="text-white">harmonia vibracional</strong> com o Número de Destino da criança — sem bloqueios energéticos.
        </p>

        <a
          href="/comprar?produto=nome_bebe"
          class="inline-block bg-[#D4AF37] text-[#1A1A1A] font-bold text-lg px-10 py-4 rounded-xl hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-xl shadow-[#D4AF37]/20"
        >
          Escolher o Nome do Meu Bebê →
        </a>
        <div class="flex items-center justify-center gap-6 mt-5 flex-wrap">
          <p class="text-gray-600 text-sm">Pagamento único · R$ 147 · Acesso imediato</p>
          <div class="flex items-center gap-1.5">
            <span class="text-[#D4AF37] text-xs">✦</span>
            <p class="text-gray-600 text-sm">Garantia de 7 dias</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── O RISCO DO NOME ERRADO — Gatilho Dor ── */}
    <section class="py-16 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">O Peso da Escolha</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">
            O Que Acontece Quando o Nome Não Está Alinhado?
          </h2>
          <p class="text-gray-500 max-w-xl mx-auto text-sm">
            Um nome não é apenas identidade — é uma frequência que acompanha a criança em cada etapa da vida. Um nome desalinhado não é destino, mas cria resistências que poderiam ter sido evitadas.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {[
            {
              icone: '◈',
              titulo: 'Dificuldade de expressão na infância',
              desc: 'Crianças com bloqueio de expressão no nome tendem a ter dificuldade de se impor, de ser ouvidas e de conquistar seu espaço nos grupos.',
            },
            {
              icone: '◈',
              titulo: 'Padrões de resistência na adolescência',
              desc: 'Conflitos recorrentes com autoridade, dificuldade de focar e sensação de não pertencimento são sinais comuns de desalinhamento vibracional.',
            },
            {
              icone: '◈',
              titulo: 'Teto invisível na vida adulta',
              desc: 'O mesmo padrão de bloqueio no nome que limitou a infância continua operando na carreira, nas finanças e nos relacionamentos.',
            },
          ].map(s => (
            <div class="flex flex-col gap-3 bg-white/3 rounded-2xl p-6 transition-all duration-700 hover:bg-white/5 hover:-translate-y-0.5 group cursor-default">
              <div class="text-[#D4AF37] text-lg group-hover:text-[#f2ca50] transition-colors duration-700">{s.icone}</div>
              <h3 class="text-[#e5e2e1] font-semibold text-sm">{s.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Por que o nome importa */}
    <section class="py-16 bg-[#0f0f0f] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">Por Que o Nome do Bebê Importa na Numerologia?</h2>
          <p class="text-gray-400 max-w-2xl mx-auto">Na cabala, cada nome carrega uma vibração matemática que influencia a experiência de vida da pessoa. Um nome harmonioso potencializa o destino. Um nome com bloqueios cria resistências desnecessárias.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { icon: '⬡', t: 'Compatibilidade Numérica', d: 'O nome precisa ser compatível com o Número de Destino da criança — calculado pela data de nascimento.' },
            { icon: '◈', t: 'Harmonia com o Sobrenome', d: 'O nome completo (incluindo sobrenome da família) é analisado como um todo vibracional.' },
            { icon: '△', t: 'Ausência de Bloqueios', d: 'Verificamos os 4 triângulos cabalísticos de cada candidato para garantir que não há sequências bloqueadoras.' },
          ].map(c => (
            <div class="bg-white/3 rounded-2xl p-6 text-center transition-all duration-700 ease-out hover:bg-white/6 hover:shadow-[0_20px_50px_rgba(0,0,0,0.6)] hover:-translate-y-1 group cursor-default">
              <div class="text-[#D4AF37] text-3xl mb-3 group-hover:text-[#f2ca50] transition-colors duration-700">{c.icon}</div>
              <h3 class="text-[#e5e2e1] font-semibold text-sm mb-2">{c.t}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{c.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Como funciona o ranking */}
    <section class="py-16 bg-[#111111] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Metodologia</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">Como Funciona o Ranking de Nomes</h2>
        </div>
        <div class="grid md:grid-cols-4 gap-6">
          {[
            { n: '01', t: 'Seus candidatos', d: 'Você informa os nomes que está considerando para o bebê.' },
            { n: '02', t: 'Análise completa', d: 'Calculamos os 4 triângulos cabalísticos de cada candidato com o sobrenome da família.' },
            { n: '03', t: 'Score 0–100', d: 'Cada nome recebe uma pontuação baseada em bloqueios, compatibilidade e lições kármicas.' },
            { n: '04', t: 'O Nome de Ouro', d: 'O sistema revela qual candidato tem a melhor vibração para o destino do seu filho.' },
          ].map(s => (
            <div class="text-center">
              <div class="font-cinzel text-4xl font-bold text-[#D4AF37]/30 mb-3">{s.n}</div>
              <h3 class="text-white font-medium text-sm mb-2">{s.t}</h3>
              <p class="text-gray-500 text-xs leading-relaxed">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* O que você recebe */}
    <section class="py-16 bg-[#0f0f0f] animate-on-scroll">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Entregável</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">O Que Você Recebe</h2>
          <p class="text-gray-500 text-sm max-w-xl mx-auto">Um relatório completo que revela matematicamente o melhor nome para o seu bebê.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            { icon: '★', titulo: 'O Nome de Ouro', desc: 'O melhor candidato revelado matematicamente — o nome com score máximo para o destino do seu filho.', destaque: true },
            { icon: '☯', titulo: 'Arquétipo da Criança', desc: 'O perfil inato do bebê: como ele tende a se relacionar, aprender e expressar sua personalidade.' },
            { icon: '△', titulo: '4 Triângulos por Candidato', desc: 'Análise cabalística completa de cada nome que você informa, com o sobrenome da família.' },
            { icon: '⬟', titulo: 'Score 0–100', desc: 'Cada candidato recebe uma pontuação por harmonia vibracional, compatibilidade e ausência de bloqueios.' },
            { icon: '◈', titulo: 'Compatibilidade com o Sobrenome', desc: 'O nome completo é analisado como um todo — não só o primeiro nome.' },
            { icon: '✦', titulo: 'Guia para os Pais', desc: 'Como lidar com o perfil numerológico do filho: potencialidades e desafios de cada fase da vida.' },
          ].map(c => (
            <div class={`rounded-2xl p-5 transition-all duration-700 ease-out hover:shadow-[0_20px_50px_rgba(0,0,0,0.6)] hover:-translate-y-1 group cursor-default ${c.destaque ? 'bg-[#D4AF37]/10 border border-[#D4AF37]/30 hover:bg-[#D4AF37]/15' : 'bg-white/3 hover:bg-white/6'}`}>
              <div class={`text-2xl mb-3 transition-colors duration-700 ${c.destaque ? 'text-[#f2ca50]' : 'text-[#D4AF37] group-hover:text-[#f2ca50]'}`}>{c.icon}</div>
              <h3 class={`font-semibold text-sm mb-2 ${c.destaque ? 'text-[#f2ca50]' : 'text-[#e5e2e1]'}`}>{c.titulo}</h3>
              <p class="text-gray-500 text-xs leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── DEPOIMENTOS ── */}
    <section class="py-16 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Pais que Escolheram com Certeza</p>
          <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-white mb-4">O Que Dizem as Famílias</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          {[
            {
              inicial: 'F',
              nome: 'Fernanda & Lucas',
              area: 'Pais da pequena Sofia · Florianópolis',
              texto: 'Tínhamos 5 nomes na lista e não conseguíamos decidir. A análise mostrou que Sofia tinha score 94 — o mais alto de todos — e alinhada perfeitamente com o Destino da nossa filha. A sensação de certeza foi imediata. Não havia mais dúvida.',
            },
            {
              inicial: 'R',
              nome: 'Renata S.',
              area: 'Mãe do Theo · Belo Horizonte',
              texto: 'Fiquei impressionada com a profundidade. A análise não só mostrou qual nome era melhor — explicou por quê, com os 4 triângulos e o perfil do arquétipo da criança. Agora sei como potencializar a personalidade natural do meu filho desde cedo.',
            },
          ].map(d => (
            <div class="bg-white/3 rounded-2xl p-6 flex flex-col gap-4 transition-all duration-700 hover:bg-white/5 hover:-translate-y-0.5">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-[#D4AF37]/20 flex items-center justify-center flex-shrink-0">
                  <span class="font-cinzel font-bold text-[#D4AF37]">{d.inicial}</span>
                </div>
                <div>
                  <p class="text-[#e5e2e1] text-sm font-medium">{d.nome}</p>
                  <p class="text-gray-600 text-xs">{d.area}</p>
                </div>
                <div class="ml-auto flex gap-0.5">
                  {[1,2,3,4,5].map(() => (
                    <span class="text-[#D4AF37] text-xs">★</span>
                  ))}
                </div>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed italic">"{d.texto}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* FAQ */}
    {faqItems.length > 0 && (
      <FAQSection items={faqItems} client:visible />
    )}

    {/* ── GARANTIA ── */}
    <section class="py-12 bg-[#111111] animate-on-scroll">
      <div class="max-w-2xl mx-auto px-4">
        <div class="bg-[#D4AF37]/8 border border-[#D4AF37]/25 rounded-2xl p-8 text-center">
          <div class="text-4xl mb-4">🛡</div>
          <h3 class="font-cinzel text-xl font-bold text-white mb-3">Garantia Incondicional de 7 Dias</h3>
          <p class="text-gray-400 text-sm leading-relaxed max-w-md mx-auto">
            Se por qualquer motivo a análise não atender às suas expectativas, devolvemos 100% do valor sem burocracia. A única coisa que você não pode devolver é a clareza que terá sobre o nome do seu filho.
          </p>
        </div>
      </div>
    </section>

    {/* CTA final */}
    <section class="py-20 bg-[#0d0d0d] animate-on-scroll">
      <div class="max-w-xl mx-auto px-4 text-center">
        <p class="text-[#D4AF37] text-xs font-medium tracking-widest uppercase mb-3">Investimento</p>
        <h2 class="font-cinzel text-3xl font-bold text-white mb-4">Garanta o Melhor Começo</h2>
        <div class="font-cinzel text-5xl font-bold text-[#D4AF37] mb-2">R$ 147</div>
        <p class="text-gray-500 text-sm mb-8">Pagamento único · Acesso por 30 dias · Resultados na hora</p>
        <a
          href="/comprar?produto=nome_bebe"
          class="block w-full text-center bg-[#D4AF37] text-[#1A1A1A] font-bold text-lg px-10 py-4 rounded-xl hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-xl shadow-[#D4AF37]/20"
        >
          Escolher o Nome do Meu Bebê →
        </a>
        <div class="flex items-center justify-center gap-6 mt-5 flex-wrap">
          <p class="text-gray-600 text-xs">🔒 Pagamento seguro via Stripe</p>
          <p class="text-gray-600 text-xs">🛡 Garantia de 7 dias</p>
          <p class="text-gray-600 text-xs">⚡ Acesso imediato</p>
        </div>
      </div>
    </section>

  </main>

  <LandingFooter client:visible />
</LandingLayout>
