---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppLayout from '../../layouts/AppLayout.astro';
import { FAQSection } from '../../frontend/components/landing/FAQSection';
import type { FaqItemProps } from '../../frontend/components/landing/FAQSection';
import { SupportForm } from '../../frontend/components/support/SupportForm';
import { LandingHeader } from '../../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../../frontend/components/landing/LandingFooter';
import { getFaqs } from '../../backend/notion/faqs';

const user = Astro.locals.user;

let faqItems: FaqItemProps[] = [];
try {
  faqItems = await getFaqs();
} catch (err) {
  console.warn('[suporte] Falha ao carregar FAQs do Notion — usando fallback:', err);
}
---

{user ? (
  <AppLayout title="Suporte">
    <div class="max-w-3xl mx-auto space-y-8">
      <div>
        <h1 class="font-cinzel text-3xl font-bold text-white mb-1">Central de Suporte</h1>
        <p class="text-gray-400">Encontre respostas ou entre em contato com nossa equipe.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <a
          href="mailto:suporte@nomemagnetico.com.br"
          class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 hover:border-[#D4AF37]/40 transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl mb-3">✉️</div>
          <h3 class="font-cinzel text-lg font-bold text-white mb-2">Email</h3>
          <p class="text-gray-400 text-sm">suporte@nomemagnetico.com.br</p>
          <p class="text-gray-600 text-xs mt-2">Resposta em até 24h</p>
        </a>

        <SupportForm
          userEmail={user.email ?? ''}
          userName={user.user_metadata?.full_name ?? ''}
          client:visible
        />
      </div>

      <FAQSection items={faqItems} client:visible />
    </div>
  </AppLayout>
) : (
  <BaseLayout title="Suporte">
    <LandingHeader client:load />
    <div class="pt-24">
      <div class="max-w-3xl mx-auto px-4 py-16">
        <div class="text-center mb-12">
          <h1 class="font-cinzel text-4xl font-bold text-white mb-3">Central de Suporte</h1>
          <p class="text-gray-400">Encontre respostas ou entre em contato com nossa equipe.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 mb-16">
          <a
            href="mailto:suporte@nomemagnetico.com.br"
            class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 hover:border-[#D4AF37]/40 transition-all duration-300 hover:scale-[1.02]"
          >
            <div class="text-3xl mb-3">✉️</div>
            <h3 class="font-cinzel text-lg font-bold text-white mb-2">Email</h3>
            <p class="text-gray-400 text-sm">suporte@nomemagnetico.com.br</p>
            <p class="text-gray-600 text-xs mt-2">Resposta em até 24h</p>
          </a>

          <SupportForm client:visible />
        </div>
      </div>

      <FAQSection items={faqItems} client:visible />
      <LandingFooter client:visible />
    </div>
  </BaseLayout>
)}
