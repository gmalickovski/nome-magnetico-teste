---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { PublicAnalysisForm } from '../frontend/components/landing/PublicAnalysisForm';

const user = Astro.locals.user;

const REDIRECT_URL = '/app/analise-gratuita';
const LOGIN_URL = `/auth/login?redirect=${encodeURIComponent(REDIRECT_URL)}`;
---

<LandingLayout
  title="Análise Gratuita do Seu Nome de Nascimento | Nome Magnético"
  description="Descubra os bloqueios energéticos, lições kármicas e tendências ocultas do seu nome. Análise completa com os 4 triângulos numerológicos — gratuita, sem limite de tempo."
  keywords="análise gratuita nome, bloqueios energéticos nome, numerologia gratuita, lições kármicas, triângulos numerológicos, numerologia cabalística"
>
  <link rel="canonical" href="https://nomemagnetico.com.br/analise-gratuita" />

  <LandingHeader client:load />

  <main class="min-h-screen bg-[#111111] pt-20 pb-24">

    <!-- HERO (centralizado, coluna única) -->
    <section class="max-w-2xl mx-auto px-4 pt-16 pb-10 text-center">

      <div class="inline-flex items-center gap-2 bg-[#d7c6ff]/10 border border-[#d7c6ff]/30 rounded-full px-5 py-2 mb-8">
        <span class="text-[#d7c6ff] text-xs" aria-hidden="true">✦</span>
        <span class="text-[#d7c6ff] text-sm font-medium tracking-wide">Análise Gratuita — Uma por Conta</span>
        <span class="text-[#d7c6ff] text-xs" aria-hidden="true">✦</span>
      </div>

      <h1 class="font-cinzel text-4xl sm:text-5xl font-bold text-[#e5e2e1] mb-5 leading-tight">
        Descubra a<br/>
        <span style="background: linear-gradient(135deg, #2DD4BF, #0D9488, #0F766E); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Frequência do Seu Nome
        </span>
      </h1>

      <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8">
        Calcule agora os bloqueios energéticos, lições kármicas e os 5 números principais
        do seu nome de nascimento — sem precisar criar conta.
      </p>

      <!-- Bullets -->
      <ul class="flex flex-col sm:flex-row sm:flex-wrap items-center sm:justify-center gap-x-6 gap-y-2 mb-8">
        {[
          'Análise instantânea e gratuita',
          '4 triângulos numerológicos cabalísticos',
          'PDF completo após criar conta (grátis)',
        ].map(item => (
          <li class="flex items-center gap-2 text-gray-400 text-sm">
            <span class="text-[#2DD4BF] text-xs">✦</span>
            {item}
          </li>
        ))}
      </ul>
    </section>

    <!-- FORMULÁRIO / RESULTADO — largura completa no desktop -->
    <section class="max-w-4xl mx-auto px-4 pb-4">
      <PublicAnalysisForm isLoggedIn={!!user} client:load />
    </section>

    <!-- O QUE A ANÁLISE REVELA -->
    <section class="max-w-4xl mx-auto px-4 py-16">
      <h2 class="font-cinzel text-2xl md:text-3xl font-bold text-center text-white mb-12">
        O Que Sua Análise Vai Revelar
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: '🔺', title: '4 Triângulos Numerológicos', desc: 'Triângulo da Vida, Pessoal, Social e do Destino — cada um revela uma dimensão diferente da influência do seu nome.' },
          { icon: '⚡', title: 'Bloqueios Energéticos', desc: 'Sequências repetidas nos triângulos que criam padrões de travamento — identificados com precisão matemática.' },
          { icon: '🌀', title: 'Lições Kármicas', desc: 'Números ausentes no seu nome revelam qualidades que você veio desenvolver nesta encarnação.' },
          { icon: '📊', title: 'Tendências Ocultas', desc: 'Números que aparecem em excesso no seu nome, revelando qualidades hiperativas que podem gerar desequilíbrio.' },
          { icon: '🔢', title: '5 Números Principais', desc: 'Expressão, Destino, Motivação, Missão e Personalidade — o mapa vibracional completo do seu nome.' },
          { icon: '📄', title: 'Relatório em PDF', desc: 'Baixe sua análise completa em PDF com todos os dados, acesso permanente em "Minhas Análises".' },
        ].map(item => (
          <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6">
            <div class="text-2xl mb-3">{item.icon}</div>
            <h3 class="font-cinzel text-base font-bold text-white mb-2">{item.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

  </main>

  <LandingFooter client:load />
</LandingLayout>
