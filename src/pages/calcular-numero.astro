---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { CalculadoraGratis } from '../frontend/components/landing/CalculadoraGratis';

const schemaWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Teste de Bloqueios Numerológicos — Nome Magnético',
  url: 'https://nomemagnetico.com.br/calcular-numero',
  description: 'Descubra gratuitamente se seu nome carrega bloqueios energéticos na numerologia cabalística. Informe seu nome completo e data de nascimento.',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web',
  inLanguage: 'pt-BR',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'BRL',
  },
};
---

<LandingLayout
  title="Teste de Bloqueios do Seu Nome — Grátis | Nome Magnético"
  description="Descubra se seu nome carrega bloqueios energéticos que travam seu sucesso, relacionamentos e prosperidade. Teste gratuito de numerologia cabalística."
  keywords="teste de bloqueios energéticos, bloqueios no nome, numerologia gratuita, número de expressão, calcular número nome, numerologia cabalística grátis, frequência vibracional nome"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebApp)} />

  <LandingHeader client:load />

  <main class="min-h-screen bg-[#111111] pt-20 pb-16">
    <div class="max-w-2xl mx-auto px-4">

      {/* Header da página */}
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-full px-4 py-1.5 mb-6">
          <span class="text-[#D4AF37] text-xs" aria-hidden="true">✦</span>
          <span class="text-[#D4AF37] text-sm font-medium">Diagnóstico Gratuito</span>
          <span class="text-[#D4AF37] text-xs" aria-hidden="true">✦</span>
        </div>

        <h1 class="font-cinzel text-3xl md:text-4xl font-bold text-[#e5e2e1] mb-4 leading-tight">
          Teste de Bloqueios<br/>
          <span style="background: linear-gradient(135deg, #D4AF37, #E8C84A, #B8960E); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            do Seu Nome
          </span>
        </h1>
        <p class="text-gray-400 text-base md:text-lg max-w-xl mx-auto leading-relaxed">
          Descubra se seu nome carrega bloqueios energéticos que criam padrões invisíveis de travamento — no sucesso, nos relacionamentos e na prosperidade.
        </p>
        <p class="text-gray-600 text-sm mt-3">87% dos nomes analisados têm ao menos 1 bloqueio ativo</p>
      </div>

      {/* Bloco educativo — foco em bloqueios */}
      <div class="grid md:grid-cols-3 gap-4 mb-12">
        <div class="bg-white/3 rounded-2xl p-5">
          <div class="text-amber-400 text-xl mb-3" aria-hidden="true">⚠</div>
          <h3 class="text-white font-medium text-sm mb-2">O que são bloqueios</h3>
          <p class="text-gray-500 text-xs leading-relaxed">
            Sequências numéricas repetidas nos triângulos cabalísticos do nome que criam padrões de resistência e limitação em áreas específicas da vida.
          </p>
        </div>
        <div class="bg-white/3 rounded-2xl p-5">
          <div class="text-[#D4AF37] text-xl mb-3" aria-hidden="true">◈</div>
          <h3 class="text-white font-medium text-sm mb-2">Como são detectados</h3>
          <p class="text-gray-500 text-xs leading-relaxed">
            Calculamos os 4 triângulos cabalísticos do seu nome — Vida, Pessoal, Social e Destino — e identificamos repetições que formam bloqueios energéticos.
          </p>
        </div>
        <div class="bg-white/3 rounded-2xl p-5">
          <div class="text-[#D4AF37] text-xl mb-3" aria-hidden="true">✦</div>
          <h3 class="text-white font-medium text-sm mb-2">O que fazer</h3>
          <p class="text-gray-500 text-xs leading-relaxed">
            Uma pequena variação do nome — mantendo identidade e pronúncia — pode eliminar os bloqueios e criar harmonia com seus números de Expressão e Destino.
          </p>
        </div>
      </div>

      {/* Formulário */}
      <div class="bg-white/4 border border-white/8 rounded-2xl p-8 shadow-2xl shadow-black/50">
        <h2 class="font-cinzel text-xl font-bold text-white mb-2 text-center">Detectar Bloqueios — Gratuito</h2>
        <p class="text-gray-500 text-sm text-center mb-8">Sem cadastro. Resultado em segundos.</p>

        <CalculadoraGratis client:load />
      </div>

      {/* Aviso sobre análise completa */}
      <div class="mt-8 text-center">
        <p class="text-gray-600 text-xs leading-relaxed max-w-md mx-auto">
          Este teste mostra os bloqueios do Triângulo da Vida e os números de Expressão e Destino.
          A análise completa inclui os 4 Triângulos Cabalísticos, Lições Kármicas, Tendências Ocultas
          e 3 variações harmonizadas do seu nome.
        </p>
      </div>

    </div>
  </main>

  <LandingFooter client:visible />
</LandingLayout>
