---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../backend/db/supabase';
import { getMonthlyUsageStats, getAllTimeUsageStats } from '../../backend/ai/usage-stats';
import { getRevenueStats } from '../../backend/db/subscriptions';

const [
  { count: totalUsers },
  { count: totalAnalyses },
  { data: activeSubs },
  aiMonthlyStats,
  aiAllTimeCostUsd
] = await Promise.all([
  supabase.from('profiles').select('*', { count: 'exact', head: true }),
  supabase.from('analyses').select('*', { count: 'exact', head: true }),
  supabase.from('subscriptions').select('user_id, product_type').gt('ends_at', new Date().toISOString()),
  getMonthlyUsageStats(),
  getAllTimeUsageStats()
]);

const revenue = await getRevenueStats(aiAllTimeCostUsd);

const activeUsersCount = new Set((activeSubs || []).map(s => s.user_id)).size;
const productCounts: Record<string, number> = {
  nome_magnetico: 0,
  nome_bebe: 0,
  nome_empresa: 0
};
(activeSubs || []).forEach(sub => {
  if (productCounts[sub.product_type] !== undefined) {
    productCounts[sub.product_type]++;
  }
});

const fmtCurrency = (v: number, currency: string = 'BRL') => 
  v.toLocaleString('pt-BR', { style: 'currency', currency, maximumFractionDigits: 0 });

const formatNumber = (num: number) => {
  if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
  if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
  return num.toString();
};

const userCards = [
  { label: 'Total de Usuários', value: totalUsers ?? 0, icon: 'M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z', color: 'text-gray-400' },
  { label: 'Nome Social', value: productCounts.nome_magnetico, icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', color: 'text-[#D4AF37]' },
  { label: 'Nome de Bebê', value: productCounts.nome_bebe, icon: 'M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', color: 'text-purple-400' },
  { label: 'Nome de Empresa', value: productCounts.nome_empresa, icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', color: 'text-blue-400' },
  { label: 'Análises Realizadas', value: formatNumber(totalAnalyses ?? 0), icon: 'M5.64 16.36a9 9 0 1112.72 0l-1.41-1.42a7 7 0 10-9.9 0l-1.41 1.42zM12 10a2 2 0 110-4 2 2 0 010 4z M12 14l-4 4h8l-4-4z', color: 'text-indigo-300' },
];

const financeCards = [
  { label: 'Faturamento Bruto', value: fmtCurrency(revenue.grossBRL), icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', color: 'text-gray-400' },
  { label: 'Faturamento Líquido', value: fmtCurrency(revenue.netBRL), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', color: 'text-[#f2ca50]' },
  { label: 'Média Mensal Líquida', value: fmtCurrency(revenue.avgMonthlyNetBRL), icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', color: 'text-emerald-400' },
];

const aiCards = [
  { label: 'Requisições Solicitadas (Mês)', value: formatNumber(aiMonthlyStats.totalRequests), icon: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'text-purple-300' },
  { label: 'Tokens IA Processados (Mês)', value: formatNumber(aiMonthlyStats.totalTokens), icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', color: 'text-gray-300' },
  { label: 'Custo IA Gerado (Mês)', value: fmtCurrency(aiMonthlyStats.estimatedCostUsd, 'USD'), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', color: 'text-red-400' },
];

---

<AdminLayout title="Dashboard">
  <div class="flex flex-col items-center mb-10 mt-4">
    <h1 class="font-cinzel text-3xl md:text-4xl font-normal text-gray-200 tracking-wide mb-2 text-center">
      PORTAL DO ORÁCULO
    </h1>
    <p class="text-xs tracking-[0.2em] text-gray-500 uppercase text-center">
      Painel de Controle Administrativo
    </p>
  </div>

  <!-- SEÇÃO: USUÁRIOS E PRODUTOS -->
  <div class="mb-3">
    <h2 class="font-cinzel text-[#f2ca50] text-sm md:text-base tracking-[0.3em] uppercase">
      Usuários & Produtos
    </h2>
  </div>
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4 mb-8">
    {userCards.map(card => (
      <div class="bg-[#1a1a1a] border border-white/5 rounded-2xl p-4 md:p-5 flex flex-col justify-center">
        <div class={`${card.color} mb-2`}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d={card.icon}></path>
          </svg>
        </div>
        <div class="font-cinzel text-xl md:text-2xl text-white break-words">{card.value}</div>
        <div class="text-gray-400 text-[10px] md:text-xs tracking-wider mt-1">{card.label}</div>
      </div>
    ))}
  </div>

  <!-- SEÇÃO: FINANCEIRO -->
  <div class="mb-3">
    <h2 class="font-cinzel text-[#f2ca50] text-sm md:text-base tracking-[0.3em] uppercase">
      Financeiro
    </h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8">
    {financeCards.map(card => (
      <div class="bg-[#1a1a1a] border border-white/5 rounded-2xl p-4 md:p-5 flex flex-col justify-center">
        <div class={`${card.color} mb-2`}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d={card.icon}></path>
          </svg>
        </div>
        <div class="font-cinzel text-xl md:text-2xl text-white break-words">{card.value}</div>
        <div class="text-gray-400 text-[10px] md:text-xs tracking-wider mt-1">{card.label}</div>
      </div>
    ))}
  </div>

  <!-- SEÇÃO: DESEMPENHO E IA -->
  <div class="mb-3">
    <h2 class="font-cinzel text-[#f2ca50] text-sm md:text-base tracking-[0.3em] uppercase">
      Desempenho & Inteligência Artificial
    </h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-12">
    {aiCards.map(card => (
      <div class="bg-[#1a1a1a] border border-white/5 rounded-2xl p-4 md:p-5 flex flex-col justify-center">
        <div class={`${card.color} mb-2`}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d={card.icon}></path>
          </svg>
        </div>
        <div class="font-cinzel text-xl md:text-2xl text-white break-words">{card.value}</div>
        <div class="text-gray-400 text-[10px] md:text-xs tracking-wider mt-1">{card.label}</div>
      </div>
    ))}
  </div>

  <div class="mb-6 flex justify-center md:justify-start">
    <h2 class="font-cinzel text-[#f2ca50] text-sm md:text-base tracking-[0.3em] uppercase">
      Rituais de Gestão
    </h2>
  </div>

  <div class="space-y-4 mb-10">
    <a href="/admin/usuarios" class="flex items-center justify-between bg-[#131313] hover:bg-[#1a1a1a] border border-white/5 transition-colors p-5 rounded-2xl group">
      <div class="flex items-center gap-4">
        <div class="bg-white/5 p-3 rounded-full text-[#c084fc] group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
        </div>
        <span class="text-gray-200 font-medium">Gerenciar Usuários</span>
      </div>
      <svg class="w-5 h-5 text-gray-600 group-hover:text-[#D4AF37] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </a>



    <a href="/admin/ia" class="flex items-center justify-between bg-[#131313] hover:bg-[#1a1a1a] border border-white/5 transition-colors p-5 rounded-2xl group">
      <div class="flex items-center gap-4">
        <div class="bg-white/5 p-3 rounded-full text-gray-400 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
        </div>
        <span class="text-gray-200 font-medium">Exportar Relatórios / Logs IA</span>
      </div>
      <svg class="w-5 h-5 text-gray-600 group-hover:text-[#D4AF37] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </a>
  </div>

  <div class="bg-[#1a1a1a] border border-[#2a2a2a] rounded-2xl p-5 flex items-center gap-4">
    <div class="relative flex h-3 w-3">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
    </div>
    <div>
      <h3 class="text-[#c084fc] text-sm font-semibold tracking-wide uppercase">Sistemas Estáveis</h3>
      <p class="text-gray-500 text-xs mt-0.5">Conexão com Banco de Dados e Serviços IA ativa</p>
    </div>
  </div>

</AdminLayout>
