---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../backend/db/supabase';
import { getMonthlyUsageStats } from '../../backend/ai/usage-stats';
import { getRevenueStats } from '../../backend/db/subscriptions';

const [
  { count: totalUsers },
  { count: totalAnalyses },
  { count: totalSubscriptions },
  aiStats,
] = await Promise.all([
  supabase.from('profiles').select('*', { count: 'exact', head: true }),
  supabase.from('analyses').select('*', { count: 'exact', head: true }),
  supabase.from('subscriptions').select('*', { count: 'exact', head: true }).gt('ends_at', new Date().toISOString()),
  getMonthlyUsageStats(),
]);

const revenue = await getRevenueStats(aiStats.estimatedCostUsd);

const fmt = (v: number) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
---

<AdminLayout title="Dashboard">
  <!-- Linha 1: Cards Operacionais -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-6">
    {[
      { label: 'Usuários Totais', value: totalUsers ?? 0, icon: '👥' },
      { label: 'Análises Realizadas', value: totalAnalyses ?? 0, icon: '📊' },
      { label: 'Assinaturas Ativas', value: totalSubscriptions ?? 0, icon: '✅' },
      { label: 'Custo IA / Mês', value: `$${aiStats.estimatedCostUsd.toFixed(4)}`, icon: '💵' },
    ].map(m => (
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
        <div class="text-3xl mb-2">{m.icon}</div>
        <div class="font-cinzel text-3xl font-bold text-[#D4AF37]">{m.value}</div>
        <div class="text-gray-500 text-sm mt-1">{m.label}</div>
      </div>
    ))}
  </div>

  <!-- Linha 2: Cards Financeiros -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 text-center">
      <div class="text-3xl mb-2">💰</div>
      <div class="font-cinzel text-2xl font-bold text-[#D4AF37]">{fmt(revenue.grossBRL)}</div>
      <div class="text-gray-500 text-sm mt-1">Receita Bruta</div>
      <div class="text-gray-600 text-xs mt-2">{revenue.totalTransactions} transação(ões)</div>
    </div>
    <div class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 text-center">
      <div class="text-3xl mb-2">💳</div>
      <div class="font-cinzel text-2xl font-bold text-emerald-400">{fmt(revenue.netBRL)}</div>
      <div class="text-gray-500 text-sm mt-1">Receita Líquida</div>
      <div class="text-gray-600 text-xs mt-2">−{fmt(revenue.stripeFeeBRL)} Stripe · −{fmt(revenue.iaCostBRL)} IA</div>
    </div>
    <div class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 text-center">
      <div class="text-3xl mb-2">📈</div>
      <div class="font-cinzel text-2xl font-bold text-emerald-400">{fmt(revenue.avgMonthlyNetBRL)}</div>
      <div class="text-gray-500 text-sm mt-1">Média Mensal Líquida</div>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
      <h3 class="font-cinzel text-lg font-bold text-gray-100 mb-4">Ações Rápidas</h3>
      <div class="space-y-2">
        <a href="/admin/usuarios" class="flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 transition-colors text-gray-400 hover:text-gray-200">
          👥 Gerenciar Usuários
        </a>
        <a href="/admin/ia" class="flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 transition-colors text-gray-400 hover:text-gray-200">
          🤖 Configurar IA
        </a>
      </div>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
      <h3 class="font-cinzel text-lg font-bold text-gray-100 mb-4">Status do Sistema</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-gray-400 text-sm">Supabase</span>
          <span class="bg-emerald-500/20 text-emerald-400 text-xs px-2 py-0.5 rounded-full">Online</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-gray-400 text-sm">APP_ENV</span>
          <span class="bg-blue-500/20 text-blue-400 text-xs px-2 py-0.5 rounded-full">{process.env.APP_ENV}</span>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
