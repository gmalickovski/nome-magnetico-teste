---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listUsers } from '../../backend/db/users';
import { getActiveProductsPerUser } from '../../backend/db/subscriptions';

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const { users, total } = await listUsers(page, 20);
const totalPages = Math.ceil(total / 20);

const userIds = users.map(u => u.id);
const activeProducts = await getActiveProductsPerUser(userIds);

const PRODUCT_BADGES: Record<string, { label: string; style: string }> = {
  nome_magnetico: { label: 'NM', style: 'bg-[#D4AF37]/20 text-[#D4AF37] border border-[#D4AF37]/30' },
  nome_bebe:      { label: 'Bebê', style: 'bg-purple-500/20 text-purple-400 border border-purple-500/30' },
  nome_empresa:   { label: 'Empresa', style: 'bg-blue-500/20 text-blue-400 border border-blue-500/30' },
};
---

<AdminLayout title="Usuários">
  <div class="space-y-4">
    <p class="text-gray-400 text-sm">{total} usuário(s) cadastrado(s)</p>

    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="border-b border-white/10">
          <tr>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Email</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Nome</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Role</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Produtos</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Cadastro</th>
          </tr>
        </thead>
        <tbody>
          {users.map(user => {
            const nomeDisplay = user.nome || '—';
            const roleClass = user.role === 'admin'
              ? 'px-2 py-0.5 rounded-full text-xs font-medium bg-[#D4AF37]/20 text-[#D4AF37]'
              : 'px-2 py-0.5 rounded-full text-xs font-medium bg-gray-500/20 text-gray-400';
            const products = activeProducts.get(user.id) ?? [];
            return (
              <tr class="border-b border-white/5 hover:bg-white/3">
                <td class="px-5 py-3 text-gray-200">{user.email}</td>
                <td class="px-5 py-3 text-gray-400">{nomeDisplay}</td>
                <td class="px-5 py-3">
                  <span class={roleClass}>{user.role}</span>
                </td>
                <td class="px-5 py-3">
                  <div class="flex flex-wrap gap-1">
                    {products.length === 0
                      ? <span class="px-2 py-0.5 rounded-full text-xs bg-gray-700/40 text-gray-500">—</span>
                      : products.map(p => {
                          const badge = PRODUCT_BADGES[p] ?? { label: p, style: 'bg-gray-500/20 text-gray-400' };
                          return <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${badge.style}`}>{badge.label}</span>;
                        })
                    }
                  </div>
                </td>
                <td class="px-5 py-3 text-gray-500 text-xs">
                  {new Date(user.created_at).toLocaleDateString('pt-BR')}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    {totalPages > 1 && (
      <div class="flex items-center justify-center gap-2">
        {page > 1 && (
          <a href={`?page=${page - 1}`} class="px-3 py-1.5 rounded-lg border border-white/10 text-gray-400 hover:text-gray-200 text-sm">← Anterior</a>
        )}
        <span class="text-gray-500 text-sm">Página {page} de {totalPages}</span>
        {page < totalPages && (
          <a href={`?page=${page + 1}`} class="px-3 py-1.5 rounded-lg border border-white/10 text-gray-400 hover:text-gray-200 text-sm">Próxima →</a>
        )}
      </div>
    )}
  </div>
</AdminLayout>
