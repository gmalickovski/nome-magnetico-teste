---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../backend/db/supabase';

const { data: configs } = await supabase
  .schema('nome_magnetico')
  .from('ai_config')
  .select('*')
  .order('task');
---

<AdminLayout title="Configuração de IA">
  <div class="space-y-6">
    <p class="text-gray-400">
      Configure qual provedor e modelo de IA será usado para cada tarefa. As mudanças entram em vigor imediatamente.
    </p>

    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="border-b border-white/10">
          <tr>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Tarefa</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Provedor</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Modelo</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Temp.</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Tokens</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">Status</th>
          </tr>
        </thead>
        <tbody>
          {(configs ?? []).map(config => (
            <tr class="border-b border-white/5 hover:bg-white/3">
              <td class="px-5 py-3 text-gray-200 font-medium capitalize">{config.task}</td>
              <td class="px-5 py-3">
                <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${
                  config.provider === 'groq' ? 'bg-orange-500/20 text-orange-400' :
                  config.provider === 'claude' ? 'bg-purple-500/20 text-purple-400' :
                  'bg-blue-500/20 text-blue-400'
                }`}>{config.provider}</span>
              </td>
              <td class="px-5 py-3 text-gray-400 font-mono text-xs">{config.model}</td>
              <td class="px-5 py-3 text-gray-400">{config.temperature}</td>
              <td class="px-5 py-3 text-gray-400">{config.max_tokens}</td>
              <td class="px-5 py-3">
                <span class={`px-2 py-0.5 rounded-full text-xs ${
                  config.is_active ? 'bg-emerald-500/20 text-emerald-400' : 'bg-gray-500/20 text-gray-500'
                }`}>{config.is_active ? 'Ativo' : 'Inativo'}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-xl p-4 text-sm text-gray-400">
      <strong class="text-[#D4AF37]">Dica:</strong> Para alterar a configuração, edite diretamente na tabela <code class="text-gray-300">nome_magnetico.ai_config</code> no Supabase Dashboard.
      Em breve haverá interface de edição aqui.
    </div>
  </div>
</AdminLayout>
