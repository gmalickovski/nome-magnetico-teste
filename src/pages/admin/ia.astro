---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../backend/db/supabase';
import {
  getMonthlyUsageStats,
  getDetailedUsageLogs,
  getCostProjections,
} from '../../backend/ai/usage-stats';
import AIConfigEditor from '../../frontend/components/admin/AIConfigEditor';

const [{ data: configs }, stats, logs] = await Promise.all([
  supabase.from('ai_config').select('*').order('task'),
  getMonthlyUsageStats(),
  getDetailedUsageLogs(60),
]);

const projections = getCostProjections(stats);

const userLogs = logs.filter(l => !l.isSystem);
const systemLogs = logs.filter(l => l.isSystem);
const userCostMonth = userLogs.reduce((s, l) => s + l.estimatedCostUsd, 0);
const systemCostMonth = systemLogs.reduce((s, l) => s + l.estimatedCostUsd, 0);

const usageCards = [
  {
    icon: '📊',
    label: 'Requisições este mês',
    value: stats.totalRequests.toLocaleString('pt-BR'),
  },
  {
    icon: '🔤',
    label: 'Tokens totais este mês',
    value: stats.totalTokens.toLocaleString('pt-BR'),
  },
  {
    icon: '💵',
    label: 'Custo real este mês (USD)',
    value: `$${stats.estimatedCostUsd.toFixed(4)}`,
  },
  {
    icon: '📈',
    label: 'Custo médio / requisição',
    value: stats.totalRequests > 0 ? `$${stats.avgCostPerRequest.toFixed(6)}` : '—',
  },
  {
    icon: '🗓️',
    label: `Projeção mês completo (${projections.daysElapsed}/${projections.daysInMonth} dias)`,
    value: `$${projections.projectedMonthlyUsd.toFixed(4)}`,
  },
  {
    icon: '📅',
    label: 'Projeção anual (USD)',
    value: `$${projections.projectedAnnualUsd.toFixed(2)}`,
  },
];

function formatDate(d: string) {
  return new Date(d).toLocaleString('pt-BR', {
    day: '2-digit', month: '2-digit',
    hour: '2-digit', minute: '2-digit',
  });
}
---

<AdminLayout title="Configuração de IA">
  <div class="space-y-8">
    <p class="text-gray-400">
      Configure qual provedor e modelo de IA será usado para cada tarefa. As mudanças entram em vigor imediatamente.
    </p>

    <!-- Cards de uso mensal + projeções -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      {usageCards.map(card => (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-3 sm:p-5 text-center flex flex-col justify-center">
          <div class="text-2xl mb-1 sm:mb-2">{card.icon}</div>
          <div class="font-cinzel text-lg sm:text-xl font-bold text-[#D4AF37] break-words">{card.value}</div>
          <div class="text-gray-500 text-[10px] sm:text-xs mt-1">{card.label}</div>
        </div>
      ))}
    </div>

    <!-- Breakdown por provedor -->
    {stats.byProvider.length > 0 && (
      <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden">
        <div class="px-5 py-3 border-b border-white/10">
          <h3 class="text-sm font-medium text-gray-300">Uso por Provedor — Mês Atual</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-white/10">
              <tr>
                <th class="text-left px-5 py-3 text-gray-400 font-medium whitespace-nowrap">Provedor</th>
                <th class="text-right px-5 py-3 text-gray-400 font-medium whitespace-nowrap">Requisições</th>
                <th class="text-right px-5 py-3 text-gray-400 font-medium whitespace-nowrap">Tokens Input</th>
                <th class="text-right px-5 py-3 text-gray-400 font-medium whitespace-nowrap">Tokens Output</th>
                <th class="text-right px-5 py-3 text-gray-400 font-medium whitespace-nowrap">Custo (USD)</th>
              </tr>
            </thead>
            <tbody>
              {stats.byProvider.map(row => (
                <tr class="border-b border-white/5 hover:bg-white/3">
                  <td class="px-5 py-3 whitespace-nowrap">
                    <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${
                      row.provider === 'groq' ? 'bg-orange-500/20 text-orange-400' :
                      row.provider === 'claude' ? 'bg-purple-500/20 text-purple-400' :
                      'bg-blue-500/20 text-blue-400'
                    }`}>{row.provider}</span>
                  </td>
                  <td class="px-5 py-3 text-gray-400 text-right whitespace-nowrap">{row.requests.toLocaleString('pt-BR')}</td>
                  <td class="px-5 py-3 text-gray-400 text-right whitespace-nowrap">{row.tokensInput.toLocaleString('pt-BR')}</td>
                  <td class="px-5 py-3 text-gray-400 text-right whitespace-nowrap">{row.tokensOutput.toLocaleString('pt-BR')}</td>
                  <td class="px-5 py-3 text-[#D4AF37] text-right font-mono text-xs whitespace-nowrap">${row.estimatedCostUsd.toFixed(4)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- Logs de uso detalhados (últimas 60 requisições) -->
    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden">
      <div class="px-5 py-3 border-b border-white/10 flex items-center justify-between gap-4 flex-wrap">
        <h3 class="text-sm font-medium text-gray-300">Histórico de Requisições à IA</h3>
        <div class="flex gap-4 text-xs text-gray-500">
          <span>Usuários: <span class="text-gray-300">${userCostMonth.toFixed(4)}</span></span>
          <span>Sistema: <span class="text-gray-300">${systemCostMonth.toFixed(4)}</span></span>
          <span class="text-[#D4AF37] font-medium">Total: ${stats.estimatedCostUsd.toFixed(4)}</span>
        </div>
      </div>
      {logs.length === 0 ? (
        <p class="px-5 py-6 text-gray-500 text-sm">Nenhuma requisição registrada ainda.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-white/10">
              <tr>
                <th class="text-left px-4 py-3 text-gray-400 font-medium whitespace-nowrap">Data</th>
                <th class="text-left px-4 py-3 text-gray-400 font-medium whitespace-nowrap">Origem</th>
                <th class="text-left px-4 py-3 text-gray-400 font-medium whitespace-nowrap">Tarefa</th>
                <th class="text-left px-4 py-3 text-gray-400 font-medium whitespace-nowrap">Provedor / Modelo</th>
                <th class="text-right px-4 py-3 text-gray-400 font-medium whitespace-nowrap">Tokens</th>
                <th class="text-right px-4 py-3 text-gray-400 font-medium whitespace-nowrap">Custo (USD)</th>
              </tr>
            </thead>
            <tbody>
              {logs.map(log => (
                <tr class="border-b border-white/5 hover:bg-white/3">
                  <td class="px-4 py-2.5 text-gray-500 text-xs whitespace-nowrap">{formatDate(log.createdAt)}</td>
                  <td class="px-4 py-2.5 whitespace-nowrap">
                    <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${
                      log.isSystem
                        ? 'bg-purple-500/20 text-purple-400'
                        : 'bg-emerald-500/20 text-emerald-400'
                    }`}>
                      {log.isSystem ? 'sistema' : 'usuário'}
                    </span>
                  </td>
                  <td class="px-4 py-2.5 text-gray-400 text-xs whitespace-nowrap">{log.task}</td>
                  <td class="px-4 py-2.5 whitespace-nowrap">
                    <span class={`px-2 py-0.5 rounded-full text-xs font-medium mr-1 ${
                      log.provider === 'groq' ? 'bg-orange-500/20 text-orange-400' :
                      log.provider === 'claude' ? 'bg-purple-500/20 text-purple-400' :
                      'bg-blue-500/20 text-blue-400'
                    }`}>{log.provider}</span>
                    <span class="text-gray-500 text-xs font-mono">{log.model.replace('claude-', '').replace('-20251001', '')}</span>
                  </td>
                  <td class="px-4 py-2.5 text-gray-400 text-right text-xs whitespace-nowrap font-mono">
                    {log.tokensTotal.toLocaleString('pt-BR')}
                  </td>
                  <td class="px-4 py-2.5 text-right whitespace-nowrap">
                    <span class={`font-mono text-xs ${log.estimatedCostUsd > 0.001 ? 'text-[#D4AF37]' : 'text-gray-500'}`}>
                      ${log.estimatedCostUsd.toFixed(5)}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
            <tfoot class="border-t border-white/10 bg-white/3">
              <tr>
                <td colspan="5" class="px-4 py-3 text-gray-400 text-xs text-right font-medium">Total (últimas {logs.length} requisições):</td>
                <td class="px-4 py-3 text-right">
                  <span class="font-mono text-xs font-bold text-[#D4AF37]">
                    ${logs.reduce((s, l) => s + l.estimatedCostUsd, 0).toFixed(4)}
                  </span>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      )}
    </div>

    <!-- Editor de configuração -->
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
      <h3 class="font-cinzel text-lg font-bold text-gray-100 mb-6">Editor de Configuração</h3>
      <AIConfigEditor
        currentConfigs={configs ?? []}
        client:load
      />
    </div>
  </div>
</AdminLayout>
