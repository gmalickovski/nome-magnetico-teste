---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { HeroSection } from '../frontend/components/landing/HeroSection';
import { HowItWorksSection } from '../frontend/components/landing/HowItWorksSection';
import { ProductsSection } from '../frontend/components/landing/ProductsSection';
import { TesteBloqueio } from '../frontend/components/landing/TesteBloqueio';
import { PricingSection } from '../frontend/components/landing/PricingSection';
import { PromoBanner } from '../frontend/components/landing/PromoBanner';
import { FAQSection } from '../frontend/components/landing/FAQSection';
import type { FaqItemProps } from '../frontend/components/landing/FAQSection';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { getSupabaseFaqs } from '../backend/faqs/getSupabaseFaqs';
import { getHqPricesAndPromo } from '../backend/payments/prices';
import type { PriceInfo, ActivePromotion } from '../backend/payments/prices';

let faqItems: FaqItemProps[] = [];
try {
  faqItems = await getSupabaseFaqs({ featuredOnly: true });
} catch (err) {
  console.warn('[index] Falha ao carregar FAQs do Supabase — usando fallback:', err);
}

let hqPrices: Record<string, PriceInfo> | undefined;
let promotion: ActivePromotion | null = null;
try {
  const result = await getHqPricesAndPromo();
  hqPrices = result.prices;
  promotion = result.promotion;
} catch (err) {
  console.warn('[index] Falha ao carregar preços/promoção do HQ — usando fallback:', err);
}
---

<LandingLayout
  title="Numerologia Cabalística do Seu Nome — Detecte Bloqueios e Encontre Seu Nome Magnético"
  description="Seu nome de nascimento carrega frequências que podem estar bloqueando sua carreira, relacionamentos e prosperidade. Faça a análise cabalística completa: mapa de 5 números, 4 triângulos e variações de nome harmonizado."
  keywords="numerologia cabalística, análise do nome numerologia, bloqueios energéticos nome, numerologia nome completo, mapa numerológico completo, nome social numerologia, mudar nome numerologia, nome sem bloqueios, análise vibracional gratuita nome, arquétipo junguiano nome, nome para bebê numerologia, nome empresarial numerologia"
>
  {promotion && <PromoBanner promotion={promotion} client:load />}
  <LandingHeader client:load />
  <HeroSection client:load />
  <HowItWorksSection client:visible />
  <ProductsSection client:visible />
  <TesteBloqueio client:visible />
  <PricingSection hqPrices={hqPrices} promotion={promotion} client:visible />
  <FAQSection items={faqItems} client:visible />
  <LandingFooter client:visible />
</LandingLayout>
