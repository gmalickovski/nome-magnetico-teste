---
import LandingLayout from '../layouts/LandingLayout.astro';
import { CheckoutFlow } from '../frontend/components/purchase/CheckoutFlow';
import { hasActiveSubscription } from '../backend/db/subscriptions';
import { createUserClient } from '../backend/db/supabase';
import { getHqPricesAndPromo } from '../backend/payments/prices';
import type { PriceInfo, ActivePromotion } from '../backend/payments/prices';

const user = Astro.locals.user;

// Admin: redirecionar direto para o app
if (user) {
  try {
    const client = createUserClient(Astro.locals.accessToken ?? '');
    const { data: profile } = await client
      .from('profiles').select('role').eq('id', user.id).single();
    if (profile?.role === 'admin') return Astro.redirect('/app');
  } catch {}
}

const produto = Astro.url.searchParams.get('produto') ?? '';
const produtosValidos = ['nome_social', 'nome_bebe', 'nome_empresa'] as const;
type ProductType = typeof produtosValidos[number];
const productType: ProductType | null = (produtosValidos as readonly string[]).includes(produto)
  ? (produto as ProductType)
  : null;

// isOwned só é relevante quando há produto específico
let isOwned = false;
if (user && productType) {
  isOwned = await hasActiveSubscription(user.id, productType);
}

// Preços e promoção via HQ
let hqPrices: Record<string, PriceInfo> | undefined;
let promotion: ActivePromotion | null = null;
try {
  const result = await getHqPricesAndPromo();
  hqPrices = result.prices;
  promotion = result.promotion;
} catch (err) {
  console.warn('[comprar] Falha ao carregar preços/promoção do HQ — usando fallback:', err);
}

const paymentLinks = {
  nome_social: '/auth/login?redirect=/comprar?produto=nome_social',
  nome_bebe:      '/auth/login?redirect=/comprar?produto=nome_bebe',
  nome_empresa:   '/auth/login?redirect=/comprar?produto=nome_empresa',
};
// BreadcrumbList para /comprar — melhora navegação no Google e AI Overviews
const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Início',
      item: 'https://nomemagnetico.com.br',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Planos de Análise Numerológica',
      item: 'https://nomemagnetico.com.br/comprar',
    },
  ],
};
---

<LandingLayout
  title="Planos de Análise Numerológica — Nome Magnético"
  description="Escolha sua análise de numerologia cabalística: Nome Social (R$ 97), Nome para Bebê (R$ 147) ou Nome Empresarial (R$ 197). Pagamento único, acesso imediato por 30 dias, PDF para download e garantia de 7 dias."
  keywords="comprar numerologia cabalística, planos numerologia, preço mapa numerológico, análise nome cabalística preço, numerologia nome completo comprar, mapa numerológico online, análise bloqueios energéticos nome"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <CheckoutFlow
    client:load
    productType={productType}
    isLoggedIn={!!user}
    isOwned={isOwned}
    paymentLinks={paymentLinks}
    hqPrices={hqPrices}
    promotion={promotion}
  />
</LandingLayout>
