---
import LandingLayout from '../layouts/LandingLayout.astro';
import { LandingHeader } from '../frontend/components/landing/LandingHeader';
import { LandingFooter } from '../frontend/components/landing/LandingFooter';
import { PublicContactForm } from '../frontend/components/support/PublicContactForm';
import { FAQSection } from '../frontend/components/landing/FAQSection';
import type { FaqItemProps } from '../frontend/components/landing/FAQSection';
import { getSupabaseFaqs } from '../backend/faqs/getSupabaseFaqs';

let faqItems: FaqItemProps[] = [];
try {
  faqItems = await getSupabaseFaqs();
} catch (err) {
  console.warn('[suporte] Falha ao carregar FAQs:', err);
}
---

<LandingLayout
  title="Suporte & Contato — Fale Conosco"
  description="Tire dúvidas sobre sua análise de numerologia cabalística. A equipe do Nome Magnético responde em até 24 horas úteis. Acesse nosso FAQ completo."
  keywords="suporte numerologia, dúvidas mapa numerológico, contato nome magnético, ajuda análise nome cabalística, FAQ numerologia"
  showChatwoot={true}
>
  <LandingHeader client:load />

  <main class="min-h-screen bg-[#111111] pt-28 pb-20 px-4">
    <div class="max-w-5xl mx-auto">

      <!-- Hero -->
      <div class="text-center mb-16">
        <p class="text-[#D4AF37] text-sm font-medium tracking-widest uppercase mb-4">Suporte</p>
        <h1 class="font-cinzel text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
          Como podemos ajudar?
        </h1>
        <p class="text-gray-400 text-lg max-w-xl mx-auto leading-relaxed">
          Nossa equipe responde em até <strong class="text-gray-300">24 horas úteis</strong>.
          Preencha o formulário ou fale diretamente pelo chat.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Coluna principal: formulário -->
        <div class="lg:col-span-2">
          <div class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6 md:p-10">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-xl bg-[#D4AF37]/10 flex items-center justify-center text-lg">✉</div>
              <div>
                <h2 class="font-cinzel text-xl font-bold text-white">Enviar Dúvida</h2>
                <p class="text-gray-500 text-sm">Resposta em até 24h úteis</p>
              </div>
            </div>
            <PublicContactForm client:visible />
          </div>
        </div>

        <!-- Coluna lateral: contatos e links -->
        <div class="flex flex-col gap-5">

          <!-- Email direto -->
          <div class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-[#D4AF37]/10 flex items-center justify-center text-lg mb-4">@</div>
            <h3 class="font-cinzel text-base font-bold text-white mb-1">Email Direto</h3>
            <p class="text-gray-500 text-sm mb-3">Para dúvidas urgentes ou críticas</p>
            <a
              href="mailto:suporte@nomemagnetico.com.br"
              class="text-[#D4AF37] hover:text-[#f2ca50] text-sm font-medium transition-colors break-all"
            >
              suporte@nomemagnetico.com.br
            </a>
          </div>

          <!-- Chat ao vivo -->
          <div class="bg-white/5 border border-[#D4AF37]/20 rounded-2xl p-6">
            <div class="w-10 h-10 rounded-xl bg-[#D4AF37]/10 flex items-center justify-center text-lg mb-4">💬</div>
            <h3 class="font-cinzel text-base font-bold text-white mb-1">Chat ao Vivo</h3>
            <p class="text-gray-500 text-sm mb-3">Disponível no horário comercial</p>
            <button
              onclick="window.$chatwoot?.toggle()"
              class="text-sm text-[#D4AF37] hover:text-[#f2ca50] font-medium transition-colors"
            >
              Abrir chat →
            </button>
          </div>

          <!-- Já é cliente -->
          <div class="bg-[#D4AF37]/5 border border-[#D4AF37]/30 rounded-2xl p-6">
            <h3 class="font-cinzel text-base font-bold text-[#D4AF37] mb-2">Já é cliente?</h3>
            <p class="text-gray-500 text-sm mb-4">
              Acesse a central de suporte completa com FAQ personalizado dentro da plataforma.
            </p>
            <a
              href="/app/suporte"
              class="inline-flex items-center gap-2 text-sm font-medium text-white bg-[#D4AF37]/20 hover:bg-[#D4AF37]/30 border border-[#D4AF37]/30 px-4 py-2 rounded-xl transition-colors"
            >
              Acessar Central de Suporte
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

        </div>
      </div>

    </div>
  </main>

  <FAQSection items={faqItems} client:visible />

  <LandingFooter client:visible />
</LandingLayout>
