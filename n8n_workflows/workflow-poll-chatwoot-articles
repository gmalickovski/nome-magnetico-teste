            },
            "id": "sup-002",
            "name": "Mapear Categoria",
            "type": "n8n-nodes-base.supabase",
            "typeVersion": 1,
            "position": [1040, 180],
            "credentials": {
                "supabaseApi": {
                    "id": "Q8FUTrO3QSkHxr8B",
                    "name": "Supabase Cloude - Nome Magnético"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Monta o objeto para upsert no Supabase\nconst article  = $('Verificar se Mudou').item.json;\nconst catRow   = $input.first().json ?? null;\n\nconst upsert = {\n  chatwoot_article_id: article.chatwoot_article_id,\n  question:            article.question,\n  answer_markdown:     article.answer_markdown,\n  is_active:           article.is_active,\n  updated_at:          new Date().toISOString(),\n};\n\nif (article.slug)             upsert.slug             = article.slug;\nif (article.meta_title)       upsert.meta_title        = article.meta_title;\nif (article.meta_description) upsert.meta_description  = article.meta_description;\nif (article.meta_tags)        upsert.meta_tags         = article.meta_tags;\nif (catRow?.id)               upsert.category_id       = catRow.id;\n\nreturn [{ json: upsert }];"
            },
