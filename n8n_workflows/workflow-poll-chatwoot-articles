            "name": "Buscar Artigos (pág 1)",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [-160, 300]
        },
        {
            "parameters": {
                "jsCode": "// Extrai array de artigos do payload Chatwoot\nconst payload = $input.first().json;\nconst articles = payload.payload ?? [];\n\nif (!articles.length) return [];\n\n// Retorna cada artigo como item separado\nreturn articles.map(a => ({\n  json: {\n    chatwoot_article_id: String(a.id),\n    question:            a.title ?? '',\n    answer_markdown:     a.content ?? '',\n    slug:                a.slug ?? null,\n    is_active:           a.status === 'published',\n    meta_title:          a.meta?.title ?? null,\n    meta_description:    a.meta?.description ?? null,\n    meta_tags:           Array.isArray(a.meta?.tags) ? a.meta.tags : null,\n    chatwoot_updated_at: a.updated_at ?? null,\n    chatwoot_category_id: a.category?.id ?? null\n  }\n}));"
            },
            "id": "code-001",
            "name": "Normalizar Artigos",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [80, 300]
        },
        {
            "parameters": {
                "operation": "select",
                "tableId": "faq_items",
                "matchType": "allFilters",
                "filters": {
                    "conditions": [
                        {
                            "keyName": "chatwoot_article_id",
                            "condition": "eq",
                            "keyValue": "={{ $json.chatwoot_article_id }}"
                        }
                    ]
                },
                "returnAll": false,
                "limit": 1
            },
            "id": "sup-001",
            "name": "Buscar no Supabase",
            "type": "n8n-nodes-base.supabase",
            "typeVersion": 1,
            "position": [320, 300],
            "credentials": {
                "supabaseApi": {
                    "id": "Q8FUTrO3QSkHxr8B",
                    "name": "Supabase Cloude - Nome Magnético"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Decide se precisa atualizar:\n// - Artigo novo (não existe no Supabase) → sempre atualiza\n// - Artigo existente → só se updated_at do Chatwoot for mais recente\nconst article    = $('Normalizar Artigos').item.json;\nconst existing   = $input.first().json ?? null;\n\nif (!existing || !existing.id) {\n  // Artigo novo\n  return [{ json: { ...article, needs_update: true, is_new: true } }];\n}\n\nconst cwUpdated  = article.chatwoot_updated_at ? new Date(article.chatwoot_updated_at) : null;\nconst dbUpdated  = existing.updated_at ? new Date(existing.updated_at) : null;\n\nconst needsUpdate = !cwUpdated || !dbUpdated || cwUpdated > dbUpdated;\n\nreturn [{ json: { ...article, existing_id: existing.id, needs_update: needsUpdate, is_new: false } }];"
            },
            "id": "code-002",
            "name": "Verificar se Mudou",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [560, 300]
        },
        {
            "parameters": {
                "dataType": "boolean",
                "value1": "={{ $json.needs_update }}",
                "rules": {
                    "rules": [
                        { "value2": true, "output": 0 }
                    ]
                },
                "fallbackOutput": 1
            },
            "id": "sw-001",
            "name": "Precisa Atualizar?",
            "type": "n8n-nodes-base.switch",
            "typeVersion": 1,
            "position": [800, 300]
        },
