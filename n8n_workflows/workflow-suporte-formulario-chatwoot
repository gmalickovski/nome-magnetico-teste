    {
      "parameters": {
        "jsCode": "// Busca contato no Chatwoot por email; cria se não existir\n// Recebe dados completos de 'Definir Label' (usuário/vip) ou 'Dados Visitante'\nconst dados = $input.item.json;\n\nconst BASE  = 'https://suporte.studiomlk.com.br/api/v1/accounts/1';\nconst TOKEN = '8FsqBLpvNJhZZ73XXiad2XvK';\nconst headers = {\n  'api_access_token': TOKEN,\n  'Content-Type': 'application/json'\n};\n\nconst searchRes  = await fetch(\n  `${BASE}/contacts/search?q=${encodeURIComponent(dados.email)}&include_contacts=true`,\n  { headers }\n);\nconst searchData = await searchRes.json();\n\nconst contacts = searchData.payload?.contacts ?? [];\nconst match    = contacts.find(c => c.email === dados.email);\n\nlet contactId;\nif (match) {\n  contactId = match.id;\n} else {\n  const createRes  = await fetch(`${BASE}/contacts`, {\n    method: 'POST',\n    headers,\n    body: JSON.stringify({ name: dados.nome, email: dados.email })\n  });\n  const createData = await createRes.json();\n  contactId = createData.id;\n}\n\nreturn [{ json: { ...dados, contact_id: contactId, inbox_id: 2 } }];"
      },
