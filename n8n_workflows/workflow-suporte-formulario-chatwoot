      "parameters": {
        "jsCode": "// Prepara dados do visitante após salvar lead\n// O Supabase Create retorna o registro criado — recupera dados do formulário via expressão\nconst dadosForm = $('Preparar Dados').item.json;\nconst labelUsuario = 'nm-visitante';\nconst labelsComStatus = [...(dadosForm.labels || []), labelUsuario];\n\nreturn [{\n  json: {\n    ...dadosForm,\n    tipoUsuario: 'visitante',\n    labelUsuario,\n    labels: labelsComStatus\n  }\n}];"
