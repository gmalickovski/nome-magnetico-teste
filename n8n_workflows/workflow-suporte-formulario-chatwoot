      "parameters": {
        "jsCode": "// Normaliza dados do formulário, mapeia labels e prepara conteúdos\nconst body = $json.body || $json;\n\nconst nome     = body.nome     || body.email?.split('@')[0] || 'Usuário';\nconst email    = body.email    || '';\nconst assunto  = body.assunto  || 'Outros';\nconst mensagem = body.mensagem || '';\nconst origem   = body.origem   || 'publico';\nconst userId   = body.user_id  || null;\nconst ts       = body.timestamp || new Date().toISOString();\n\n// Mapeamento assunto → label Chatwoot\n// Crie essas labels em: Chatwoot → Configurações → Labels\nconst labelMap = {\n  // PublicContactForm\n  'Dúvida sobre os planos':       'planos',\n  'Como funciona a numerologia':  'numerologia',\n  'Informações gerais':           'geral',\n  'Parceria ou imprensa':         'parceria',\n  'Outros':                       'outros',\n  // SupportForm (app)\n  'Bug':                          'bug',\n  'Sugestão':                     'sugestao',\n  'Primeiros Passos':             'primeiros-passos',\n  'Assinatura e Planos':          'assinatura',\n  'Conta e Segurança':            'conta',\n  'Solução de Problemas':         'suporte',\n};\n\nconst assuntoLabel = labelMap[assunto] || 'outros';\nconst origemLabel  = origem === 'app' ? 'usuario-app' : 'site-publico';\n\n// Mensagem formatada para o Chatwoot (aparece como primeira msg da conversa)\nconst dataHora = new Date(ts).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nconst mensagemChatwoot = [\n  `📋 *Assunto:* ${assunto}`,\n  `🌐 *Origem:* ${origem === 'app' ? 'Área do cliente' : 'Site público'}`,\n  userId ? `👤 *User ID:* ${userId}` : null,\n  `📅 *Enviado em:* ${dataHora}`,\n  ``,\n  mensagem\n].filter(Boolean).join('\\n');\n\n// Email HTML de confirmação para o usuário\nconst emailHtml = `\n<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"></head>\n<body style=\"margin:0;padding:0;background:#0f0f0f;font-family:Arial,sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#0f0f0f;padding:40px 20px;\">\n    <tr><td align=\"center\">\n      <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#1a1a1a;border-radius:12px;overflow:hidden;border:1px solid rgba(212,175,55,0.2);\">\n        <!-- Header -->\n        <tr><td style=\"background:linear-gradient(135deg,#1a1a1a 0%,#111 100%);padding:40px 40px 30px;text-align:center;border-bottom:1px solid rgba(212,175,55,0.2);\">\n          <h1 style=\"margin:0;color:#D4AF37;font-size:28px;letter-spacing:2px;\">NOME MAGNÉTICO</h1>\n          <p style=\"margin:8px 0 0;color:#a0a0a0;font-size:14px;\">Central de Suporte</p>\n        </td></tr>\n        <!-- Body -->\n        <tr><td style=\"padding:40px;\">\n          <p style=\"color:#e5e7eb;font-size:16px;margin:0 0 20px;\">Olá, <strong style=\"color:#D4AF37;\">${nome}</strong>!</p>\n          <p style=\"color:#a0a0a0;font-size:15px;line-height:1.6;margin:0 0 24px;\">Recebemos sua mensagem e nossa equipe de suporte irá analisá-la em breve.</p>\n          <!-- Assunto Box -->\n          <div style=\"background:#111;border-left:3px solid #D4AF37;border-radius:4px;padding:16px 20px;margin:0 0 24px;\">\n            <p style=\"margin:0;color:#a0a0a0;font-size:12px;text-transform:uppercase;letter-spacing:1px;\">Assunto recebido</p>\n            <p style=\"margin:4px 0 0;color:#e5e7eb;font-size:15px;font-weight:bold;\">${assunto}</p>\n          </div>\n          <p style=\"color:#a0a0a0;font-size:15px;line-height:1.6;margin:0 0 32px;\">Você receberá nossa resposta em até <strong style=\"color:#e5e7eb;\">24 horas úteis</strong>. Para acompanhar, basta responder este email.</p>\n          <p style=\"color:#e5e7eb;font-size:14px;margin:0;\">Atenciosamente,<br><strong style=\"color:#D4AF37;\">Equipe Nome Magnético</strong></p>\n        </td></tr>\n        <!-- Footer -->\n        <tr><td style=\"padding:20px 40px;border-top:1px solid #2a2a2a;text-align:center;\">\n          <p style=\"margin:0;color:#555;font-size:12px;\">suporte@nomemagnetico.com.br</p>\n        </td></tr>\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>`;\n\nreturn [{\n  json: {\n    nome, email, assunto, mensagem, mensagemChatwoot,\n    emailHtml, origem, userId,\n    labels: [assuntoLabel, origemLabel]\n  }\n}];"
      },
