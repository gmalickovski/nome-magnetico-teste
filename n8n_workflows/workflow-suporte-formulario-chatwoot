    {
      "parameters": {
        "jsCode": "// Normaliza dados do formulário, mapeia labels e prepara conteúdos\nconst body = $json.body || $json;\n\nconst nome     = body.nome     || body.email?.split('@')[0] || 'Usuário';\nconst email    = body.email    || '';\nconst assunto  = body.assunto  || 'Outros';\nconst mensagem = body.mensagem || '';\nconst origem   = body.origem   || 'publico';\nconst userId   = body.user_id  || null;\nconst ts       = body.timestamp || new Date().toISOString();\n\nconst labelMap = {\n  'Dúvida sobre os planos':       'planos',\n  'Como funciona a numerologia':  'numerologia',\n  'Informações gerais':           'geral',\n  'Parceria ou imprensa':         'parceria',\n  'Outros':                       'outros',\n  'Bug':                          'bug',\n  'Sugestão':                     'sugestao',\n  'Primeiros Passos':             'primeiros-passos',\n  'Assinatura e Planos':          'assinatura',\n  'Conta e Segurança':            'conta',\n  'Solução de Problemas':         'suporte',\n};\n\nconst assuntoLabel = labelMap[assunto] || 'outros';\nconst origemLabel  = origem === 'app' ? 'usuario-app' : 'site-publico';\n\nconst dataHora = new Date(ts).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nconst mensagemChatwoot = [\n  `📋 *Assunto:* ${assunto}`,\n  `🌐 *Origem:* ${origem === 'app' ? 'Área do cliente' : 'Site público'}`,\n  userId ? `👤 *User ID:* ${userId}` : null,\n  `📅 *Enviado em:* ${dataHora}`,\n  ``,\n  mensagem\n].filter(Boolean).join('\\n');\n\nconst mensagemPreview = mensagem.length > 220\n  ? mensagem.slice(0, 220).trimEnd() + '...'\n  : mensagem;\n\nconst emailHtml = `<!DOCTYPE html><html lang='pt-BR'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'></head><body style='margin:0;padding:0;background:#f5f5f0;font-family:Helvetica Neue,Helvetica,Arial,sans-serif;'><table width='100%' cellpadding='0' cellspacing='0' style='background:#f5f5f0;padding:48px 0;'><tr><td align='center'><table width='560' cellpadding='0' cellspacing='0' style='background:#ffffff;border-radius:12px;overflow:hidden;'><tr><td style='background:#1a1a1a;padding:32px 40px;text-align:center;'><p style='margin:0;font-family:Georgia,serif;color:#D4AF37;font-size:22px;letter-spacing:3px;font-weight:400;text-transform:uppercase;'>Nome Magn\u00e9tico</p><p style='margin:8px 0 0;color:#a0a0a0;font-size:11px;letter-spacing:2px;text-transform:uppercase;'>Numerologia Cabal\u00edstica</p></td></tr><tr><td style='padding:40px 40px 28px;'><p style='margin:0 0 20px;color:#111;font-size:17px;font-weight:500;'>Ol\u00e1, ${nome}!</p><p style='margin:0 0 24px;color:#444;font-size:15px;line-height:1.7;'>Recebemos sua mensagem e nossa equipe j\u00e1 foi notificada. Faremos o poss\u00edvel para responder o mais breve poss\u00edvel \u2014 geralmente em at\u00e9 1 dia \u00fatil.</p><table width='100%' cellpadding='0' cellspacing='0' style='background:#faf8f2;border-left:4px solid #D4AF37;border-radius:0 6px 6px 0;margin-bottom:28px;'><tr><td style='padding:18px 22px;'><p style='margin:0 0 4px;color:#999;font-size:11px;text-transform:uppercase;letter-spacing:1px;'>Assunto</p><p style='margin:0 0 14px;color:#222;font-size:14px;font-weight:600;'>${assunto}</p><p style='margin:0 0 4px;color:#999;font-size:11px;text-transform:uppercase;letter-spacing:1px;'>Sua mensagem</p><p style='margin:0;color:#555;font-size:14px;line-height:1.6;'>${mensagemPreview}</p></td></tr></table><p style='margin:0;color:#666;font-size:14px;line-height:1.7;'>Caso queira acrescentar alguma informa\u00e7\u00e3o, basta responder diretamente a este email.</p></td></tr><tr><td style='padding:0 40px;'><hr style='border:none;border-top:1px solid #eee;margin:0;'></td></tr><tr><td style='padding:24px 40px 40px;'><p style='margin:0 0 2px;color:#222;font-size:14px;font-weight:600;'>Equipe Nome Magn\u00e9tico</p><p style='margin:0;color:#999;font-size:13px;'>suporte@nomemagnetico.com.br</p></td></tr></table><table width='560' cellpadding='0' cellspacing='0'><tr><td style='padding:20px 0;text-align:center;'><p style='margin:0;color:#aaa;font-size:12px;'>\u00a9 2025 Nome Magn\u00e9tico \u00b7 Todos os direitos reservados</p></td></tr></table></td></tr></table></body></html>`;\n\nreturn [{\n  json: {\n    nome, email, assunto, mensagem, mensagemPreview,\n    mensagemChatwoot, origem, userId,\n    labels: [assuntoLabel, origemLabel],\n    emailHtml\n  }\n}];"
      },
