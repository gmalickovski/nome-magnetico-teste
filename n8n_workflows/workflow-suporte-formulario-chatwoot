    {
      "parameters": {
        "jsCode": "// Lê resultado de 'Buscar Assinatura' e define label nm-vip ou nm-usuario\n// Recebe 1 item de IF TRUE — nunca 0 itens\n// Acessa subscriptions via $('Buscar Assinatura').all()\nconst dados = $input.item.json;\nconst assinaturas = $('Buscar Assinatura').all();\nconst temAtivo = assinaturas.length > 0 &&\n  !assinaturas[0].json.error &&\n  assinaturas.some(s => s.json.is_active === true);\n\nconst tipoUsuario  = temAtivo ? 'vip'      : 'usuario';\nconst labelUsuario = temAtivo ? 'nm-vip'   : 'nm-usuario';\nconst labelsComStatus = [...(dados.labels || []), labelUsuario];\n\nreturn [{\n  json: {\n    ...dados,\n    tipoUsuario,\n    labelUsuario,\n    labels: labelsComStatus\n  }\n}];"
