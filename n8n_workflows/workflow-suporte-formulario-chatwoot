    {
      "parameters": {
        "jsCode": "// Busca contato no Chatwoot por email; cria se não existir\n// Retorna todos os dados + contact_id pronto para o próximo node\nconst dados = $input.first().json;\nconst BASE   = 'https://suporte.studiomlk.com.br/api/v1/accounts/1';\nconst TOKEN  = '8FsqBLpvNJhZZ73XXiad2XvK';\nconst INBOX_ID = 2;\n\nconst headers = {\n  'api_access_token': TOKEN,\n  'Content-Type': 'application/json'\n};\n\n// 1. Buscar contato por email\nconst searchRes  = await fetch(`${BASE}/contacts/search?q=${encodeURIComponent(dados.email)}&include_contacts=true`, { headers });\nconst searchData = await searchRes.json();\n\nconst contacts = searchData.payload?.contacts ?? [];\nconst match    = contacts.find(c => c.email === dados.email);\n\nlet contactId;\nif (match) {\n  contactId = match.id;\n} else {\n  // 2. Criar novo contato\n  const createRes  = await fetch(`${BASE}/contacts`, {\n    method: 'POST',\n    headers,\n    body: JSON.stringify({\n      name:  dados.nome,\n      email: dados.email\n    })\n  });\n  const createData = await createRes.json();\n  contactId = createData.id;\n}\n\nreturn [{ json: { ...dados, contact_id: contactId, inbox_id: INBOX_ID } }];"
      },
