      "parameters": {
        "jsCode": "// Normaliza dados do formulário e prepara labels + mensagem formatada\nconst body = $json.body || $json;\n\nconst nome    = body.nome    || body.email?.split('@')[0] || 'Usuário';\nconst email   = body.email   || 'sem-email@nome-magnetico.com.br';\nconst assunto = body.assunto || 'Outros';\nconst mensagem= body.mensagem|| '';\nconst origem  = body.origem  || 'publico';\nconst userId  = body.user_id || null;\nconst ts      = body.timestamp || new Date().toISOString();\n\n// Mapeamento assunto → label Chatwoot (crie essas labels no Chatwoot antes)\nconst labelMap = {\n  // PublicContactForm\n  'Dúvida sobre os planos':       'planos',\n  'Como funciona a numerologia':  'numerologia',\n  'Informações gerais':           'geral',\n  'Parceria ou imprensa':         'parceria',\n  'Outros':                       'outros',\n  // SupportForm (app)\n  'Bug':                          'bug',\n  'Sugestão':                     'sugestao',\n  'Primeiros Passos':             'primeiros-passos',\n  'Assinatura e Planos':          'assinatura',\n  'Conta e Segurança':            'conta',\n  'Solução de Problemas':         'suporte',\n};\n\nconst assuntoLabel = labelMap[assunto] || 'outros';\nconst origemLabel  = origem === 'app' ? 'usuario-app' : 'site-publico';\n\n// Mensagem formatada que vai aparecer na conversa do Chatwoot\nconst dataHora = new Date(ts).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nconst mensagemFormatada = [\n  `📋 *Assunto:* ${assunto}`,\n  `🌐 *Origem:* ${origem === 'app' ? 'Área do cliente' : 'Site público'}`,\n  userId ? `👤 *User ID:* ${userId}` : null,\n  `📅 *Enviado em:* ${dataHora}`,\n  ``,\n  mensagem\n].filter(Boolean).join('\\n');\n\nreturn [{\n  json: {\n    nome,\n    email,\n    assunto,\n    mensagem,\n    mensagemFormatada,\n    origem,\n    userId,\n    labels: [assuntoLabel, origemLabel]\n  }\n}];"
      },
