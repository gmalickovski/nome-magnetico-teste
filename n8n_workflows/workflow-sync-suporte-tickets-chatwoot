            "parameters": {
                "jsCode": "// Apenas lógica: extrai dados e calcula labels. Sem chamadas HTTP.\nconst record = $node['Webhook (Supabase)'].json.body.record;\n\nconst LABEL_MAP = {\n  'Bug':                           'nm-bug',\n  'Sugestão':                      'nm-sugestao',\n  'Primeiros Passos':              'nm-primeiros-passos',\n  'Assinatura e Planos':           'nm-assinaturas-e-planos',\n  'Conta e Segurança':             'nm-conta-e-seguranca',\n  'Solução de Problemas':          'nm-solucao-de-problemas',\n  'Dúvida sobre os planos':        'nm-duvida-sobre-planos',\n  'Como funciona a numerologia':   'nm-como-funciona',\n  'Informações gerais':            'nm-informacoes-gerais',\n  'Parceria ou imprensa':          'nm-parceria',\n  'Outros':                        'nm-outros',\n};\n\nconst labels = [];\nif (LABEL_MAP[record.subject]) labels.push(LABEL_MAP[record.subject]);\nif (record.priority === 'urgent') labels.push('nm-vip');\nif (record.priority === 'normal') labels.push('nm-usuario');\nif (record.priority === 'low') labels.push('nm-visitante');\n\nreturn [{ json: {\n  email:     record.contact_email || 'visitante@nomemagnetico.com.br',\n  name:      record.contact_name  || 'Visitante',\n  subject:   record.subject,\n  priority:  record.priority,\n  ticket_id: record.id,\n  labels,\n} }];"
            },
