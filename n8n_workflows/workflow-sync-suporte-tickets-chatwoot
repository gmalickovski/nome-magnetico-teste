        {
            "parameters": {
                "jsCode": "// Extrai contact_id de qualquer caminho (encontrado ou criado)\n// e repassa o nome do ticket para atualização no Chatwoot\nconst input = $input.first().json;\nconst name = $node['Preparar Dados'].json.name;\n\n// Caminho 'encontrado': payload[]\nif (input.payload && input.payload.length > 0) {\n  return [{ json: { chatwoot_contact_id: input.payload[0].id, contact_name: name } }];\n}\n// Caminho 'criado': id direto\nif (input.id) {\n  return [{ json: { chatwoot_contact_id: input.id, contact_name: name } }];\n}\nthrow new Error('Não foi possível obter contact_id do Chatwoot');"
            },
